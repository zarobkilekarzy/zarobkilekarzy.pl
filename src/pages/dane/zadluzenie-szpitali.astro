---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareRow from '../../components/ShareRow.astro';
import Aktualizacja from '../../components/Aktualizacja.astro';
import { getCollection } from 'astro:content';

const dlug = (await getCollection('zarobki'))
  .filter((z) => z.data.grupa === 'zadluzenie')
  .sort((a, b) => a.data.kolejnosc - b.data.kolejnosc);

const fmt = (n: number) => new Intl.NumberFormat('pl-PL').format(n);

// Zweryfikowane statystyki skali — do siatki kart (neutralne, nie alarmowe).
const skala = [
  {
    v: '298', u: 'szpitali', opis: 'ma zobowiązania <strong>wymagalne</strong> (przeterminowane) — to ponad połowa (53%) wszystkich publicznych.',
    src: 'Rzeczpospolita', url: 'https://www.rp.pl/ochrona-zdrowia/art44638431-rosnie-zadluzenie-publicznych-szpitali-to-juz-34-mld-zlotych',
  },
  {
    v: '91%', u: 'na minusie', opis: 'szpitali powiatowych zamknęło 2025 r. <strong>stratą</strong> na działalności podstawowej — na plusie tylko 19 z 207.',
    src: 'Menedżer Zdrowia', url: 'https://www.termedia.pl/mz/Finanse-szpitali-powiatowych-systematyczne-narastanie-strat-,66853.html',
  },
  {
    v: '~½', u: 'placówek', opis: 'zbadanych szpitali ma <strong>dług większy niż wartość całego majątku</strong>.',
    src: 'Rynek Zdrowia', url: 'https://www.rynekzdrowia.pl/Finanse-i-zarzadzanie/Az-trudno-uwierzyc-W-polowie-zbadanych-szpitali-dlug-przekracza-wartosc-majatku,283326,1.html',
  },
  {
    v: '344', u: 'mln zł', opis: 'to same <strong>odsetki</strong> od długów szpitali powiatowych (2025) — koszty finansowe były 7× większe niż ich przychody finansowe.',
    src: 'Menedżer Zdrowia', url: 'https://www.termedia.pl/mz/Finanse-szpitali-powiatowych-systematyczne-narastanie-strat-,66853.html',
  },
  {
    v: '5,5–10', u: 'mld zł', opis: 'tyle pochłonie <strong>oddłużanie</strong> publicznych szpitali w perspektywie dekady — z pieniędzy publicznych.',
    src: 'Prawo.pl', url: 'https://www.prawo.pl/zdrowie/jak-oddluzyc-polskie-szpitale-raport-zdrowie-ponad-dlugi,1543437.html',
  },
];

// „Lista wstydu” — pojedyncze szpitale z największą roczną stratą netto (wstępny wynik 2024,
// dane MZ zebrane przez Menedżera Zdrowia). MZ publikuje długi tylko zbiorczo (po województwach).
const listaWstydu = [
  { rola: 'Woj. Szpital Specjalistyczny im. M. Pirogowa', miasto: 'Łódź', kwota: 88013861 },
  { rola: 'Woj. Szpital Specjalistyczny im. kard. Wyszyńskiego', miasto: 'Lublin', kwota: 79949350 },
  { rola: 'Woj. Szpital Specjalistyczny im. NMP', miasto: 'Częstochowa', kwota: 54576624,
    dlug: 'Faktyczny dług placówki: <strong>172 mln zł</strong> zobowiązań <strong>wymagalnych</strong> (31.12.2025; 175 mln na 31.03.2026), ok. <strong>289 mln zł</strong> ogółem — <strong>jeden z trzech najbardziej zadłużonych szpitali w Polsce</strong>. Podlega marszałkowi woj. śląskiego; strata za 2025 urosła już do ~85 mln zł, a same koszty obsługi długu do 43 mln zł.' },
  { rola: 'Szpital Wojewódzki im. Jana Pawła II', miasto: 'Bełchatów', kwota: 51320479, hot: true },
  { rola: 'Woj. Szpital Zespolony im. J. Śniadeckiego', miasto: 'Białystok', kwota: 47555530 },
  { rola: 'Wojewódzki Szpital Zespolony', miasto: 'Płock', kwota: 45119750 },
  { rola: 'Woj. Szpital Specjalistyczny im. M. Skłodowskiej-Curie', miasto: 'Zgierz', kwota: 43297412 },
  { rola: 'Samodzielny Publiczny ZOZ', miasto: 'Sanok', kwota: 39857634 },
  { rola: 'Szpital Wojewódzki im. Prymasa kard. S. Wyszyńskiego', miasto: 'Sieradz', kwota: 38206531 },
  { rola: 'Radomski Szpital Specjalistyczny im. dr. T. Chałubińskiego', miasto: 'Radom', kwota: 37659046 },
];
---

<BaseLayout
  title="Zadłużenie szpitali — zarobkilekarzy.pl"
  description="Dług publicznych szpitali sięga 34 mld zł i idzie nie na inwestycje, lecz na bieżącą działalność — głównie wynagrodzenia. To pensje wypłacane na kredyt, który spłacamy ze środków publicznych."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow"><a href="/dane/">Dane</a> · Zadłużenie szpitali</p>
      <h1>Zadłużenie szpitali: pensje wypłacane na kredyt</h1>
      <Aktualizacja />
      <p class="lead">
        Dług publicznych szpitali przekroczył <strong>34 mld zł</strong> na koniec 2025 r.,
        a po pierwszym kwartale 2026 przebił <strong>37 mld zł</strong> — i nie przestaje
        rosnąć. Kluczowe: te pieniądze idą <strong>nie na inwestycje, lecz na bieżącą
        działalność — głównie wynagrodzenia</strong>. To znaczy, że część pensji jest de
        facto wypłacana <strong>na kredyt</strong>, który ostatecznie spłaca podatnik.
      </p>

      <div class="data-grid">
        {dlug.map((z) => (
          <div class="data-card">
            <p class="k">{z.data.etykieta}</p>
            <p class="v">{fmt(z.data.kwota).replace('.', ',')} {z.data.jednostka}</p>
            <p class="src">
              {z.data.uwaga && <span>{z.data.uwaga} · </span>}
              <a href={z.data.zrodloUrl} target="_blank" rel="noopener noreferrer">{z.data.zrodloNazwa}</a>
            </p>
          </div>
        ))}
      </div>

      <div class="callout" style="border-left-color: var(--alert); background: var(--alert-50); margin-top: 1.5rem">
        <p>
          <strong>Skąd ten dług?</strong> Zobowiązania publicznych szpitali nie służą
          strategicznym inwestycjom, lecz finansowaniu <strong>bieżącej działalności</strong> —
          przede wszystkim kosztów wynagrodzeń. Same wydatki na personel podczas dyżurów
          potrafią stanowić <strong>70–80% kosztów</strong> placówki, a w skrajnych
          przypadkach same pensje przekraczają cały budżet placówki: „w niektórych
          szpitalach na wynagrodzenia przeznaczone jest nawet <strong>106 proc. budżetu</strong>,
          co jest skrajnie trudną sytuacją dla podmiotu” — przyznała ministra zdrowia (maj
          2026). Kolejne ustawowe podwyżki (od 1 lipca) dokładają do tego obciążenia.
        </p>
        <p>
          Ponieważ zadłużone szpitale tracą zdolność kredytową, na spłatę wymagalnych
          zobowiązań biorą <strong>pożyczki</strong> od instytucji finansowych — czyli
          zadłużają się dalej, by wypłacić bieżące pensje. W praktyce część wynagrodzeń jest
          finansowana długiem, który i tak spłaca się ze środków publicznych (dotacje,
          oddłużanie). Płacimy więc <strong>dwa razy</strong>: raz za pracę, drugi raz za
          odsetki od tego, że nie było na nią pieniędzy.
        </p>
      </div>

      <p class="source-note">
        Dług 34 mld zł na koniec 2025 (562 placówki: SPZOZ 27 + spółki 4,1 + instytuty 2,9 mld)
        i przekroczenie 37 mld po I kw. 2026 —
        <a href="https://www.rynekzdrowia.pl/Finanse-i-zarzadzanie/Szpitale-tona-w-dlugach-Zadluzenie-siega-blisko-40-mld-zl,286396,1.html" target="_blank" rel="noopener noreferrer">Rynek Zdrowia</a>;
        rekordowy skok zobowiązań wymagalnych (+19,6% kw/kw) —
        <a href="https://politykazdrowotna.com/artykul/zadluzenie-szpitali-n2230555" target="_blank" rel="noopener noreferrer">Polityka Zdrowotna</a>
        (dane MZ); charakter długu (bieżąca działalność, nie inwestycje) —
        <a href="https://www.rp.pl/ochrona-zdrowia/art44638431-rosnie-zadluzenie-publicznych-szpitali-to-juz-34-mld-zlotych" target="_blank" rel="noopener noreferrer">Rzeczpospolita</a>;
        wynagrodzenia jako główny koszt i pożyczki na spłatę —
        <a href="https://www.egospodarka.pl/197895,Szpitale-pod-sciana-Od-1-lipca-rosna-pensje-medykow-a-zadluzenie-juz-dlawi-placowki,1,24,1.html" target="_blank" rel="noopener noreferrer">eGospodarka</a>,
        <a href="https://politykazdrowotna.com/artykul/zadluzenie-szpitali-n2230555" target="_blank" rel="noopener noreferrer">Polityka Zdrowotna</a>;
        „do 106% budżetu na pensje” —
        <a href="https://www.rynekzdrowia.pl/Polityka-zdrowotna/Ministra-zdrowia-w-niektorych-szpitalach-pensje-pochlaniaja-106-proc-budzetu-Resort-chce-limitu,284133,14.html" target="_blank" rel="noopener noreferrer">Rynek Zdrowia</a>.
        NIK: zadłużenie lecznic nie zmienia się od lat.
      </p>

      <h2 style="margin-top: 2.75rem">Skala w liczbach</h2>
      <p class="muted" style="max-width: 66ch; margin-top: 0.5rem">
        34 mld zł to suma zbiorcza. Dopiero rozbicie pokazuje, jak głęboki jest problem —
        i jak bardzo dług przestał być wyjątkiem, a stał się <em>normalnym</em> sposobem
        finansowania bieżącej działalności.
      </p>
      <div class="skala-grid">
        {skala.map((s) => (
          <div class="skala-card">
            <p class="skala-v">{s.v} <span class="skala-u">{s.u}</span></p>
            <p class="skala-opis" set:html={s.opis} />
            <p class="skala-src"><a href={s.url} target="_blank" rel="noopener noreferrer">{s.src}</a></p>
          </div>
        ))}
      </div>
      <p class="source-note" style="margin-top: 0.9rem">
        Zakres bywa różny: dane o stratach i odsetkach dotyczą <strong>szpitali powiatowych</strong>
        (próba wg Menedżera Zdrowia), zobowiązania wymagalne i suma 34 mld zł — ogółu publicznych
        SPZOZ. Mimo różnych prób obraz jest zbieżny: <strong>dług jest strukturalny, nie incydentalny</strong>.
      </p>

      <h2 style="margin-top: 2.75rem">Które szpitale? „Lista wstydu”</h2>
      <p class="muted" style="max-width: 68ch; margin-top: 0.5rem">
        Ministerstwo Zdrowia podaje długi <strong>tylko zbiorczo</strong> (po województwach) — nie
        per placówka. Pojedyncze szpitale widać jednak przez ich <strong>roczny wynik</strong>: oto
        dziesięć z największą stratą netto za 2024 r. (dane wstępne MZ). Przy <strong>Częstochowie</strong>
        (#3) pokazujemy dodatkowo <strong>faktyczny dług placówki</strong> — rzadki wyjątek, bo akurat
        ujawnił go organ prowadzący. Na dole — <strong>Kalisz</strong>, odwrotny przypadek: zysk na
        papierze, a dług ukryty.
      </p>
      <div class="table-wrap">
        <table class="lw">
          <thead>
            <tr><th>#</th><th>Szpital</th><th>Strata netto (2024)</th></tr>
          </thead>
          <tbody>
            {listaWstydu.map((s, i) => (
              <tr class={s.hot ? 'is-hot' : ''}>
                <td class="lw-rank">{i + 1}</td>
                <th scope="row">{s.rola}<span class="lw-city">{s.miasto}</span>{s.dlug && <span class="lw-dlug" set:html={s.dlug} />}</th>
                <td class="lw-num">{fmt(s.kwota)} zł</td>
              </tr>
            ))}
            <tr class="lw-note">
              <td class="lw-rank" aria-hidden="true">◆</td>
              <th scope="row">
                Wojewódzki Szpital Zespolony im. Perzyny
                <span class="lw-city"><strong>Kalisz</strong> · za 2024 r. wykazał <strong>zysk ~2,2 mln zł</strong> — a mimo to zalegał pielęgniarkom. <a href="#kalisz">więcej ↓</a></span>
              </th>
              <td class="lw-num">37 mln zł<span class="lw-tag">dług ukryty, nie strata*</span></td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="callout quiet">
        <p>
          Zwróć uwagę na <strong>#4 — Bełchatów</strong>. To ten sam szpital, w którym ujawniono
          <strong>rekordowe kontrakty</strong> (urolog 151 097 zł/mc, ortopeda 142 032 zł/mc). Placówka
          z czwartą największą roczną stratą w kraju wypłaca jedne z najwyższych stawek — a widać to
          tylko dlatego, że akurat ten szpital je <a href="/dane/rekordy/">ujawnił</a>. Ile podobnych
          zestawień kryje się tam, gdzie stawek się nie publikuje, <strong>nie wiadomo</strong>.
        </p>
      </div>
      <p class="source-note">
        Ranking strat netto pojedynczych szpitali (wstępny wynik 2024) —
        <a href="https://www.termedia.pl/mz/Lista-wstydu-,63573.html" target="_blank" rel="noopener noreferrer">„Lista wstydu”, Menedżer Zdrowia</a> (dane MZ);
        cztery z pierwszej dziesiątki to szpitale z woj. łódzkiego (Łódź, Bełchatów, Zgierz, Sieradz).
        <strong>*</strong> Kalisz nie jest w rankingu strat — za 2024 r. wykazał <strong>zysk ~2,2 mln zł</strong>
        (sprawozdanie, KRS), a mimo to zalegał <strong>37 mln zł</strong> wobec pielęgniarek: dowód, że
        sam wynik netto nie pokazuje ukrytych zobowiązań.
        Długi zbiorczo (po województwach) — <a href="https://www.gov.pl/web/zdrowie/zadluzenie-spzoz" target="_blank" rel="noopener noreferrer">Ministerstwo Zdrowia</a>.
        Faktyczny dług Woj. Szpitala Specjalistycznego im. NMP w Częstochowie („Parkitka”, organ
        prowadzący: marszałek woj. śląskiego): zobowiązania wymagalne ~172 mln zł (31.12.2025), 175 mln
        na 31.03.2026, strata ~85 mln zł (2025), obsługa długu 43 mln zł, „jeden z trzech najbardziej
        zadłużonych szpitali w Polsce” —
        <a href="https://zdrowie.dziennik.pl/aktualnosci/artykuly/599197,parkitka-szpital-czestochowa-lekarze-dyzury.html" target="_blank" rel="noopener noreferrer">Dziennik.pl</a>,
        <a href="https://zycieczestochowy.pl/85-mln-zl-dlugu-zajecia-komornicze-i-plan-ratunkowy-dyrekcja-szpitala-na-parkitce-rozmawiala-z-mediami/" target="_blank" rel="noopener noreferrer">Życie Częstochowy</a>;
        zobowiązania ogółem ~289 mln zł (31.12.2025) — dane marszałka woj. śląskiego, przywołane w
        <a href="https://x.com/JerzyPolaczek/status/2074742367060394337" target="_blank" rel="noopener noreferrer">interpelacji poselskiej (X)</a>.
      </p>

      <h2 id="kalisz" style="margin-top: 2.75rem">Jeden szpital, cała mechanika: Kalisz</h2>
      <p class="muted" style="max-width: 68ch; margin-top: 0.5rem">
        Zadłużenie brzmi abstrakcyjnie, dopóki nie zejdzie się do jednej placówki. Wojewódzki
        Szpital Zespolony im. Ludwika Perzyny w Kaliszu pokazuje cały mechanizm naraz: ten sam
        publiczny pieniądz, a dwie skrajnie różne strony.
      </p>

      <div class="case">
        <div class="case-cols">
          <div class="case-col">
            <p class="case-k">Zaległe wynagrodzenia personelu</p>
            <p class="case-v">~37 mln zł</p>
            <p class="case-d">
              Głównie <strong>240 pielęgniarek</strong> — wyrównania za lata błędnego
              zaszeregowania i zaniżonych stawek. Dług ujawnił dopiero <strong>audyt nowej
              dyrekcji</strong> (lipiec 2024); wcześniej dokumentacja go nie pokazywała.
              Kontrola wykazała nieprawidłowości z okresu poprzedniej dyrekcji — sprawę
              skierowano do prokuratury (zarzut, w toku).
            </p>
          </div>
          <div class="case-col">
            <p class="case-k">Kontrakty czterech lekarzy</p>
            <p class="case-v is-accent">~10 mln zł<span class="case-per">/rok razem</span></p>
            <p class="case-d">
              Czterej specjaliści (m.in. ginekologia, kardiologia, neurochirurgia) z kontraktami
              rzędu <strong>2–2,5 mln zł rocznie</strong> każdy (media pisały o „ponad 250 tys.
              zł miesięcznie”). Ostatnie umowy podpisano <strong>na kilka dni przed zmianą
              dyrekcji</strong> (koniec czerwca 2024).
            </p>
          </div>
        </div>
        <div class="case-foot">
          <p class="case-foot-lead">A do tego, w tym samym czasie:</p>
          <ul class="case-extra">
            <li>NFZ zalega szpitalowi <strong>ponad 4 mln zł</strong> za wykonane świadczenia.</li>
            <li>Oddział <strong>urologii</strong> zawieszony od sierpnia 2025 — z braku lekarzy (wznowienie zapowiadane na czerwiec 2026).</li>
          </ul>
        </div>
      </div>

      <blockquote class="case-quote">
        „Od lat nie dostawałyśmy tego, co powinnyśmy, a tu kilku specjalistów inkasuje miliony.
        To jest naprawdę chora sytuacja.”
        <cite>— pielęgniarka szpitala, cyt. za Frondą</cite>
      </blockquote>

      <div class="callout quiet">
        <p>
          To nie jest historia o „chciwych lekarzach” — kontrakty są <strong>legalne i jawne</strong>.
          Sednem jest <strong>alokacja</strong>: w jednej placówce garstka kontraktów pochłania w rok
          tyle, ile latami zalegano setkom pielęgniarek — a oddział pada nie „bo nie ma pieniędzy”,
          lecz bo pieniądz rozłożono nieprzejrzyście. Skalę tego zestawienia poznano dopiero, gdy
          <strong>ktoś policzył je ręcznie</strong> po zmianie dyrekcji. Rejestr powiązany z numerem
          <a href="/postulat/">PWZ</a> pokazywałby taki obraz w każdym szpitalu <strong>w jeden dzień</strong>.
        </p>
      </div>
      <p class="source-note">
        Dług, kontrakty i zaległości NFZ —
        <a href="https://calisia.pl/zadluzenie-szpitala-wysokie-wynagrodzenia-lekarzy-i-milionowe-zaleglosci-nfz-mamy-oficjalne-wyjasnienia-dyrektora-placowki,74768" target="_blank" rel="noopener noreferrer">Calisia.pl</a> (wyjaśnienia dyrektora),
        <a href="https://kalisz24.info.pl/40-mln-zl-dlugu-milionowe-kontrakty-lekarzy-i-zaleglosci-narodowego-funduszu-zdrowia/" target="_blank" rel="noopener noreferrer">kalisz24.info</a>,
        <a href="https://portal.abczdrowie.pl/szpital-w-kaliszu-z-37-mln-zl-dlugu-nowy-dyrektor-ujawnia-skale-zaniedban/7183447202130688a" target="_blank" rel="noopener noreferrer">abcZdrowie</a>,
        <a href="https://www.fronda.pl/a/Miliony-dla-lekarzy-a-szpital-tonie-w-dlugach,249058.html" target="_blank" rel="noopener noreferrer">Fronda</a>;
        zawieszenie i odbudowa urologii —
        <a href="https://kalisz.eska.pl/kalisz-co-dalej-z-urologia-w-szpitalu-jest-realna-mozliwosc-odbudowy-oddzialu-aa-pkvj-q84o-oRkB.html" target="_blank" rel="noopener noreferrer">ESKA Kalisz</a>.
        Bez nazwisk — opisujemy placówkę i role, nie osoby.
      </p>

      <p class="pager"><a href="/dane/budzet-nfz/">← Budżet NFZ</a> · <a href="/dane/">Wszystkie dane →</a></p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <ShareRow heading="Pomóż nagłośnić sprawę:" />
    </div>
  </section>
</BaseLayout>

<style>
  .skala-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; margin: 1.25rem 0 0; }
  .skala-card { background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: 1.25rem; }
  .skala-v { font-family: var(--font-mono); font-size: 2rem; font-weight: 600; color: var(--ink); margin: 0 0 0.5rem; line-height: 1; }
  .skala-u { font-family: var(--font-sans); font-size: 0.9rem; font-weight: 500; color: var(--ink-soft); }
  .skala-opis { font-size: 0.9rem; color: var(--ink); line-height: 1.5; margin: 0 0 0.6rem; }
  .skala-opis :global(strong) { font-weight: 600; }
  .skala-src { font-size: 0.78rem; margin: 0; }
  .skala-src a { color: var(--ink-faint); }
  .skala-src a:hover { color: var(--brand); }

