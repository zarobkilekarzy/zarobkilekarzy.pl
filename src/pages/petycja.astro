---
// LANDING AKCYJNY (do sharowania) — skupiony na WYSŁANIU. Publiczny: indeksowany, w sitemap,
// linkowany z nawigacji i strony głównej. Teoria → /petycja/jak-to-dziala; treść → komponent
// <PetycjaTresc /> (jedno źródło: src/lib/petycja.ts). JEDNA treść petycji, wysyłana do
// Ministerstwa Zdrowia (mailem — najprościej) i opcjonalnie do Senatu (pismo ogólne/poczta).
import BaseLayout from '../layouts/BaseLayout.astro';
import PetycjaTresc from '../components/PetycjaTresc.astro';
import LicznikPetycji from '../components/LicznikPetycji.astro';
import PetycjaShare from '../components/PetycjaShare.astro';
import AktualizacjaUstawa from '../components/AktualizacjaUstawa.astro';
import { PETYCJA_TRESC, PETYCJA_TEMAT, ADRESACI, KORESPONDENCJA, fillPetycja } from '../lib/petycja';
import { Picture } from 'astro:assets';
import gov1 from '../assets/petycja-govpl/1.webp';
import gov2 from '../assets/petycja-govpl/2.webp';
import gov3 from '../assets/petycja-govpl/3.webp';
import gov4 from '../assets/petycja-govpl/4.webp';
import gov5 from '../assets/petycja-govpl/5.webp';

const MZ_EMAIL = ADRESACI.mz.email;

// Fallback mailto prerenderowany build-time — przycisk „Otwórz mail” działa też bez JS
// (placeholdery do samodzielnego uzupełnienia); skrypt nadpisuje href danymi z formularza.
const MAILTO_DEFAULT =
  'mailto:' + MZ_EMAIL +
  '?subject=' + encodeURIComponent(PETYCJA_TEMAT) +
  '&body=' + encodeURIComponent('Adresat: Minister Zdrowia\n\n' + fillPetycja());

// Linie adresowe do nagłówka wydruku (proste obiekty — trafiają do define:vars).
const ADRESACI_BLOK = { mz: ADRESACI.mz.blok, senat: ADRESACI.senat.blok };

// STAN AKCJI — wartości aktualizowane RĘCZNIE przy każdej zmianie (jedno miejsce).
// naLiscieMZ: null = jeszcze nie widać / nie sprawdzono; liczba = ile petycji w tej
// sprawie widnieje na liście MZ. ogloszeniePW: null albo { do: 'data', url: '...' }.
const STAN = {
  aktualizacja: '13 lipca 2026',
  naLiscieMZ: null as number | null,
  ogloszeniePW: null as { do: string; url: string } | null,
  odpowiedz: null as { data: string; url: string } | null,
};
const LISTA_MZ_URL = 'https://www.gov.pl/web/zdrowie/petycje2';
---

<BaseLayout
  title="Wyślij petycję — jawność wynagrodzeń lekarzy"
  description="Wyślij gotową petycję o jawny rejestr wynagrodzeń lekarzy ze środków publicznych — do Ministerstwa Zdrowia (i opcjonalnie do Senatu). Wpisz imię, skopiuj, wyślij."
>
  <AktualizacjaUstawa />
  <section class="section">
    <div class="container pet-wrap">
      <div class="pet-main">
      <p class="eyebrow">Petycja</p>
      <h1>Wyślij petycję o jawność wynagrodzeń lekarzy</h1>
      <p class="lead">
        Gotowa, formalna petycja o jawny rejestr wynagrodzeń ze środków publicznych.
        Wpisz imię, skopiuj, wyślij. Zajmie minutę.
      </p>

      <div class="pet-subnav">
        <a class="btn btn-primary" href="#wyslij">Wyślij teraz ↓</a>
        <a class="pet-subnav-link" href="/petycja/jak-to-dziala/">Jak to działa — i dlaczego tak</a>
        <a class="pet-subnav-link" href="/petycja/tresc/">Pełna treść petycji →</a>
      </div>

      <!-- SKUTKI PRAWNE -->
      <h2 class="blk">Co zrobi Twoja petycja</h2>
      <div class="effects">
        <div class="effect">
          <span class="effect-tag">Ministerstwo Zdrowia</span>
          <p>
            Urząd ma <strong>prawny obowiązek</strong> ją rozpatrzyć i
            <strong>odpowiedzieć w 3 miesiące</strong>. Nie może jej zignorować.
          </p>
        </div>
        <div class="effect">
          <span class="effect-tag">Senat (opcjonalnie)</span>
          <p>
            Ta sama treść wysłana do Senatu trafia do <strong>Komisji Petycji</strong>,
            która może przekuć postulat w <strong>projekt ustawy</strong>.
          </p>
        </div>
      </div>
      <p class="effects-foot">
        Jedna treść, dwa możliwe adresy — <strong>wyślij najpierw do Ministerstwa Zdrowia</strong>,
        a jeśli chcesz wzmocnić, także do Senatu.
      </p>

      <!-- AKCJA -->
      <div class="action-zone">
      <h2 class="blk" id="wyslij" style="scroll-margin-top: 1.5rem">Uzupełnij i wyślij</h2>

      <div class="mail-card">
      <div class="gen-form">
        <div class="field">
          <label for="imie">Imię i nazwisko</label>
          <input id="imie" type="text" autocomplete="name" placeholder="np. Jan Kowalski" />
        </div>
        <div class="field">
          <label for="miejscowosc">Miejscowość</label>
          <input id="miejscowosc" type="text" autocomplete="address-level2" placeholder="np. Poznań" />
        </div>
      </div>
      <p class="privacy-hint">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
        <span><strong>Nie zapisujemy tych danych.</strong> Wszystko dzieje się lokalnie w Twojej
        przeglądarce — służą tylko do wpisania Cię w treść petycji, nic nie trafia na żaden serwer.</span>
      </p>
      <p class="gen-warn" id="genWarn" role="alert" hidden></p>

      <!-- JEDNA treść petycji (komponent = jedno źródło prawdy) -->
        <div class="mail-row">
          <span class="mail-k">Temat</span>
          <span class="mail-v">{PETYCJA_TEMAT}</span>
        </div>
        <div class="pet-doc">
          <div class="pet-doc-label">
            <span>Treść petycji — to wysyłasz</span>
            <span class="pet-doc-hint" aria-hidden="true">przewiń, aby przeczytać całość ↓</span>
          </div>
          <div class="pet-doc-box">
            <div class="petbox">
              <PetycjaTresc id="petbody" />
            </div>
          </div>
        </div>
        <div class="cta-row">
          <button class="btn btn-primary" id="copyBtn" type="button">Kopiuj treść</button>
          <a class="btn" id="mailtoMz" href={MAILTO_DEFAULT}>Otwórz mail do Min. Zdrowia</a>
          <button class="btn" id="printBtn" type="button" aria-expanded="false" aria-controls="printChoice">Drukuj</button>
        </div>
        <div class="print-choice" id="printChoice" hidden>
          <span class="print-choice-label">Wydruk dla:</span>
          <button class="btn" type="button" data-print="mz">Ministerstwa Zdrowia</button>
          <button class="btn" type="button" data-print="senat">Senatu</button>
        </div>
        <p class="mailto-hint">
          Po otwarciu maila sprawdź, czy treść jest kompletna — powinna kończyć się stopką
          o ZarobkiLekarzy.pl. Niektóre programy pocztowe ucinają tak długie wiadomości;
          wtedy wróć i użyj „Kopiuj treść”.
        </p>
        <p class="mail-addr">
          Mail trafia na adres Ministerstwa Zdrowia: <strong>{MZ_EMAIL}</strong>
        </p>
        <p class="senat-opt">
          <strong>Chcesz wzmocnić?</strong> Wyślij <strong>tę samą treść</strong> także do Senatu.
          Jak to zrobić — do Ministerstwa Zdrowia i do Senatu — masz krok po kroku niżej w
          <a href="#jak-wyslac">„Jak wysłać”</a>.
        </p>
      </div>
      </div><!-- /.action-zone -->

      <!-- JAK WYSŁAĆ -->
      <h2 class="blk" id="jak-wyslac" style="scroll-margin-top: 1.5rem">Jak wysłać</h2>
      <p class="muted" style="max-width: 66ch">
        Masz jedną treść (wyżej) i dwa możliwe adresy: wyślij najpierw do Ministerstwa Zdrowia,
        a do Senatu — jeśli chcesz wzmocnić. Każdy z poniższych sposobów jest tak samo ważny.
      </p>

      <div class="tabs">
        <input class="tab-in" type="radio" name="jakway" id="way-mail" checked />
        <input class="tab-in" type="radio" name="jakway" id="way-gov" />
        <input class="tab-in" type="radio" name="jakway" id="way-druk" />
        <div class="tablist">
          <label class="tab-lab" for="way-mail">E-mailem</label>
          <label class="tab-lab" for="way-gov">Pismo ogólne (gov.pl)</label>
          <label class="tab-lab" for="way-druk">Wydruk i poczta</label>
        </div>
        <div class="tab-pane" id="pane-mail">
          <p>
            Najprościej: kliknij <strong>„Otwórz mail do Min. Zdrowia”</strong> wyżej — temat
            i treść wpiszą się same. Albo skopiuj treść i wyślij ręcznie na adres:
          </p>
          <p class="addr-mono">{MZ_EMAIL}</p>
          <p>
            Petycja wysłana e-mailem jest w pełni ważna. Senat nie udostępnia adresu e-mail do
            petycji — do niego użyj zakładki „Pismo ogólne (gov.pl)” lub „Wydruk i poczta”.
          </p>
        </div>
        <div class="tab-pane" id="pane-gov">
          <p>Ta droga daje <strong>UPP</strong> — urzędowe potwierdzenie z datą, jak list polecony:</p>
          <ol class="steps-in">
            <li>Skopiuj treść przyciskiem <strong>„Kopiuj treść”</strong> wyżej.</li>
            <li>Otwórz usługę <a href="https://www.gov.pl/web/gov/wyslij-pismo-ogolne" target="_blank" rel="noopener noreferrer">„Wyślij pismo ogólne”</a> na gov.pl, kliknij <strong>„Wyślij pismo ogólne”</strong> i zaloguj się (mObywatel, Profil Zaufany, bankowość lub e-dowód).</li>
            <li>W polu <strong>„Urząd lub instytucja”</strong> wskaż <strong>Ministerstwo Zdrowia</strong> (albo <strong>Kancelarię Senatu</strong>).</li>
            <li>W <strong>„Rodzaj pisma”</strong> wybierz <strong>„Inne pismo”</strong>, a w polu <strong>„Inny rodzaj pisma”</strong> wpisz <strong>„Petycja”</strong>.</li>
            <li>W <strong>„Tytuł pisma”</strong> wpisz temat (jak wyżej), a w <strong>„Treść pisma”</strong> wklej treść petycji.</li>
            <li>Wybierz <strong>„Podpisz i wyślij”</strong> i zachowaj UPP.</li>
          </ol>

          <details class="gov-walk">
            <summary>Pokaż krok po kroku (zrzuty ekranu)</summary>
            <ol class="gov-steps">
              <li>
                Otwórz <a href="https://www.gov.pl/web/gov/wyslij-pismo-ogolne" target="_blank" rel="noopener noreferrer">gov.pl → „Wyślij pismo ogólne”</a> i kliknij <strong>WYŚLIJ PISMO OGÓLNE</strong>.
                <Picture src={gov3} width={1100} formats={['avif', 'webp']} fallbackFormat="jpg" quality={64} loading="lazy" class="gov-shot" alt="Strona gov.pl „Wyślij pismo ogólne” z niebieskim przyciskiem Wyślij pismo ogólne." />
              </li>
              <li>
                <em>Opcjonalnie</em> — jeśli nie wiesz, czy wybrać e-Doręczenia czy ePUAP, uruchom kreator „Sprawdź, który sposób korespondencji” przyciskiem <strong>START</strong>.
                <Picture src={gov1} width={1100} formats={['avif', 'webp']} fallbackFormat="jpg" quality={64} loading="lazy" class="gov-shot" alt="Kreator gov.pl: „Odpowiedz na kilka prostych pytań” z przyciskiem START." />
              </li>
              <li>
                Na pytanie „Do jakiej instytucji chcesz wysłać pismo?” wybierz <strong>pierwszą opcję</strong> (administracja publiczna / ministerstwo → e-Doręczenia) i <strong>DALEJ</strong>.
                <Picture src={gov2} width={1100} formats={['avif', 'webp']} fallbackFormat="jpg" quality={64} loading="lazy" class="gov-shot" alt="Kreator gov.pl: pytanie o instytucję z zaznaczoną pierwszą opcją (administracja publiczna, e-Doręczenia)." />
              </li>
              <li>
                Zaloguj się — <strong>mObywatel</strong>, <strong>Profil Zaufany</strong>, bankowość elektroniczna lub e-dowód.
                <Picture src={gov4} width={1100} formats={['avif', 'webp']} fallbackFormat="jpg" quality={64} loading="lazy" class="gov-shot" alt="Ekran logowania login.gov.pl: mObywatel, bankowość elektroniczna, e-dowód, Profil Zaufany." />
              </li>
              <li>
                Wypełnij formularz: <strong>Urząd</strong> = Ministerstwo Zdrowia (lub Kancelaria Senatu), <strong>Rodzaj pisma</strong> = „Inne pismo”, <strong>Inny rodzaj pisma</strong> = „Petycja”, a w <strong>Tytule</strong> i <strong>Treści</strong> wklej dane z petycji. Na końcu <strong>„Podpisz i wyślij”</strong>.
                <Picture src={gov5} width={1100} formats={['avif', 'webp']} fallbackFormat="jpg" quality={64} loading="lazy" class="gov-shot" alt="Formularz „Pismo ogólne do podmiotu publicznego”: Ministerstwo Zdrowia jako urząd, Rodzaj pisma = Inne pismo, Inny rodzaj pisma = Petycja, oraz tytuł i treść petycji." />
              </li>
            </ol>
          </details>
        </div>
        <div class="tab-pane" id="pane-druk">
          <p>
            Kliknij <strong>„Drukuj”</strong> — przycisk zapyta, dla kogo wydruk (Ministerstwa
            Zdrowia czy Senatu), i doda nagłówek z adresatem oraz datą. Wydruk podpisz
            i <strong>uzupełnij odręcznie linię „Adres do korespondencji” — bez adresu urząd
            pozostawi petycję bez rozpatrzenia</strong>. Wyślij na:
          </p>
          <ul class="addr-list">
            <li>{ADRESACI.mz.adres}</li>
            <li>{ADRESACI.senat.adres}</li>
          </ul>
          <p>Wydruk nie ma mniejszej mocy niż e-mail czy pismo urzędowe.</p>
        </div>
      </div>

      <p class="senat-note">
        <strong>Do Senatu</strong> (opcjonalnie, tą samą treścią): Senat nie przyjmuje petycji
        e-mailem, więc skorzystaj z zakładki <strong>„Pismo ogólne (gov.pl)”</strong> — w usłudze
        „Wyślij pismo ogólne”, w kroku wyboru adresata wskaż <strong>Kancelarię Senatu</strong> —
        albo z zakładki <strong>„Wydruk i poczta”</strong> (na adres Kancelarii Senatu podany wyżej).
      </p>

      <!-- CO DALEJ (sprawczość) -->
      <h2 class="blk" id="co-dalej" style="scroll-margin-top: 1.5rem">Co się stanie z Twoją petycją</h2>
      <ol class="next">
        <li><strong>Dostajesz potwierdzenie.</strong> Kopia maila zostaje u Ciebie; przy piśmie ogólnym dostajesz UPP — urzędowe poświadczenie z datą, jak list polecony.</li>
        <li><strong>Urząd MUSI ją rozpatrzyć.</strong> Nie może jej zignorować — ma ustawowy obowiązek odpowiedzieć (Ministerstwo Zdrowia: do 3 miesięcy).</li>
        <li><strong>Twoja petycja staje się jawna.</strong> Urząd publikuje jej treść i sposób załatwienia na swojej stronie (BIP) — petycja o jawność sama staje się jawna. Twoje nazwisko trafi tam tylko za Twoją zgodą (domyślnie: nie).</li>
        <li><strong>Im więcej głosów, tym mocniej.</strong> Wiele petycji w tej samej sprawie urząd może rozpatrzyć łącznie — jedną, zbiorczą odpowiedzią, którą trudniej zbyć milczeniem.</li>
        <li><strong>Senat → realna droga do ustawy.</strong> Petycja do Senatu trafia do Komisji Petycji, która może przekuć ją w projekt ustawy.</li>
      </ol>
      <p class="next-punch">
        Jedna petycja to sygnał. Tysiące identycznych w tej samej sprawie — to fakt,
        którego nie da się przemilczeć.
      </p>

      <LicznikPetycji />

      <!-- STAN AKCJI — publiczny tracker sprawy; wartości w const STAN (frontmatter). -->
      <h2 class="blk" id="stan" style="scroll-margin-top: 1.5rem">Stan akcji</h2>
      <dl class="stan">
        <div class="stan-row">
          <dt>Petycje widoczne u adresata</dt>
          <dd>
            {STAN.naLiscieMZ == null ? (
              <Fragment>
                sprawdzamy — ministerstwo publikuje wpływające petycje na
                <a href={LISTA_MZ_URL} target="_blank" rel="noopener noreferrer"> swojej liście</a>,
                zwykle w 1–2 tygodnie od wpływu
              </Fragment>
            ) : (
              <Fragment>
                <strong>{STAN.naLiscieMZ}</strong> — zob.
                <a href={LISTA_MZ_URL} target="_blank" rel="noopener noreferrer"> listę petycji MZ</a>
              </Fragment>
            )}
          </dd>
        </div>
        <div class="stan-row">
          <dt>Ustawowy termin odpowiedzi</dt>
          <dd>
            3 miesiące od złożenia (art. 10 ust. 1) — dla petycji wysłanych 13 lipca to
            <strong> 13 października 2026 r.</strong> Urząd może ten termin przesunąć tylko
            w udokumentowany sposób: ogłaszając łączne rozpatrywanie petycji wielokrotnej
            (termin biegnie wtedy od końca okresu oczekiwania, art. 11 ust. 2) albo
            przedłużając go o maks. 3 miesiące (art. 10 ust. 3).
            <strong> Każde przesunięcie pokażemy tutaj</strong> — z podstawą prawną
            i linkiem do ogłoszenia.
            {STAN.ogloszeniePW && (
              <Fragment>
                {' '}<strong>Ogłoszono łączne rozpatrywanie:</strong> urząd czeka na dalsze
                petycje do {STAN.ogloszeniePW.do} —
                <a href={STAN.ogloszeniePW.url} target="_blank" rel="noopener noreferrer"> ogłoszenie</a>.
              </Fragment>
            )}
          </dd>
        </div>
        <div class="stan-row">
          <dt>Odpowiedź urzędu</dt>
          <dd>
            {STAN.odpowiedz == null ? (
              <Fragment>
                czekamy — <strong>każdą oficjalną odpowiedź opublikujemy i omówimy</strong>,
                także odmowną. Odpowiedź na petycję o jawność sama jest informacją publiczną.
              </Fragment>
            ) : (
              <Fragment>
                nadeszła {STAN.odpowiedz.data} —
                <a href={STAN.odpowiedz.url}> nasze omówienie</a>
              </Fragment>
            )}
          </dd>
        </div>
      </dl>
      <p class="source-note">
        Obiecujemy tylko to, co od nas zależy: publikację każdej odpowiedzi i pilnowanie
        terminów — daty nie kontrolujemy, kontrolujemy to, że żadne przesunięcie nie
        przejdzie niezauważone. Ostatnia aktualizacja: {STAN.aktualizacja}.
      </p>

      <PetycjaShare
        heading="Wysłane? Daj znać innym"
        intro="Najprostsze wsparcie po wysłaniu petycji to przekazać ją dalej — im więcej identycznych petycji w tej samej sprawie, tym trudniej ją zbyć. Pobierz gotową grafikę i dołącz do posta albo udostępnij sam link (podgląd graficzny dołączy się automatycznie)."
      />

      <p class="source-note">
        Masz pytania albo wątpliwości? <a href="/petycja/jak-to-dziala/">Jak to działa — i dlaczego tak</a>.
        Sama treść i jej omówienie — <a href="/petycja/tresc/">treść petycji</a>. Dlaczego jawność —
        zob. <a href="/postulat/">nasz postulat</a>. Podstawa prawna:
        <a href="https://isap.sejm.gov.pl/isap.nsf/DocDetails.xsp?id=WDU20140001195" target="_blank" rel="noopener noreferrer">ustawa o petycjach</a>
        (art. 2, 4, 10, 11) i art. 63 Konstytucji RP.
      </p>
      </div><!-- /.pet-main -->

      <aside class="pet-rail" aria-label="Akcja i sekcje">
        <div class="rail-card">
          <p class="rail-tag">Zajmie minutę</p>
          <a class="btn btn-primary rail-cta" href="#wyslij">Wyślij petycję ↓</a>
          <p class="rail-sub">Wpisz imię, skopiuj, wyślij — mailem albo pismem urzędowym.</p>
        </div>
        <nav class="rail-nav" aria-label="Sekcje strony">
          <a href="#wyslij">Uzupełnij i wyślij</a>
          <a href="#jak-wyslac">Jak wysłać</a>
          <a href="#co-dalej">Co się stanie</a>
          <a href="#stan">Stan akcji</a>
        </nav>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .narrow { max-width: 780px; }
  .blk { margin-top: 2.5rem; }

  /* Układ dwustrefowy: treść + lepki pasek akcji (desktop ≥ 900 px) */
  .pet-wrap { display: grid; grid-template-columns: minmax(0, 1fr) 14rem; gap: 2.5rem; align-items: start; }
  .pet-main { min-width: 0; max-width: 46rem; }
  .pet-rail { position: sticky; top: 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
  .rail-card { border: 1px solid var(--line); border-top: 4px solid var(--brand); border-radius: var(--radius-lg); background: #fff; padding: 1.1rem 1.2rem; }
  .rail-tag { margin: 0 0 0.6rem; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--brand); }
  .rail-cta { width: 100%; justify-content: center; }
  .rail-sub { margin: 0.65rem 0 0; font-size: 0.85rem; color: var(--ink-soft); line-height: 1.45; }
  .rail-nav { display: flex; flex-direction: column; gap: 0.1rem; border-left: 2px solid var(--line); padding-left: 0.9rem; }
  .rail-nav a { padding: 0.28rem 0; font-size: 0.9rem; color: var(--ink-soft); }
  .rail-nav a:hover { color: var(--brand); }
  @media (max-width: 900px) {
    .pet-wrap { grid-template-columns: 1fr; }
    .pet-main { max-width: none; }
    .pet-rail { display: none; }
  }

  /* Zakładki „Jak wysłać” — natywne radio + CSS, bez JS (dostępne z klawiatury) */
  .tabs { margin: 1.25rem 0 0; }
  .tab-in { position: absolute; width: 1px; height: 1px; opacity: 0; }
  .tablist { display: flex; flex-wrap: wrap; gap: 0.35rem; border-bottom: 2px solid var(--line); }
  .tab-lab { cursor: pointer; padding: 0.55rem 1rem; font-weight: 600; font-size: 0.95rem; color: var(--ink-soft); border: 2px solid transparent; border-bottom: none; border-radius: var(--radius) var(--radius) 0 0; margin-bottom: -2px; }
  .tab-lab:hover { color: var(--brand); }
  .tab-pane { display: none; padding: 1.25rem 0 0; }
  #way-mail:checked ~ #pane-mail,
  #way-gov:checked ~ #pane-gov,
  #way-druk:checked ~ #pane-druk { display: block; }
  #way-mail:checked ~ .tablist .tab-lab[for="way-mail"],
  #way-gov:checked ~ .tablist .tab-lab[for="way-gov"],
  #way-druk:checked ~ .tablist .tab-lab[for="way-druk"] { color: var(--brand); border-color: var(--line); border-bottom-color: #fff; background: #fff; }
  #way-mail:focus-visible ~ .tablist .tab-lab[for="way-mail"],
  #way-gov:focus-visible ~ .tablist .tab-lab[for="way-gov"],
  #way-druk:focus-visible ~ .tablist .tab-lab[for="way-druk"] { outline: 2px solid var(--brand); outline-offset: 2px; }
  .tab-pane > :first-child { margin-top: 0; }
  .tab-pane p { margin: 0 0 0.55rem; color: var(--ink-soft); line-height: 1.6; }
  .tab-pane p:last-child { margin-bottom: 0; }

  .pet-subnav { display: flex; align-items: center; gap: 1.1rem; flex-wrap: wrap; margin: 1.25rem 0 0; }
  .pet-subnav-link { font-weight: 500; color: var(--brand); }

  /* Skutki prawne */
  .effects { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 0.5rem 0 0.75rem; }
  .effect { border: 1px solid var(--line); border-top: 4px solid var(--brand); border-radius: var(--radius); padding: 1rem 1.25rem; background: #fff; }
  .effect-tag { display: inline-block; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--brand); margin-bottom: 0.4rem; }
  .effect p { margin: 0; line-height: 1.55; color: var(--ink); }
  .effects-foot { margin: 0.25rem 0 0; color: var(--ink); }
  @media (max-width: 560px) { .effects { grid-template-columns: 1fr; } }

  /* Kroki */
  .steps { list-style: none; padding: 0; margin: 1rem 0 0; display: flex; flex-direction: column; gap: 0.6rem; }
  .steps li { display: flex; align-items: baseline; gap: 0.7rem; line-height: 1.6; color: var(--ink); }
  .step-n {
    flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center;
    width: 1.7rem; height: 1.7rem; border-radius: 999px;
    background: var(--brand); color: #fff; font-size: 0.9rem; font-weight: 600;
    transform: translateY(0.2rem);
  }

  /* Formularz */
  .gen-form { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 0 0 0.75rem; }
  .field { display: flex; flex-direction: column; gap: 0.3rem; }
  .field label { font-size: 0.85rem; font-weight: 600; color: var(--ink-soft); }
  .field input {
    font-family: var(--font-sans); font-size: 1.05rem; padding: 0.7rem 0.85rem;
    border: 1px solid var(--line); border-radius: var(--radius); background: #fff; color: var(--ink);
  }
  .field input:focus { outline: none; border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-50); }
  @media (max-width: 540px) { .gen-form { grid-template-columns: 1fr; } }
  .privacy-hint { display: flex; align-items: flex-start; gap: 0.5rem; margin: 0 0 1.75rem; font-size: 0.9rem; color: var(--ink-soft); line-height: 1.5; }
  .privacy-hint svg { flex-shrink: 0; color: var(--brand); margin-top: 0.15rem; }
  .gen-warn { margin: 0 0 1.75rem; font-size: 0.9rem; color: var(--alert); line-height: 1.5; }

  /* Strefa akcji — wizualne serce strony: tinted tło + uniesiona biała karta */
  .action-zone { margin-top: 2.5rem; background: var(--brand-50); border: 1px solid #d5e2f0; border-radius: var(--radius-lg); padding: 1.4rem 1.5rem 1.6rem; }
  .action-zone > h2 { margin-top: 0; }
  @media (max-width: 560px) { .action-zone { padding: 1.1rem 1rem 1.3rem; } }

  /* Karta petycji */
  .mail-card { background: #fff; border: 1px solid var(--line); border-radius: var(--radius-lg); padding: 1.25rem 1.5rem; box-shadow: 0 10px 30px -14px rgba(15, 76, 129, 0.28); }
  .mail-row { display: flex; gap: 0.75rem; padding-bottom: 0.7rem; border-bottom: 1px solid var(--line); margin-bottom: 0.85rem; }
  .mail-k { font-size: 0.74rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--ink-faint); flex-shrink: 0; padding-top: 2px; min-width: 3.2rem; }
  .mail-v { font-weight: 500; word-break: break-word; }
  /* Dokument petycji — wyraźny, oźródłowany panel „to wysyłasz” */
  .pet-doc { margin-bottom: 1.1rem; }
  .pet-doc-label { display: flex; justify-content: space-between; align-items: baseline; gap: 0.5rem; margin-bottom: 0.4rem; font-size: 0.74rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--ink-soft); }
  .pet-doc-hint { text-transform: none; letter-spacing: 0; font-weight: 400; font-size: 0.74rem; color: var(--ink-faint); }
  .pet-doc-box { position: relative; }
  .pet-doc-box::after { content: ''; position: absolute; left: 1px; right: 1px; bottom: 1px; height: 2.5rem; background: linear-gradient(to bottom, transparent, var(--paper-2)); border-radius: 0 0 var(--radius) var(--radius); pointer-events: none; }
  .petbox {
    max-height: 20rem; overflow-y: auto;
    border: 1px solid var(--line); border-radius: var(--radius);
    background: var(--paper-2); padding: 0.9rem 1.1rem 2.5rem;
    scrollbar-width: thin; scrollbar-color: var(--line-2) transparent;
  }
  .petbox::-webkit-scrollbar { width: 11px; }
  .petbox::-webkit-scrollbar-thumb { background: var(--line-2); border-radius: 6px; border: 3px solid var(--paper-2); }
  .petbox::-webkit-scrollbar-track { background: transparent; }
  .print-choice { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; margin-top: 0.75rem; }
  .print-choice[hidden] { display: none; }
  .print-choice-label { font-size: 0.85rem; font-weight: 600; color: var(--ink-soft); }
  .mailto-hint { margin: 0.85rem 0 0; font-size: 0.92rem; color: var(--ink-soft); line-height: 1.5; }
  .mail-addr { margin: 0.85rem 0 0; font-size: 0.92rem; color: var(--ink-soft); }
  .mail-addr strong { font-family: var(--font-mono); color: var(--ink); }
  .senat-opt { margin: 0.85rem 0 0; padding-top: 0.9rem; border-top: 1px dashed var(--line); font-size: 0.93rem; color: var(--ink-soft); line-height: 1.55; }
  .senat-note { margin: 1rem 0 0; padding: 0.9rem 1.15rem; background: var(--brand-50); border-left: 4px solid var(--brand); border-radius: 0 var(--radius) var(--radius) 0; font-size: 0.95rem; color: var(--ink); line-height: 1.55; }

  /* Walkthrough gov.pl (zrzuty ekranu) */
  .gov-walk { margin: 1rem 0 0; }
  .gov-walk > summary { cursor: pointer; font-weight: 600; color: var(--brand); list-style: none; padding: 0.35rem 0; }
  .gov-walk > summary::-webkit-details-marker { display: none; }
  .gov-walk > summary::before { content: '▸ '; }
  .gov-walk[open] > summary::before { content: '▾ '; }
  .gov-steps { margin: 1rem 0 0; padding-left: 1.4rem; display: flex; flex-direction: column; gap: 1.5rem; }
  .gov-steps > li { line-height: 1.55; color: var(--ink); }
  .gov-shot { display: block; width: 100%; height: auto; margin-top: 0.7rem; border: 1px solid var(--line); border-radius: var(--radius); }

  /* Jak wysłać */
  .ways { list-style: none; counter-reset: w; padding: 0; margin: 1.25rem 0 0; display: flex; flex-direction: column; gap: 1rem; }
  .ways > li { border: 1px solid var(--line); border-left: 4px solid var(--brand); border-radius: 0 var(--radius) var(--radius) 0; padding: 1.1rem 1.35rem; }
  .ways > li h3 { margin: 0 0 0.5rem; font-size: 1.05rem; }
  .ways > li h3::before { counter-increment: w; content: counter(w) ". "; color: var(--brand); font-weight: 600; }
  .ways p { margin: 0 0 0.55rem; color: var(--ink-soft); line-height: 1.6; }
  .ways p:last-child { margin-bottom: 0; }
  .addr-mono { font-family: var(--font-mono); font-size: 1rem; color: var(--ink) !important; background: var(--paper-2); display: inline-block; padding: 0.35rem 0.7rem; border-radius: var(--radius); }
  .steps-in { margin: 0.5rem 0 0; padding-left: 1.3rem; }
  .steps-in li { margin: 0.4rem 0; color: var(--ink); line-height: 1.55; }
  .addr-list { list-style: none; margin: 0.4rem 0 0.6rem; padding: 0; display: flex; flex-direction: column; gap: 0.4rem; }
  .addr-list li { padding-left: 0.9rem; border-left: 2px solid var(--line-2); color: var(--ink); font-size: 0.95rem; }

  /* Stan akcji — tracker sprawy */
  .stan { margin: 1rem 0 0; border: 1px solid var(--line); border-radius: var(--radius-lg); background: #fff; overflow: hidden; }
  .stan-row { display: grid; grid-template-columns: 15rem 1fr; gap: 1rem; padding: 0.95rem 1.25rem; }
  .stan-row + .stan-row { border-top: 1px solid var(--line); }
  .stan-row dt { font-size: 0.8rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; color: var(--ink-soft); padding-top: 0.15rem; }
  .stan-row dd { margin: 0; color: var(--ink); line-height: 1.6; }
  @media (max-width: 620px) { .stan-row { grid-template-columns: 1fr; gap: 0.35rem; } }

  /* Co dalej — oś czasu */
  .next { counter-reset: nx; list-style: none; padding: 0; margin: 1.25rem 0 0; }
  .next li { position: relative; padding: 0 0 1.15rem 2.6rem; line-height: 1.6; color: var(--ink); }
  .next li::before {
    content: counter(nx); counter-increment: nx;
    position: absolute; left: 0; top: 0;
    width: 1.7rem; height: 1.7rem; border-radius: 999px;
    background: var(--brand); color: #fff; font-size: 0.9rem; font-weight: 600;
    display: flex; align-items: center; justify-content: center;
  }
  .next li::after {
    content: ''; position: absolute; left: calc(0.85rem - 1px); top: 1.9rem; bottom: 0;
    width: 2px; background: var(--line);
  }
  .next li:last-child { padding-bottom: 0; }
  .next li:last-child::after { display: none; }
  .next-punch {
    margin: 0.75rem 0 0; padding: 0.9rem 1.25rem;
    background: var(--brand-50); border-left: 4px solid var(--brand);
    border-radius: 0 var(--radius) var(--radius) 0;
    font-weight: 500; color: var(--ink);
  }
</style>

<!-- Druk: globalna reguła, bo #petbody pochodzi z komponentu (inny scope) -->
<style is:global>
  @media print {
    body.printing * { visibility: hidden !important; }
    body.printing .print-target, body.printing .print-target * { visibility: visible !important; }
    body.printing .print-target {
      position: absolute; left: 0; top: 0; width: 100%;
      max-height: none !important; overflow: visible !important;
      font-size: 12pt; line-height: 1.5; color: #000; white-space: pre-wrap;
    }
  }
</style>

<script is:inline define:vars={{ MZ_EMAIL, PETYCJA_TEMAT, PETYCJA_TRESC, KORESPONDENCJA, ADRESACI_BLOK }}>
  (function () {
    var imieEl = document.getElementById('imie');
    var miejEl = document.getElementById('miejscowosc');
    var bodyEl = document.getElementById('petbody');
    var mailtoEl = document.getElementById('mailtoMz');
    var warnEl = document.getElementById('genWarn');
    if (!imieEl || !bodyEl) return;

    // Beacon lejka — anonimowy licznik akcji (reużywa /api/clicks; slug nie jest chroniony
    // Turnstile, więc przyjmuje beacon bez tokenu). Dedup ~12 h per slug w localStorage
    // (jak w BaseLayout). Fire-and-forget, zero danych osobowych.
    function beacon(slug) {
      try {
        var key = 'clk:' + slug;
        var now = Date.now();
        if (now - (Number(localStorage.getItem(key)) || 0) < 12 * 3600 * 1000) return;
        localStorage.setItem(key, String(now));
      } catch (e) {}
      try { navigator.sendBeacon('/api/clicks', JSON.stringify({ slug: slug })); } catch (e) {}
    }

    // Lustro fillPetycja() z src/lib/petycja.ts — podmienia wszystkie trzy tokeny wg
    // kanału: 'elektroniczny' (puste pola → placeholdery) / 'druk' (→ kropkowane pola
    // do odręcznego wypełnienia; pusty formularz do wydruku to legalny scenariusz).
    function build(kanal) {
      var kropki = '…………………………………………';
      var imie = (imieEl.value || '').trim() || (kanal === 'druk' ? kropki : '[Imię i nazwisko]');
      var miej = (miejEl.value || '').trim() || (kanal === 'druk' ? kropki : '[miejscowość]');
      return PETYCJA_TRESC.replace(/\{\{IMIE\}\}/g, imie)
        .replace(/\{\{MIEJSCOWOSC\}\}/g, miej)
        .replace(/\{\{ADRES_KORESPONDENCJI\}\}/g, KORESPONDENCJA[kanal]);
    }

    function fill() {
      var body = build('elektroniczny');
      bodyEl.textContent = body;
      if (mailtoEl) {
        // Mail niesie linię „Adresat:” (oznaczenie adresata, art. 4 ust. 2 pkt 3);
        // widok #petbody jest bez niej — kopiowanie pozostaje neutralne względem
        // adresata, bo kanał (gov.pl / pole „Do”) sam go wskazuje.
        mailtoEl.href =
          'mailto:' + MZ_EMAIL +
          '?subject=' + encodeURIComponent(PETYCJA_TEMAT) +
          '&body=' + encodeURIComponent('Adresat: Minister Zdrowia\n\n' + body);
      }
      // Ostrzeżenie gaśnie, gdy oba pola są już uzupełnione.
      if (warnEl && !warnEl.hidden && (imieEl.value || '').trim() && (miejEl.value || '').trim()) {
        warnEl.hidden = true;
      }
    }

    imieEl.addEventListener('input', fill);
    miejEl.addEventListener('input', fill);
    fill();

    // Guard formalny (tylko kanały elektroniczne): bez imienia i nazwiska lub
    // miejscowości petycja zostaje pozostawiona bez rozpatrzenia (art. 7 ust. 1) —
    // blokujemy akcję i wskazujemy pierwsze puste pole. Wydruku NIE blokujemy.
    function guard(event) {
      var brakImienia = !(imieEl.value || '').trim();
      var brakMiejscowosci = !(miejEl.value || '').trim();
      if (!brakImienia && !brakMiejscowosci) return true;
      if (event) event.preventDefault();
      if (warnEl) {
        warnEl.textContent =
          'Uzupełnij imię i nazwisko oraz miejscowość — petycja bez nich zostaje ' +
          'pozostawiona bez rozpatrzenia (art. 7 ust. 1 ustawy o petycjach).';
        warnEl.hidden = false;
      }
      (brakImienia ? imieEl : miejEl).focus();
      return false;
    }

    if (mailtoEl) {
      mailtoEl.addEventListener('click', function (event) {
        // Licz tylko odblokowane kliki (guard() === true) — nie zablokowane brakiem danych.
        if (guard(event)) beacon('petycja-akcja-mail');
      });
    }

    var copyBtn = document.getElementById('copyBtn');
    if (copyBtn) {
      copyBtn.addEventListener('click', function () {
        if (!guard()) return;
        beacon('petycja-akcja-kopiuj');
        var text = 'Temat: ' + PETYCJA_TEMAT + '\n\n' + bodyEl.textContent;
        var done = function () {
          var prev = copyBtn.textContent;
          copyBtn.textContent = 'Skopiowano ✓';
          setTimeout(function () { copyBtn.textContent = prev; }, 1800);
        };
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(done).catch(function () {
            copyBtn.textContent = 'Zaznacz i skopiuj ręcznie';
          });
        } else {
          copyBtn.textContent = 'Zaznacz i skopiuj ręcznie';
        }
      });
    }

    // Druk w dwóch krokach: „Drukuj” pokazuje wybór adresata (MZ / Senat), a wybór
    // buduje dokument wydruku — miejscowość i data, blok adresata, treść w kanale
    // 'druk' — i drukuje istniejącym mechanizmem .print-target + body.printing.
    var printBtn = document.getElementById('printBtn');
    var choiceEl = document.getElementById('printChoice');
    if (printBtn && choiceEl) {
      printBtn.addEventListener('click', function () {
        choiceEl.hidden = !choiceEl.hidden;
        printBtn.setAttribute('aria-expanded', String(!choiceEl.hidden));
        if (!choiceEl.hidden) {
          var first = choiceEl.querySelector('button[data-print]');
          if (first) first.focus();
        }
      });

      choiceEl.querySelectorAll('button[data-print]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          beacon('petycja-akcja-druk');
          var kto = btn.getAttribute('data-print');
          var miej = (miejEl.value || '').trim() || '……………………';
          var data = new Date().toLocaleDateString('pl-PL', {
            day: 'numeric', month: 'long', year: 'numeric',
          });
          bodyEl.textContent =
            miej + ', dnia ' + data + ' r.\n\n' +
            'Adresat:\n' + ADRESACI_BLOK[kto].join('\n') + '\n\n' +
            build('druk');
          bodyEl.classList.add('print-target');
          document.body.classList.add('printing');
          var cleanup = function () {
            bodyEl.classList.remove('print-target');
            document.body.classList.remove('printing');
            window.removeEventListener('afterprint', cleanup);
            fill(); // przywróć widok ekranowy (kanał elektroniczny)
            choiceEl.hidden = true;
            printBtn.setAttribute('aria-expanded', 'false');
          };
          window.addEventListener('afterprint', cleanup);
          window.print();
          setTimeout(cleanup, 1000);
        });
      });
    }
  })();
</script>
