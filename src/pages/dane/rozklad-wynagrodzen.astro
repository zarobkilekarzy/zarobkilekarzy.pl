---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareRow from '../../components/ShareRow.astro';
import DisclaimerZarobki from '../../components/DisclaimerZarobki.astro';
import { getCollection } from 'astro:content';

const rozklad = (await getCollection('zarobki'))
  .filter((z) => z.data.grupa === 'rozklad')
  .sort((a, b) => a.data.kolejnosc - b.data.kolejnosc);

const fmt = (n: number) => new Intl.NumberFormat('pl-PL').format(n);
---

<BaseLayout
  title="Rozkład wynagrodzeń lekarzy — zarobkilekarzy.pl"
  description="Od pensji rezydenta po rekordowe kontrakty — rozpiętość wynagrodzeń lekarzy jest ogromna. Każda liczba ze źródłem."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow"><a href="/dane">Dane</a> · Rozkład</p>
      <h1>Rozkład wynagrodzeń lekarzy</h1>
      <p class="lead">
        Od pensji rezydenta po rekordowe kontrakty — rozpiętość jest ogromna. Połowa lekarzy
        zarabia ponad 25 tys. zł, a wąska elita przekracza 100 tys. zł miesięcznie. Uwaga:
        dane AOTMiT widzą zarobki tylko <strong>na poziomie jednej placówki</strong>.
      </p>

      <DisclaimerZarobki />

      <h2 style="margin-top: 1.5rem">Jak rozliczają się lekarze: etat vs kontrakt</h2>
      <p class="muted" style="max-width: 64ch; margin-top: 0.5rem">
        Zdecydowana większość lekarzy w ochronie zdrowia rozlicza się na
        <strong>kontraktach (B2B)</strong>, nie na etacie. To właśnie kontrakty łatwo
        łączyć w wielu placówkach naraz — i to ich kwot <strong>nikt nie publikuje</strong>.
      </p>
      <div class="ek-bar" role="img" aria-label="Około 75% lekarzy rozlicza się na kontrakcie, około 25% na umowie o pracę.">
        <div class="ek-seg ek-kontrakt" style="width:75%"><span>~75%<small>kontrakt (B2B)</small></span></div>
        <div class="ek-seg ek-etat" style="width:25%"><span>~25%<small>etat (UoP)</small></span></div>
      </div>
      <div class="callout" style="border-left-color: var(--alert); background: var(--alert-50)">
        <p>
          <strong>Kwot kontraktów nie znamy — bo nie są publikowane.</strong> Wynagrodzenia
          na etacie wynikają z ustawy i są znane; ale <strong>~3 na 4 lekarzy</strong>
          rozlicza się na kontraktach B2B, których stawki i łączne kwoty pozostają
          <strong>niejawne</strong>. Publikowane mediany (np. 25 595 zł) to dane AOTMiT
          o <em>pojedynczej</em> umowie — nie o tym, ile realnie inkasuje jeden lekarz.
        </p>
      </div>
      <p class="source-note">
        Udział kontraktów (73,16% specjalistów, 2026) — dane AOTMiT (za
        <a href="https://www.rp.pl/ochrona-zdrowia/art44649861-wyplaty-lekarzy-na-kontraktach-wieksze-niz-100-tys-zl-tylko-w-1-proc-przypadkow" target="_blank" rel="noopener noreferrer">Rzeczpospolitą</a>).
        Na rynku ofert prywatnych udział B2B jest jeszcze wyższy — umowa o pracę to
        <strong>poniżej 6% ofert</strong> (<a href="https://hiredoc.com/pl/raport" target="_blank" rel="noopener noreferrer">HireDoc, Q3 2025</a>).
      </p>

      <h2 style="margin-top: 2.5rem">Rozpiętość: od rezydenta po górny 1%</h2>
      <div class="data-grid">
        {rozklad.map((z) => (
          <div class="data-card">
            <p class="k">{z.data.etykieta}</p>
            <p class="v">{z.data.kwota >= 100000 ? '> ' : ''}{fmt(z.data.kwota)} {z.data.jednostka}</p>
            <p class="src">
              {z.data.uwaga && <span>{z.data.uwaga} · </span>}
              <a href={z.data.zrodloUrl} target="_blank" rel="noopener noreferrer">{z.data.zrodloNazwa}</a>
            </p>
          </div>
        ))}
      </div>

      <h2 style="margin-top: 2.5rem">Skala wieloetatowości</h2>
      <p class="muted" style="max-width: 64ch; margin-top: 0.5rem">
        Ile placówek przypada na jednego lekarza? <strong>Nie wiadomo</strong> — bo nie
        istnieje rejestr sumujący pracę jednego lekarza w różnych miejscach (to właśnie
        nasz <a href="/postulat">postulat</a>). Skalę widać jednak pośrednio:
      </p>
      <ul style="max-width: 64ch; padding-left: 1.25rem; line-height: 1.65">
        <li>ok. <strong>75% lekarzy</strong> rozlicza się na kontraktach (B2B), które łatwo łączyć w kilku placówkach naraz;</li>
        <li>AOTMiT widzi zarobki tylko „na poziomie jednej placówki” — a po zsumowaniu kontraktów odsetek zarabiających ponad 100 tys. zł/mc rośnie z <strong>1,2% do 5–10%</strong>.</li>
      </ul>
      <p class="source-note">
        Źródła: dane AOTMiT (za
        <a href="https://www.rp.pl/ochrona-zdrowia/art44466691-625-lekarzy-w-polsce-zarabia-powyzej-100-tys-zl-dotarlismy-do-wyliczen" target="_blank" rel="noopener noreferrer">Rzeczpospolitą</a>);
        <a href="/mechanizmy">mechanizmy i źródła</a>.
      </p>

      <p class="source-note">
        Nie publikujemy liczb „z pamięci”. Dopóki pole nie ma źródła, pozostaje oznaczone jako „—”.
      </p>

      <p class="pager"><a href="/dane/kolejki">← Kolejki</a> · <a href="/dane/rekordy">Rekordowe rozliczenia →</a></p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <ShareRow heading="Pomóż nagłośnić sprawę:" />
    </div>
  </section>
</BaseLayout>

<style>
  .ek-bar { display: flex; height: 68px; border-radius: var(--radius); overflow: hidden; margin: 1.25rem 0 1rem; border: 1px solid var(--line); }
  .ek-seg { display: flex; align-items: center; justify-content: center; min-width: 0; }
  .ek-seg span { display: flex; flex-direction: column; align-items: center; line-height: 1.15; font-family: var(--font-mono); font-weight: 600; font-size: 1.15rem; }
  .ek-seg small { font-family: var(--font-sans); font-weight: 400; font-size: 0.72rem; opacity: 0.9; margin-top: 2px; }
  .ek-kontrakt { background: var(--brand); color: #fff; }
  .ek-etat { background: var(--paper-2); color: var(--ink-soft); }
  @media (max-width: 520px) { .ek-seg span { font-size: 0.95rem; } .ek-seg small { font-size: 0.62rem; } }
</style>
