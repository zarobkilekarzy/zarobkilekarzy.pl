---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { CATEGORY_LABELS, SOURCE_TYPE_LABELS, formatDate } from '../lib/categories';

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { title, source, sourceType, url, date, excerpt, category, example } =
  article.data;

// Materiały wideo (sourceType: "wideo") z YouTube dostają miniaturę.
const ytMatch =
  sourceType === 'wideo'
    ? url.match(/[?&]v=([\w-]+)/) ?? url.match(/youtu\.be\/([\w-]+)/)
    : null;
const thumb = ytMatch ? `https://img.youtube.com/vi/${ytMatch[1]}/hqdefault.jpg` : null;
const catHref = `/artykuly/kategoria/${category}/`;
---

<article class:list={['article', { 'is-video': !!thumb }]}>
  <div class="article-body">
    <p class="article-meta">
      <span>{SOURCE_TYPE_LABELS[sourceType]}</span>
      <span class="dot" aria-hidden="true">•</span>
      <span>{source}</span>
      <span class="dot" aria-hidden="true">•</span>
      <span>{formatDate(date)}</span>
      {example && <span class="badge-example">przykład</span>}
      <span class="article-clicks" data-clicks-for={article.id} hidden></span>
    </p>
    <h3>
      <a class="article-link" href={url} target="_blank" rel="noopener noreferrer" data-slug={article.id}>{title}</a>
    </h3>
    <p class="article-excerpt">{excerpt}</p>
    <a class="tag tag-link" href={catHref}>{CATEGORY_LABELS[category]}</a>
  </div>
  {
    thumb && (
      <div class="article-thumb" aria-hidden="true">
        <Image src={thumb} alt="" width={360} height={270} loading="lazy" />
        <span class="article-play">
          <svg width="40" height="40" viewBox="0 0 40 40" aria-hidden="true">
            <circle cx="20" cy="20" r="20" fill="rgba(15,76,129,0.88)" />
            <path d="M16 12.5 L29 20 L16 27.5 Z" fill="#fff" />
          </svg>
        </span>
      </div>
    )
  }
  <span class="article-ext" aria-hidden="true">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
      <path d="M7 17L17 7M9 7h8v8"></path>
    </svg>
  </span>
</article>

<style>
  /* Cała karta klikalna do źródła (stretched link); tag kategorii to osobny link. */
  .article { position: relative; }
  .article-body { flex: 1; min-width: 0; }
  .article h3 { margin-top: 0; }
  .article-link { color: inherit; text-decoration: none; }
  .article-link::after {
    content: ''; position: absolute; inset: 0; z-index: 1; border-radius: var(--radius);
  }
  /* Licznik przejść do źródła — pokazywany dopiero, gdy JS wypełni liczbę. */
  .article-clicks[hidden] { display: none; }
  .article-clicks { position: relative; z-index: 2; color: var(--ink-faint); font-variant-numeric: tabular-nums; white-space: nowrap; }
  .article-clicks::before { content: '•'; margin: 0 0.4rem; color: var(--ink-faint); }
  .tag-link {
    position: relative; z-index: 2; display: inline-block; margin-top: 0.6rem;
    text-decoration: none; transition: border-color 0.15s ease, color 0.15s ease;
  }
  .tag-link:hover { border-color: var(--brand); color: var(--brand); }

  .article-thumb { position: relative; flex-shrink: 0; width: 172px; align-self: flex-start; }
  .article-thumb img {
    width: 100%; aspect-ratio: 16 / 9; object-fit: cover; display: block;
    border-radius: var(--radius); background: var(--paper-2);
  }
  .article-play { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; pointer-events: none; }
  @media (max-width: 560px) {
    .article-thumb { width: 116px; }
  }
</style>
