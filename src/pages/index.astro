<script>
  // Karuzela w wielkim hero. Slajdy = panele hero (fade, grid-stack, inert na nieaktywnych);
  // NAWIGACJA = trzy kafle pod hero (aria-current, roving tabindex, strzałki). Autoprzewijanie
  // OFF przy prefers-reduced-motion, pauza na hover/focus/ukrytej karcie; ręczny wybór wyłącza auto.
  const PLAY_SVG = '<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>';
  const PAUSE_SVG = '<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6 5h4v14H6zM14 5h4v14h-4z"/></svg>';

  document.querySelectorAll('.js-hero-carousel').forEach((root) => {
    const slides = Array.from(root.querySelectorAll('.mh-slide'));
    const tiles = Array.from(root.querySelectorAll('.tcard'));
    const playBtn = root.querySelector('.mh-play');
    const live = root.querySelector('.mh-live');
    const n = slides.length;
    if (n < 2 || tiles.length !== n) return;

    const rmq = window.matchMedia('(prefers-reduced-motion: reduce)');
    const DELAY = 7000;
    let i = Math.max(0, slides.findIndex((s) => s.classList.contains('is-active')));
    let auto = !rmq.matches;
    let hovered = false;
    const canAnim = typeof root.animate === 'function';
    let prog = null;   // pasek postępu = ZEGAR przewijania (koniec paska → następny slajd)
    let timer = null;  // fallback bez Web Animations API (brak paska, samo przewijanie)

    function clearRun() {
      if (prog) { prog.cancel(); prog = null; }
      if (timer) { clearInterval(timer); timer = null; }
    }

    // Uzbrój odliczanie do następnego slajdu na AKTYWNYM kaflu: pasek .tc-prog
    // wypełnia się 0→100% przez DELAY, a jego KONIEC przewija karuzelę — jeden
    // zegar dla paska i dla zmiany slajdu, więc nie mogą się rozjechać. Pauza
    // (hover / ukryta karta) zamraża pasek; wznowienie idzie od tego samego miejsca.
    function arm() {
      clearRun();
      if (!auto) return;                    // autoplay off → brak odliczania (CSS pokazuje pasek pełny)
      const fill = tiles[i].querySelector('.tc-prog');
      if (canAnim && fill) {
        prog = fill.animate(
          [{ transform: 'scaleX(0)' }, { transform: 'scaleX(1)' }],
          { duration: DELAY, easing: 'linear', fill: 'forwards' },
        );
        prog.onfinish = () => select(i + 1, false, false);
        if (hovered || document.hidden) prog.pause();
      } else if (!hovered && !document.hidden) {
        timer = setInterval(() => select(i + 1, false, false), DELAY);
      }
    }

    function refresh() {
      const running = auto && !hovered && !document.hidden;
      if (prog) {
        if (running) prog.play(); else prog.pause();
      } else if (auto && !canAnim) {         // fallback: pauza = clear, wznowienie = nowy interval
        if (running && !timer) timer = setInterval(() => select(i + 1, false, false), DELAY);
        else if (!running && timer) { clearInterval(timer); timer = null; }
      }
      if (playBtn) {
        playBtn.setAttribute('aria-pressed', String(auto));
        playBtn.setAttribute('aria-label', auto ? 'Zatrzymaj automatyczne przewijanie' : 'Włącz automatyczne przewijanie');
        playBtn.innerHTML = auto ? PAUSE_SVG : PLAY_SVG;
      }
    }

    function select(to, announce, focusTile) {
      i = (to + n) % n;
      slides.forEach((s, k) => {
        const on = k === i;
        s.classList.toggle('is-active', on);
        if (on) s.removeAttribute('inert'); else s.setAttribute('inert', '');
        s.setAttribute('aria-hidden', String(!on));
      });
      tiles.forEach((t, k) => {
        const on = k === i;
        t.setAttribute('aria-current', String(on));
        t.tabIndex = on ? 0 : -1;
      });
      if (focusTile) tiles[i].focus();
      if (live) live.textContent = announce ? `Slajd ${i + 1} z ${n}: ${slides[i].dataset.title || ''}` : '';
      arm();
      refresh();
    }

    tiles.forEach((t, k) => {
      t.addEventListener('click', () => { auto = false; select(k, true, false); });
      t.addEventListener('keydown', (e) => {
        let to = null;
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') to = k + 1;
        else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') to = k - 1;
        else if (e.key === 'Home') to = 0;
        else if (e.key === 'End') to = n - 1;
        if (to === null) return;
        e.preventDefault();
        auto = false;
        select(to, true, true);
      });
    });
    playBtn?.addEventListener('click', () => { auto = !auto; arm(); refresh(); });

    root.addEventListener('mouseenter', () => { hovered = true; refresh(); });
    root.addEventListener('mouseleave', () => { hovered = false; refresh(); });
    root.addEventListener('focusin', () => { hovered = true; refresh(); });
    root.addEventListener('focusout', () => {
      if (!root.contains(document.activeElement)) { hovered = false; refresh(); }
    });
    document.addEventListener('visibilitychange', refresh);

    select(i, false, false);
  });
</script>

<style>
  .hero-combo { position: relative; }

  /* ===== MEGA-HERO (ciemne pasmo, karuzela) ========================= */
  .megahero {
    position: relative; overflow: hidden;
    background: var(--panel); color: var(--on-panel);
    padding: 5rem 0 8.5rem;
  }
  .megahero::before {
    content: ""; position: absolute; inset: 0; pointer-events: none;
    background:
      radial-gradient(60% 90% at 82% 40%, rgba(69,184,194,0.16), transparent 70%),
      radial-gradient(55% 80% at 12% 20%, rgba(47,111,177,0.20), transparent 70%);
  }
  .mh-pulse {
    position: absolute; left: 0; right: 0; bottom: 3.2rem; width: 100%; height: 120px;
    color: var(--teal); opacity: 0.16; pointer-events: none;
  }
  .megahero .container { position: relative; z-index: 1; }
  .mh-play {
    position: absolute; top: 1.1rem; right: 1.1rem; z-index: 3;
    width: 40px; height: 40px; border-radius: 999px; cursor: pointer;
    border: 1px solid rgba(255,255,255,0.4); background: rgba(255,255,255,0.08); color: #fff;
    display: inline-flex; align-items: center; justify-content: center;
  }
  .mh-play:hover { background: rgba(255,255,255,0.18); }

  /* karuzela = grid-stack; align-self:start pinuje krótsze slajdy do góry (brak pustki nad tekstem) */
  .mh-track { display: grid; }
  .mh-slide { grid-area: 1 / 1; align-self: start; opacity: 0; visibility: hidden; transition: opacity 0.5s ease, visibility 0.5s ease; }
  .mh-slide.is-active { opacity: 1; visibility: visible; }

  .mh-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 3rem; align-items: center; }
  .mh-eyebrow { font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.09em; color: #8fc7ff; margin: 0 0 0.9rem; }
