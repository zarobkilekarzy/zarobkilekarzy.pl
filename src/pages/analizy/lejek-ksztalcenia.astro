  .cmp .hot { color: var(--alert); font-weight: 600; }
  .vs { border-collapse: collapse; width: 100%; min-width: 460px; font-size: 0.94rem; }
  .vs thead th { text-align: left; padding: 0.7rem 0.9rem; background: var(--paper-2); color: var(--ink-soft); font-weight: 600; font-size: 0.82rem; border-bottom: 2px solid var(--line); }
  .vs thead th span { display: block; font-weight: 400; font-size: 0.72rem; }
  .vs tbody th { text-align: left; padding: 0.7rem 0.9rem; font-weight: 500; color: var(--ink-soft); }
  .vs td { text-align: left; padding: 0.7rem 0.9rem; }
