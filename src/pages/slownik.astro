---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShareRow from '../components/ShareRow.astro';

// Mini-słowniczek: definicja formy/pojęcia (neutralna) oddzielona od obserwacji
// watchdoga. Cel: obniżyć próg wejścia dla laika, bez upraszczania do przekłamania.
const terminy = [
  {
    id: 'nfz',
    t: 'NFZ',
    d: 'Narodowy Fundusz Zdrowia — państwowy płatnik. Zbiera Twoją składkę zdrowotną i płaci placówkom za leczenie. Plan finansowy na 2026 r.: ~217 mld zł.',
  },
  {
    id: 'pwz',
    t: 'PWZ',
    d: 'Numer prawa wykonywania zawodu — publiczny, jawny identyfikator zawodowy lekarza (to nie PESEL).',
    note: 'Właśnie o ten numer proponujemy oprzeć jawny rejestr wypłat ze środków publicznych — bez ujawniania danych prywatnych.',
  },
  {
    id: 'aotmit',
    t: 'AOTMiT',
    d: 'Agencja Oceny Technologii Medycznych i Taryfikacji — państwowa agencja, która wycenia świadczenia (ustala „taryfę”) i zbiera dane o wynagrodzeniach medyków.',
  },
  {
    id: 'etat',
    t: 'Etat (umowa o pracę)',
    d: 'Zatrudnienie na zasadach Kodeksu pracy. Płaca zasadnicza wynika z ustawy (drabina taryfowa) i jest jawna; obowiązują limity czasu pracy.',
  },
  {
    id: 'kontrakt',
    t: 'Kontrakt / B2B',
    d: 'Umowa, w której lekarz prowadzący działalność (firma) wystawia placówce faktury — jak przedsiębiorca przedsiębiorcy. Legalna, powszechna forma rozliczenia.',
    note: 'Kwot kontraktów nikt nie publikuje, a jeden lekarz może łączyć je w wielu placówkach naraz — i nikt nie sumuje ich po osobie. To sedno problemu jawności.',
  },
  {
    id: 'kapitacja',
    t: 'Kapitacja',
    d: 'Sposób finansowania podstawowej opieki zdrowotnej (POZ): stała roczna stawka „za zapisanego pacjenta” (2026: 226,08 zł, korygowana współczynnikiem wieku), niezależnie od liczby wizyt.',
  },
  {
    id: 'ryczalt',
    t: 'Ryczałt',
    d: 'W szpitalu (sieć PSZ): z góry ustalona kwota za pakiet świadczeń rozliczanych „w punktach”, a nie osobno za każdą procedurę.',
  },
  {
    id: 'nadwykonania',
    t: 'Nadwykonania',
    d: 'Świadczenia udzielone pacjentom ponad limit z umowy z NFZ. Placówka je wykonała, ale zapłata bywa sporna albo odroczona.',
  },
  {
    id: 'gotowosc',
    t: 'Dyżur „pod telefonem” (gotowość)',
    d: 'Płatna gotowość do stawienia się na wezwanie — 50% stawki godzinowej — bez obowiązku fizycznej obecności w szpitalu.',
    note: 'Bez rejestru nikt nie widzi, ile takich gotowości przypada na jednego lekarza w tej samej dobie.',
  },
  {
    id: 'opt-out',
    t: 'Opt-out',
    d: 'Pisemna zgoda pracownika na pracę powyżej 48 godzin tygodniowo (do ok. 78 h). Dotyczy etatu — kontrakt B2B jest poza tymi limitami.',
  },
];
---

<BaseLayout
  title="Słowniczek pojęć — zarobkilekarzy.pl"
  description="Prosty słowniczek: kontrakt/B2B, kapitacja, ryczałt, nadwykonania, AOTMiT, PWZ, gotowość, opt-out — po ludzku, jednym zdaniem, bez żargonu."
>
  <section class="section">
    <div class="container" style="max-width: 780px">
      <p class="eyebrow">Bez żargonu</p>
      <h1>Słowniczek — pojęcia w jednym zdaniu</h1>
      <p class="lead">
        Ochrona zdrowia mówi swoim językiem: kontrakt, kapitacja, ryczałt, taryfa. Tu
        tłumaczymy najważniejsze pojęcia z tej strony <strong>prosto, jednym zdaniem</strong> —
        żeby dane dało się zrozumieć bez wcześniejszej wiedzy. Definicję formy oddzielamy od
        naszej obserwacji.
      </p>

      <dl class="glossary">
        {terminy.map((x) => (
          <div class="gl-item" id={x.id}>
            <dt>{x.t}</dt>
            <dd>
              <p class="gl-def">{x.d}</p>
              {x.note && <p class="gl-note"><span class="gl-tag">obserwacja</span>{x.note}</p>}
            </dd>
          </div>
        ))}
      </dl>

      <p class="source-note">
        Liczby w hasłach mają źródła na podstronach, do których się odnoszą — zob.
        <a href="/dane">dane</a>, <a href="/mechanizmy">mechanizmy</a> i <a href="/postulat">postulat</a>.
        Brakuje pojęcia? <a href="mailto:kontakt@zarobkilekarzy.pl">napisz do nas</a>.
      </p>

      <div class="cta-row">
        <a class="btn btn-primary" href="/dane">Zobacz dane</a>
        <a class="btn" href="/postulat">Poznaj postulat</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <ShareRow heading="Pomóż nagłośnić sprawę:" />
    </div>
  </section>
</BaseLayout>

<style>
  .glossary { margin: 1.75rem 0 2rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .gl-item { border: 1px solid var(--line); border-radius: var(--radius-lg); background: var(--bg); padding: 1.1rem 1.35rem; scroll-margin-top: 5rem; }
  .gl-item dt { font-family: var(--font-serif); font-weight: 600; font-size: 1.15rem; color: var(--ink); margin: 0 0 0.35rem; }
  .gl-item dd { margin: 0; }
  .gl-def { margin: 0; color: var(--ink); line-height: 1.6; }
  .gl-note { margin: 0.6rem 0 0; font-size: 0.9rem; color: var(--ink-soft); line-height: 1.55; border-left: 3px solid var(--brand); padding-left: 0.8rem; }
  .gl-tag { display: inline-block; font-size: 0.66rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--brand); background: var(--brand-50); padding: 0.1rem 0.45rem; border-radius: 999px; margin-right: 0.5rem; vertical-align: 0.05em; }
</style>
