---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareRow from '../../components/ShareRow.astro';
import DisclaimerZarobki from '../../components/DisclaimerZarobki.astro';
import { getCollection } from 'astro:content';

const rekordy = (await getCollection('zarobki'))
  .filter((z) => z.data.grupa === 'rekord')
  .sort((a, b) => a.data.kolejnosc - b.data.kolejnosc);

const podium = rekordy.filter((z) => z.data.jednostka === 'zł/dzień');
const miesieczne = rekordy.filter((z) => z.data.jednostka === 'zł/mc');
const roczne = rekordy.filter((z) => z.data.jednostka === 'zł/rok');

const fmt = (n: number) => new Intl.NumberFormat('pl-PL').format(n);

// Porównanie: dniówki gwiazd futbolu vs rekordowy dzień neurochirurga (308 tys. zł).
// Pensja roczna ÷ 365; kursy 1 EUR=4,25 zł, 1 USD=3,65 zł, 1 GBP=4,90 zł.
const liga = [
  { rank: 1, name: 'Ronaldo', club: 'Al-Nassr', val: '2 350 000 zł', w: 100, over: true },
  { rank: 2, name: 'Haaland', club: 'Manchester City', val: '367 000 zł', w: 100 },
  { rank: 3, name: 'Neurochirurg', club: 'spółka Spine / NFZ', val: '308 000 zł', w: 84, doc: true },
  { rank: 4, name: 'Messi', club: 'Inter Miami', val: '283 000 zł', w: 77 },
  { rank: 5, name: 'Lewandowski', club: 'FC Barcelona', val: '242 000 zł', w: 66 },
  { rank: 6, name: 'Yamal', club: 'FC Barcelona', val: '194 000 zł', w: 53 },
];
---

<BaseLayout
  title="Rekordowe rozliczenia lekarzy — zarobkilekarzy.pl"
  description="Udokumentowane rekordy rozliczeń ze środków publicznych: od 316 tys. zł miesięcznie po miliony rocznie. Bez nazwisk — opisujemy mechanizm, nie osobę."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow"><a href="/dane">Dane</a> · Rekordy</p>
      <h1>Rekordowe rozliczenia</h1>
      <p class="lead">
        Udokumentowane, oźródłowane rekordy — z odpowiedzi urzędów, oświadczeń majątkowych
        (jawnych z mocy prawa) i doniesień prasowych. <strong>Nie podajemy nazwisk</strong> —
        opisujemy rolę, dziedzinę i region. Mechanizm, nie osoba.
      </p>

      <DisclaimerZarobki />

      {podium.map((z) => (
        <div class="podium">
          <div class="podium-badge">🥇 1. miejsce na podium</div>
          <p class="podium-label">{z.data.etykieta}</p>
          <p class="podium-line">
            <span class="podium-num">308 tys. zł</span>
            <span class="podium-per">DZIENNIE</span>
          </p>
          <p class="podium-sub">— czyli nawet <strong>26 tys. zł za godzinę</strong>.</p>
          <p class="podium-meta">
            <span class="chip chip-alert">zarzut — sprawa w toku</span>
            {z.data.rola} · {z.data.region}
          </p>
          <p class="podium-note">{z.data.uwaga}</p>
          <p class="rec-src"><a href={z.data.zrodloUrl} target="_blank" rel="noopener noreferrer">{z.data.zrodloNazwa}</a></p>
        </div>
      ))}

      <h2 style="margin-top: 2.5rem">Neurochirurg w Lidze Mistrzów</h2>
      <p class="muted" style="max-width: 66ch; margin-top: 0.5rem">
        Dla skali — dniówki gwiazd światowego futbolu (pensja klubowa brutto 2025/26 ÷ 365
        dni) zestawione z <strong>rekordowym dniem lekarza ze spółki</strong>. Rachunek za
        jeden dzień pracy plasuje go między Haalandem a Messim.
      </p>
      <div class="liga">
        {liga.map((r) => (
          <div class={`lm-row${r.doc ? ' is-doc' : ''}`}>
            <span class="lm-rank">{r.rank}</span>
            <div class="lm-body">
              <div class="lm-head">
                <span class="lm-name">{r.name}</span>
                <span class="lm-club">{r.club}</span>
                <span class="lm-val">{r.val}</span>
              </div>
              <div class="lm-bar">
                <div class={`lm-fill${r.over ? ' is-over' : ''}${r.doc ? ' is-docfill' : ''}`} style={`width:${r.w}%`}>
                  {r.over && <span class="lm-over">poza skalą ↗</span>}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
      <p class="source-note">
        Pensje klubowe brutto 2025/26 ÷ 365 dni; kursy: 1 EUR = 4,25 zł · 1 USD = 3,65 zł ·
        1 GBP = 4,90 zł. Źródła: Capology, Forbes, Sportico; rekordowy dzień neurochirurga
        (73 zabiegi w 12 godzin) —
        <a href="https://www.rp.pl/ochrona-zdrowia/art44774891-300-tys-zl-za-dzien-pracy-tyle-mieli-zarabiac-neurochirurdzy-w-szpitalach" target="_blank" rel="noopener noreferrer">Rzeczpospolita</a> /
        WP „afera kręgosłupowa”. To zarzut — sprawa w toku.
      </p>

      <h2 style="margin-top: 2.5rem">Miesięczne rozliczenia (NFZ / kontrakty)</h2>
      <div class="rec-list">
        {miesieczne.map((z) => (
          <div class="rec">
            <div class="rec-num">{fmt(z.data.kwota)}<span class="rec-unit">{z.data.jednostka}</span></div>
            <div class="rec-body">
              <p class="rec-label">{z.data.etykieta}</p>
              <p class="rec-meta">
                {z.data.forma && <span class="chip">{z.data.forma}</span>}
                {z.data.rola && <span>{z.data.rola}</span>}
                {z.data.region && <span> · {z.data.region}</span>}
              </p>
              {z.data.uwaga && <p class="rec-note">{z.data.uwaga}</p>}
              <p class="rec-src"><a href={z.data.zrodloUrl} target="_blank" rel="noopener noreferrer">{z.data.zrodloNazwa}</a></p>
            </div>
          </div>
        ))}
      </div>

      <h2 style="margin-top: 2.5rem">Roczne dochody (oświadczenia majątkowe)</h2>
      <div class="rec-list">
        {roczne.map((z) => (
          <div class="rec">
            <div class="rec-num">{fmt(z.data.kwota)}<span class="rec-unit">{z.data.jednostka}</span></div>
            <div class="rec-body">
              <p class="rec-label">{z.data.etykieta}</p>
              <p class="rec-meta">
                {z.data.rola && <span>{z.data.rola}</span>}
                {z.data.region && <span> · {z.data.region}</span>}
                {z.data.statusFaktu === 'zarzut' && <span class="chip chip-alert">zarzut</span>}
              </p>
              {z.data.uwaga && <p class="rec-note">{z.data.uwaga}</p>}
              <p class="rec-src"><a href={z.data.zrodloUrl} target="_blank" rel="noopener noreferrer">{z.data.zrodloNazwa}</a></p>
            </div>
          </div>
        ))}
      </div>

      <p class="source-note" style="margin-top: 1.5rem">
        <strong>Uczciwie:</strong> dochód z oświadczenia majątkowego (praktyka indywidualna)
        nie jest tożsamy z „kontraktem NFZ” — część praktyk rozlicza się prywatnie. Kwoty
        rozliczeń to fakty; ewentualne zarzuty w postępowaniach oznaczamy osobno i traktujemy
        jako <strong>nieudowodnione</strong>.
      </p>

      <p class="pager"><a href="/dane/rozklad-wynagrodzen">← Rozkład</a> · <a href="/dane/wedlug-specjalizacji">Według specjalizacji →</a></p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <ShareRow heading="Pomóż nagłośnić sprawę:" />
    </div>
  </section>
</BaseLayout>

<style>
  .rec-list { display: flex; flex-direction: column; gap: 1rem; margin: 1.25rem 0; }
  .rec { display: flex; gap: 1.25rem; align-items: flex-start; background: var(--bg); border: 1px solid var(--line); border-left: 4px solid var(--alert); border-radius: 0 var(--radius) var(--radius) 0; padding: 1rem 1.25rem; }
  .rec-num { font-family: var(--font-mono); font-size: clamp(1.4rem, 4vw, 1.9rem); font-weight: 600; color: var(--alert); line-height: 1.1; white-space: nowrap; flex-shrink: 0; min-width: 12ch; text-align: right; }
  .rec-unit { display: block; font-size: 0.72rem; color: var(--ink-faint); font-weight: 400; }
  .rec-body { min-width: 0; }
  .rec-label { font-weight: 600; color: var(--ink); margin: 0 0 0.25rem; }
  .rec-meta { font-size: 0.86rem; color: var(--ink-soft); margin: 0 0 0.35rem; }
  .rec-note { font-size: 0.84rem; color: var(--ink-soft); margin: 0 0 0.35rem; line-height: 1.5; }
  .rec-src { font-size: 0.8rem; margin: 0; }
  .podium { background: linear-gradient(180deg, var(--alert-50), var(--bg)); border: 2px solid var(--alert); border-radius: var(--radius-lg); padding: 1.5rem 1.75rem; margin: 1.5rem 0 2rem; }
  .podium-badge { display: inline-block; background: var(--alert); color: #fff; font-weight: 700; font-size: 0.82rem; padding: 0.2rem 0.7rem; border-radius: 999px; margin-bottom: 0.75rem; }
  .podium-label { font-weight: 600; color: var(--ink); margin: 0 0 0.35rem; font-size: 1.05rem; }
  .podium-line { display: flex; align-items: baseline; gap: 0.75rem; flex-wrap: wrap; margin: 0.25rem 0; }
  .podium-num { font-family: var(--font-mono); font-size: clamp(2.4rem, 9vw, 4rem); font-weight: 700; color: var(--alert); line-height: 1; }
  .podium-per { font-family: var(--font-sans); font-weight: 800; font-size: clamp(1.4rem, 5vw, 2.2rem); letter-spacing: 0.08em; color: var(--alert); text-transform: uppercase; border-bottom: 4px solid var(--alert); padding-bottom: 2px; }
  .podium-sub { font-size: 1.05rem; color: var(--ink); margin: 0.4rem 0 0.6rem; }
  .podium-meta { font-size: 0.86rem; color: var(--ink-soft); margin: 0 0 0.5rem; }
  .podium-note { font-size: 0.86rem; color: var(--ink-soft); line-height: 1.55; margin: 0 0 0.5rem; }
  .chip { display: inline-block; padding: 0.05rem 0.45rem; border-radius: 999px; background: var(--paper-2); font-size: 0.72rem; margin-right: 0.4rem; }
  .chip-alert { background: var(--alert-50); color: var(--alert); font-weight: 600; }
  .pager { margin-top: 2.5rem; font-size: 0.9rem; color: var(--ink-soft); }
  .liga { display: flex; flex-direction: column; gap: 0.85rem; margin: 1.25rem 0 0.75rem; }
  .lm-row { display: flex; gap: 0.9rem; align-items: center; }
  .lm-row.is-doc { background: var(--alert-50); border: 1px solid var(--alert); border-radius: var(--radius); padding: 0.6rem 0.75rem; margin: -0.2rem -0.75rem; }
  .lm-rank { font-family: var(--font-mono); font-size: 1.5rem; font-weight: 700; color: var(--ink-faint); width: 1.4ch; text-align: center; flex-shrink: 0; }
  .lm-row.is-doc .lm-rank { color: var(--alert); }
  .lm-body { flex: 1; min-width: 0; }
  .lm-head { display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.3rem; flex-wrap: wrap; }
  .lm-name { font-weight: 700; color: var(--ink); }
  .lm-club { font-size: 0.82rem; color: var(--ink-soft); }
  .lm-val { margin-left: auto; font-family: var(--font-mono); font-weight: 600; white-space: nowrap; }
  .lm-row.is-doc .lm-name, .lm-row.is-doc .lm-val { color: var(--alert); }
  .lm-bar { background: var(--paper-2); border-radius: var(--radius); height: 16px; width: 100%; overflow: hidden; }
  .lm-fill { height: 100%; background: var(--ink-faint); border-radius: var(--radius); min-width: 4px; position: relative; }
  .lm-fill.is-docfill { background: var(--alert); }
  .lm-fill.is-over { background: repeating-linear-gradient(90deg, var(--ink-soft) 0 10px, var(--paper-2) 10px 14px); }
  .lm-over { position: absolute; right: 6px; top: 50%; transform: translateY(-50%); font-size: 0.62rem; font-weight: 700; color: var(--ink); background: rgba(255,255,255,0.7); padding: 0 3px; border-radius: 3px; }
  @media (max-width: 520px) {
    .rec { flex-direction: column; gap: 0.4rem; }
    .rec-num { min-width: 0; text-align: left; }
  }
</style>
