---
// Strona główna. Hero = wielkie ciemne pasmo, które ROTUJE jako karuzela 3 tematów
// (Petycja / Postulat / Poradnik pacjenta); trzy kafle pod hero są NAWIGACJĄ karuzeli
// (klik → zmiana slajdu, aktywny kafel podniesiony). Autoprzewijanie z pauzą, sterowanie
// klawiaturą, `inert` na nieaktywnych slajdach.
//
// Panel hero: tokeny --panel/--on-panel CELOWO ciemne w OBU motywach → tekst na nim
// jasnymi, NIEodwracalnymi kolorami (hardcode rgba(255,255,255,·) + jasny błękit na eyebrow).
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import AktualizacjaUstawa from '../components/AktualizacjaUstawa.astro';
import Sonda from '../components/Sonda.astro';
import ShareRow from '../components/ShareRow.astro';
import { getCollection } from 'astro:content';

const latest = (await getCollection('articles'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout>
  <AktualizacjaUstawa pokazPrzycisk={true} />

  <div class="hero-combo js-hero-carousel">
    <!-- MEGA-HERO — karuzela slajdów -->
    <section class="megahero">
      <svg class="mh-pulse" viewBox="0 0 1200 120" preserveAspectRatio="none" aria-hidden="true">
        <polyline
          points="0,70 300,70 330,70 348,30 366,104 388,52 410,70 640,70 672,70 690,26 710,108 730,58 752,70 1200,70"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" />
      </svg>

      <button class="mh-play" type="button" aria-label="Zatrzymaj automatyczne przewijanie" aria-pressed="true"></button>

      <div class="container">
        <div class="mh-carousel" role="group" aria-roledescription="karuzela" aria-label="Najważniejsze: petycja, postulat, prawa pacjenta">
          <div class="mh-track">
            <!-- SLAJD 1 · PETYCJA -->
            <div class="mh-slide is-active" role="group" aria-roledescription="slajd" aria-label="1 z 3: Petycja" data-title="Petycja">
              <div class="mh-grid">
                <div class="mh-copy">
                  <p class="mh-eyebrow">Inicjatywa obywatelska na rzecz jawności</p>
                  <h1 class="mh-title">Publiczne pieniądze,<br /><span class="mh-hl">niejawne zarobki</span></h1>
                  <p class="mh-lead">
                    Część lekarzy rozlicza miliony złotych ze środków publicznych, łącząc
                    kontrakty w wielu placówkach — a pacjenci miesiącami czekają w kolejce.
                    Zbieramy dane, linkujemy źródła i postulujemy jawny rejestr.
                  </p>
                  <div class="mh-cta">
                    <a class="btn btn-on-brand" href="/petycja/">Wyślij petycję</a>
                    <a class="btn btn-ghost" href="/dane/">Zobacz dane</a>
                  </div>
                </div>
                <div class="mh-anchor">
                  <p class="mh-big">0</p>
                  <p class="mh-big-label">ogólnodostępnych rejestrów łącznego wynagrodzenia jednego lekarza ze środków publicznych</p>
                  <span class="pill pill-alert">brak jawności</span>
                </div>
              </div>
            </div>

            <!-- SLAJD 2 · POSTULAT -->
            <div class="mh-slide" role="group" aria-roledescription="slajd" aria-label="2 z 3: Postulat" data-title="Postulat" inert>
              <div class="mh-grid">
                <div class="mh-copy">
                  <p class="mh-eyebrow">Nasz postulat</p>
                  <h1 class="mh-title">Jeden <span class="mh-hl">jawny rejestr</span><br />— po numerze PWZ</h1>
                  <p class="mh-lead">
                    Łączna wypłata ze środków publicznych, zsumowana po numerze prawa
                    wykonywania zawodu — nie po PESEL, bez danych prywatnych. Dziś takiej
                    liczby nie zna nikt.
                  </p>
                  <div class="mh-cta">
                    <a class="btn btn-on-brand" href="/postulat/">Poznaj postulat</a>
                    <a class="btn btn-ghost" href="/petycja/">Wyślij petycję</a>
                  </div>
                </div>
                <div class="mh-anchor">
                  <p class="mh-big">PWZ</p>
                  <p class="mh-big-label">identyfikator zawodowy zamiast PESEL — jawny rejestr pobiera mniej danych niż zna dziś państwo</p>
                  <span class="pill pill-brand">nasz postulat</span>
                </div>
              </div>
            </div>

            <!-- SLAJD 3 · PORADNIK PACJENTA -->
            <div class="mh-slide" role="group" aria-roledescription="slajd" aria-label="3 z 3: Poradnik pacjenta" data-title="Poradnik pacjenta" inert>
              <div class="mh-grid">
                <div class="mh-copy">
                  <p class="mh-eyebrow mh-eyebrow-teal">Poradnik pacjenta</p>
                  <h1 class="mh-title">Znaj swoje prawa <span class="mh-hl-teal">u lekarza</span></h1>
                  <p class="mh-lead">
                    Jawność zaczyna się w gabinecie. Prawo do informacji, drugiej opinii,
                    leczenia bólu i darmowej pierwszej kopii dokumentacji — konkretne
                    przepisy, po ludzku.
                  </p>
                  <div class="mh-cta">
                    <a class="btn btn-on-brand" href="/prawa-pacjenta/">Poznaj prawa pacjenta</a>
                    <a class="btn btn-ghost" href="/prawa-pacjenta/druk/">Karta do druku</a>
                  </div>
                </div>
                <div class="mh-anchor">
                  <p class="mh-big">0 zł</p>
                  <p class="mh-big-label">tyle kosztuje pierwsza kopia Twojej dokumentacji medycznej (art. 28)</p>
                  <span class="pill pill-teal">prawa pacjenta</span>
                </div>
              </div>
            </div>
          </div>
          <p class="mh-live sr-only" aria-live="polite" aria-atomic="true"></p>
        </div>
      </div>
    </section>

    <!-- TRZY KAFLE = NAWIGACJA KARUZELI (nachodzą na hero) -->
    <section class="trio-wrap" aria-label="Wybierz temat">
      <div class="container">
        <div class="trio" role="group" aria-label="Wybór tematu w karuzeli">
          <button class="tcard" type="button" style="--accent: var(--brand-link)" aria-current="true">
            <span class="tc-prog" aria-hidden="true"></span>
            <span class="tc-tag">Działaj</span>
            <span class="tc-title">Wyślij petycję</span>
            <span class="tc-desc">Gotowa, formalna petycja o jawny rejestr. Urząd ma obowiązek odpowiedzieć.</span>
          </button>
          <button class="tcard" type="button" style="--accent: var(--brand-link)" aria-current="false">
            <span class="tc-prog" aria-hidden="true"></span>
            <span class="tc-tag">Zrozum</span>
            <span class="tc-title">Poznaj postulat</span>
            <span class="tc-desc">Jeden jawny rejestr wypłat ze środków publicznych — po numerze PWZ.</span>
          </button>
          <button class="tcard tcard-teal" type="button" style="--accent: var(--teal)" aria-current="false">
            <span class="tc-prog" aria-hidden="true"></span>
            <span class="tc-tag">Skorzystaj</span>
            <span class="tc-title">Prawa pacjenta</span>
            <span class="tc-desc">Informacja, druga opinia, leczenie bólu i darmowa pierwsza kopia dokumentacji.</span>
          </button>
        </div>
      </div>
    </section>
  </div>

  <!-- NAJWAŻNIEJSZE — NAWIGATOR -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Zacznij tutaj</p>
      <h2>Najmocniejsze dane i analizy</h2>
      <p class="lead" style="margin-bottom: 1.5rem">
        Sedno serwisu w kilku miejscach — od rekordowych rozliczeń po porównania
        i mechanizmy. Każda liczba ma źródło.
      </p>
      <div class="home-grid">
        <a class="home-card is-hot" href="/dane/rekordy/">
          <span class="hc-tag">Rekordy</span>
          <span class="hc-t">300 tys. zł <em>dziennie</em>, do 316 tys. zł/mies.</span>
          <span class="hc-d">Udokumentowane rozliczenia ze środków publicznych — bez nazwisk, sam mechanizm.</span>
          <span class="hc-arrow" aria-hidden="true">→</span>
        </a>
        <a class="home-card" href="/dane/kolejki/">
          <span class="hc-tag">Infografika</span>
          <span class="hc-t">Pieniądze rosną, kolejka nie maleje</span>
          <span class="hc-d">Budżet, składka, dopłaty i płaca minimalna w górę — a czas oczekiwania też.</span>
          <span class="hc-arrow" aria-hidden="true">→</span>
        </a>
        <a class="home-card" href="/dane/wedlug-specjalizacji/">
          <span class="hc-tag">Dane</span>
          <span class="hc-t">Zarobki według specjalizacji</span>
          <span class="hc-d">Pensja rezydenta, stawka rynkowa, miejsca i konkurencja — dla 29 dziedzin.</span>
          <span class="hc-arrow" aria-hidden="true">→</span>
        </a>
        <a class="home-card" href="/mechanizmy/wieloetatowosc/">
          <span class="hc-tag">Mechanizm</span>
          <span class="hc-t">Wieloetatowość</span>
          <span class="hc-d">Ten sam lekarz rozlicza kontrakty w kilku placówkach naraz — nikt tego nie sumuje.</span>
          <span class="hc-arrow" aria-hidden="true">→</span>
        </a>
        <a class="home-card" href="/dane/zadluzenie-szpitali/">
          <span class="hc-tag">Dane</span>
          <span class="hc-t">Pensje na kredyt: 34 mld zł długu</span>
          <span class="hc-d">Dług szpitali idzie głównie na wynagrodzenia — spłacamy go ze środków publicznych.</span>
          <span class="hc-arrow" aria-hidden="true">→</span>
        </a>
        <a class="home-card" href="/analizy/zarobki-lekarzy-polska-sasiedzi/">
          <span class="hc-tag">Analiza</span>
          <span class="hc-t">Polska na tle sąsiadów</span>
          <span class="hc-d">Czechy, Niemcy, Austria — u sąsiadów płace jawne w taryfie; u nas realny dochód ukryty w kontrakcie.</span>
          <span class="hc-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- W 30 SEKUND -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow">W 30 sekund</p>
      <h2>O co tu chodzi</h2>
      <ol class="tldr">
        <li><strong>Leczenie finansują publiczne pieniądze.</strong> Plan NFZ na 2026 r. to ~217 mld zł — z Twojej składki zdrowotnej.</li>
        <li><strong>Nie wiadomo, ile łącznie trafia do jednego lekarza.</strong> Większość specjalistów rozlicza się na kontraktach — często w kilku placówkach naraz — a nikt nie sumuje tych kwot po osobie.</li>
        <li><strong>Postulujemy jeden jawny rejestr.</strong> Łączna wypłata ze środków publicznych przy numerze prawa wykonywania zawodu (PWZ), bez danych prywatnych.</li>
      </ol>
      <p class="muted" style="max-width: 720px">
        Nie jesteśmy przeciwko lekarzom — przeciwnikiem jest nieprzejrzystość. Nie znasz
        jakiegoś pojęcia? Zajrzyj do <a href="/slownik/">słowniczka</a>.
      </p>
    </div>
  </section>

  <!-- SKALA RÓŻNICY: WYKRES PŁAC -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Skala różnicy</p>
      <h2>Ile zarabia lekarz, a ile Ty?</h2>
      <p class="lead">
        Miesięczne wynagrodzenie brutto. Mediana lekarza dotyczy <strong>jednej
        placówki</strong> — a ok. 73% specjalistów rozlicza się na kontraktach, często
        w kilku naraz.
      </p>

      <div class="salary">
        <div class="bar-row">
          <div class="bar-head">
            <span class="bar-name">Minimalna krajowa</span>
            <span class="bar-val">4 806 zł</span>
          </div>
          <div class="bar-track">
            <div class="bar-fill is-min" style="width:20%"></div>
            <span class="bar-flag">← to Ty?</span>
          </div>
        </div>

        <div class="bar-row">
          <div class="bar-head">
            <span class="bar-name">Mediana wynagrodzeń w Polsce</span>
            <span class="bar-val">7 907 zł</span>
          </div>
          <div class="bar-track">
            <div class="bar-fill is-med" style="width:33%"></div>
          </div>
        </div>

        <div class="bar-row">
          <div class="bar-head">
            <span class="bar-name">Mediana wynagrodzenia lekarza</span>
            <span class="bar-val">≈ 24 000 zł</span>
          </div>
          <div class="bar-track">
            <div class="bar-fill is-doc" style="width:100%"></div>
          </div>
        </div>

        <div class="bar-row">
          <div class="bar-head">
            <span class="bar-name">Najwyższe rozliczenia lekarzy</span>
            <span class="bar-val">&gt; 100 000 zł</span>
          </div>
          <div class="bar-track">
            <div class="bar-fill is-patol" style="width:100%">
              <span class="patol-label">≥ 625 lekarzy · poza skalą wykresu ↗</span>
            </div>
          </div>
        </div>
      </div>

      <p class="salary-insight">
        Mediana wynagrodzenia lekarza to ok. <strong>5×</strong> płacy minimalnej i
        <strong>3×</strong> mediany krajowej — i to liczone w <strong>jednej</strong>
        placówce.
      </p>

      <div class="patol-note">
        <p>
          To nie sufit. <strong>≥ 625 lekarzy</strong> rozlicza ponad
          <strong>100 000 zł miesięcznie</strong> — licząc tylko <strong>jedną
          placówkę</strong>; po zsumowaniu kontraktów AOTMiT szacuje <strong>5–10%
          specjalistów</strong>. Ze środków publicznych rekordzista na kontrakcie w
          mazowieckim szpitalu wojewódzkim rozliczył <strong>316 079 zł
          miesięcznie</strong> — ponad <strong>1,26 mln zł w cztery miesiące</strong>
          (przy 1,4 mld zł długu tych szpitali). Najwyższy roczny dochód w niezależnej
          analizie 160 oświadczeń majątkowych lekarzy-radnych to <strong>4,9 mln zł</strong>
          (2025) — mediana tej grupy (285 tys. zł) jest ok. 3× wyższa od krajowej.
        </p>
        <p class="source-note" style="margin-top: 0.5rem">
          Źródła: skala &gt; 100 tys./mies. — dane AOTMiT (luty 2026), za
          <a href="https://www.rp.pl/ochrona-zdrowia/art44466691-625-lekarzy-w-polsce-zarabia-powyzej-100-tys-zl-dotarlismy-do-wyliczen" target="_blank" rel="noopener noreferrer">Rzeczpospolitą</a>;
          316 079 zł/mies. — odpowiedź Urzędu Marszałkowskiego Woj. Mazowieckiego, za
          <a href="https://www.termedia.pl/mz/Milioner-w-cztery-miesiace,66022.html" target="_blank" rel="noopener noreferrer">Menedżerem Zdrowia</a>;
          rekord dochodu 4,9 mln zł (analiza 160 oświadczeń majątkowych) —
          <a href="https://cowzdrowiu.pl/aktualnosci/post/ile-zarabiaja-lekarze-radni-rekord-to-49-mln-zl" target="_blank" rel="noopener noreferrer">Co w Zdrowiu</a>.
        </p>
      </div>

      <p class="source-note">
        Źródła: płaca minimalna —
        <a href="https://isap.sejm.gov.pl/isap.nsf/DocDetails.xsp?id=WDU20250001242" target="_blank" rel="noopener noreferrer">Rozp. Rady Ministrów z 11.09.2025 (Dz.U. 2025 poz. 1242)</a>;
        mediana krajowa (XII 2025) —
        <a href="https://stat.gov.pl/obszary-tematyczne/rynek-pracy/pracujacy-zatrudnieni-wynagrodzenia-koszty-pracy/rozklad-wynagrodzen-w-gospodarce-narodowej-w-listopadzie-2025-r-,32,23.html" target="_blank" rel="noopener noreferrer">GUS, rozkład wynagrodzeń</a>;
        mediana lekarza (w jednej placówce, 22–25 tys.) — dane
        <a href="https://www.gazetaprawna.pl/biznes/zdrowie/artykuly/11149864,pensje-lekarzy-i-pielegniarek-w-polsce-2025-ile-zarabiaja-etatowcy-i.html" target="_blank" rel="noopener noreferrer">AOTMiT / Gazeta Prawna</a>.
      </p>

      <div class="callout quiet" style="margin-top: 1.25rem">
        <p>
          <strong>To nie jest atak na lekarzy.</strong> Wielu z nich jest przepracowanych —
          wg badania Naczelnej Izby Lekarskiej z 2024 r.
          (<a href="https://www.rp.pl/ochrona-zdrowia/art44685111-naczelna-izba-lekarska-proponuje-limit-godzin-pracy-lekarzy" target="_blank" rel="noopener noreferrer">NIL / Rzeczpospolita</a>)
          ponad <strong>64% pracuje powyżej 48 godzin tygodniowo</strong>. Ostrze kierujemy w
          nieprzejrzystość i skrajne kumulacje ze środków publicznych, nie w zawód ani w
          przeciętnego lekarza. <a href="/faq/">Zobacz najczęstsze zarzuty →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- NIEPRZEJRZYSTOŚĆ: NIE DA SIĘ POLICZYĆ -->
  <section class="section section-alt">
    <div class="container">
      <div class="opacity-block">
        <p class="opacity-q">Ile łącznie z budżetu NFZ trafia do jednego lekarza?</p>
        <p class="opacity-a">
          Nie wiadomo — i <strong>nie da się tego policzyć</strong>. Nie istnieje
          rejestr, który sumuje wynagrodzenia jednego lekarza ze wszystkich umów,
          zleceń i kontraktów ze środków publicznych. To nie luka techniczna — to
          <strong>sedno problemu</strong>.
        </p>
        <a class="btn btn-primary" href="/postulat/">Dlatego żądamy jawnego rejestru →</a>
      </div>
    </div>
  </section>

  <!-- KOLEJKI vs ZAROBKI -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Druga strona</p>
      <h2>Ty czekasz, oni zarabiają</h2>
      <p class="lead">
        Na wizytę u specjalisty NFZ czeka się średnio <strong>4,2 miesiąca</strong>
        (Barometr WHC, 2025). U tego samego lekarza prywatnie — zwykle kilka dni.
        Różnicę napędza praca w wielu miejscach naraz.
      </p>

      <div class="queues">
        <div class="q-row">
          <div class="q-meta"><span class="q-name">Neurochirurg</span><span class="q-nfz">13,1 mies. NFZ</span></div>
          <div class="q-bar"><div class="q-fill" style="width:100%"></div></div>
        </div>
        <div class="q-row">
          <div class="q-meta"><span class="q-name">Endokrynolog</span><span class="q-nfz">~12,9 mies. NFZ</span></div>
          <div class="q-bar"><div class="q-fill" style="width:98%"></div></div>
        </div>
        <div class="q-row">
          <div class="q-meta"><span class="q-name">Kardiolog</span><span class="q-nfz">kilka–kilkanaście mies. · prywatnie 7–21 dni</span></div>
          <div class="q-bar"><div class="q-fill" style="width:53%"></div></div>
        </div>
        <div class="q-row">
          <div class="q-meta"><span class="q-name">Ortopeda</span><span class="q-nfz">~5 mies. NFZ · prywatnie 5–14 dni</span></div>
          <div class="q-bar"><div class="q-fill" style="width:38%"></div></div>
        </div>
      </div>

      <p class="salary-insight">
        Lekarz rozlicza ok. <strong>24 000 zł/mies.</strong>, a Ty czekasz
        <strong>miesiącami</strong>. Prywatnie, za dopłatą, ten sam specjalista przyjmie
        Cię w kilka dni.
      </p>

      <p class="source-note">
        Źródła:
        <a href="https://www.rynekzdrowia.pl/Polityka-zdrowotna/Barometr-Watch-Health-Care-sredni-czas-oczekiwania-na-leczenie-w-2025-r-to-ponad-4-miesiace,279890,14.html" target="_blank" rel="noopener noreferrer">Barometr WHC 2025 (Rynek Zdrowia)</a>;
        czasy wg specjalności —
        <a href="https://www.gazetaprawna.pl/biznes/zdrowie/artykuly/11155472,kolejkidolekarzynfz2025.html" target="_blank" rel="noopener noreferrer">dane NFZ (Gazeta Prawna)</a>;
        terminy —
        <a href="https://terminyleczenia.nfz.gov.pl/" target="_blank" rel="noopener noreferrer">Informator NFZ</a>.
      </p>
    </div>
  </section>

  <!-- PASMO CTA — PETYCJA -->
  <section class="cta-band">
    <div class="container cta-band-inner">
      <div>
        <h2>Nie czekaj, aż ktoś to naprawi — zażądaj jawności sam</h2>
        <p>
          Masz na to formalne narzędzie: petycję, którą urząd ma prawny obowiązek rozpatrzyć
          i odpowiedzieć w trzy miesiące. Gotowa treść — wpisujesz imię i wysyłasz.
        </p>
      </div>
      <a class="btn btn-on-brand" href="/petycja/">Wyślij petycję</a>
    </div>
  </section>

  <!-- SPOTLIGHT: REGLAMENTACJA DOSTĘPU DO ZAWODU -->
  <section class="section section-alt">
    <div class="container">
      <div class="spotlight">
        <p class="eyebrow">Mechanizm: reglamentacja dostępu</p>
        <h2>Dlaczego lekarzy jest mało — i komu to służy</h2>
        <p>
          Polska ma ok. 3,4–3,9 lekarza na 1000 mieszkańców — poniżej średniej UE
          (ok. 4,2) — a 5,2% osób rezygnuje z potrzebnej pomocy. Wejście do zawodu jest
          reglamentowane: limit przyjęć na studia i miejsc specjalizacyjnych ustala
          ministerstwo, a samorząd lekarski protestuje przeciw nowym kierunkom i
          uproszczonym ścieżkom dla lekarzy spoza UE.
        </p>
        <p>
          Krytycy nazywają to <strong>logiką korporacyjną</strong>: im mniej nowych
