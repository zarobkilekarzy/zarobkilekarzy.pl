  }
  .kanal summary::-webkit-details-marker { display: none; }
  .kanal summary::after {
    content: "+"; color: var(--brand); font-size: 1.25rem; line-height: 1;
    margin-left: auto; flex-shrink: 0;
  }
  .kanal[open] summary::after { content: "−"; }
  .kanal[open] summary { border-bottom: 1px solid var(--line); }
  .kanal-nazwa { font-weight: 600; font-size: 0.98rem; color: var(--ink); }
  .kanal-skrot { color: var(--ink-faint); font-size: 0.88rem; }
  .kanal-tresc { padding: 0.9rem 1rem 1.1rem; }
  .kanal-kiedy { margin: 0 0 0.9rem; color: var(--ink-soft); font-size: 0.95rem; line-height: 1.6; }
  .kanal-meta { display: grid; grid-template-columns: 7.5rem 1fr; gap: 0.45rem 1rem; margin: 0; font-size: 0.92rem; }
  .kanal-meta dt { color: var(--ink-faint); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.03em; padding-top: 0.15rem; }
  .kanal-meta dd { margin: 0; color: #29384b; line-height: 1.6; }

  @media (max-width: 560px) {
    .hotline-v { font-size: 1.9rem; }
    /* Etykieta nad wartością — 7,5 rem kolumny zjadłoby treść na wąskim ekranie. */
    .kanal-meta { grid-template-columns: 1fr; gap: 0.15rem; }
    .kanal-meta dt { padding-top: 0.5rem; }
    /* Nazwa i skrót jedno pod drugim — obok siebie łamałyby się brzydko. */
