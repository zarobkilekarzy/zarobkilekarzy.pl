---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareRow from '../../components/ShareRow.astro';
import Aktualizacja from '../../components/Aktualizacja.astro';
import DisclaimerZarobki from '../../components/DisclaimerZarobki.astro';
import { getCollection } from 'astro:content';

const rekordy = (await getCollection('zarobki'))
  .filter((z) => z.data.grupa === 'rekord')
  .sort((a, b) => a.data.kolejnosc - b.data.kolejnosc);

const byKwota = (a, b) => b.data.kwota - a.data.kwota;
const dzienne = rekordy.filter((z) => z.data.jednostka === 'zł/dzień').sort(byKwota);
const miesieczne = rekordy.filter((z) => z.data.jednostka === 'zł/mies.').sort(byKwota);
const roczne = rekordy.filter((z) => z.data.jednostka === 'zł/rok').sort(byKwota);

const fmt = (n: number) => new Intl.NumberFormat('pl-PL').format(n);

// Trójka „skala" — najwyższy udokumentowany rekord w każdej jednostce czasu (dzień/miesiąc/rok).
const heroDzien = dzienne[0];
const heroMc = miesieczne[0];
const heroRok = roczne[0];
// Kotwica skali: mediana kontraktu specjalisty (AOTMiT 02.2026, EXACT) — zob. /dane/rozklad-wynagrodzen.
const medianaKontrakt = 25595;
const heroMcMult = Math.floor(heroMc.data.kwota / medianaKontrakt);
// Szerokość paska rankingu = udział kwoty w maksimum danej grupy.
const barW = (kwota: number, max: number) => Math.round((kwota / max) * 100);

// Źródłowa tabela: 10 najwyższych wynagrodzeń personelu medycznego szpitali wojewódzkich
// Mazowsza (2025), wg formy zatrudnienia. Kwoty zaokrąglone do zł. eb/en = etat brutto/netto,
// k = kontrakt brutto, ub/un = umowa cywilnoprawna brutto/netto. kx = umowa rozwiązana (**).
const woj2025 = [
  { lp: 1, eb: 101384, en: 58447, k: 316079, kx: true, ub: 100147, un: 81520 },
  { lp: 2, eb: 97736, en: 56177, k: 258400, kx: true, ub: 62600, un: 50956 },
  { lp: 3, eb: 93928, en: 54440, k: 231738, ub: 51980, un: 38795 },
  { lp: 4, eb: 90473, en: 52389, k: 210301, ub: 49710, un: 40464 },
  { lp: 5, eb: 87129, en: 50226, k: 199100, ub: 43200, un: 28253 },
  { lp: 6, eb: 86145, en: 49960, k: 198204, ub: 35167, un: 25403 },
  { lp: 7, eb: 81046, en: 47025, k: 197229, ub: 33820, un: 27529 },
  { lp: 8, eb: 79807, en: 45930, k: 188775, ub: 32580, un: 23534 },
  { lp: 9, eb: 78712, en: 45412, k: 178638, ub: 32010, un: 23122 },
  { lp: 10, eb: 74737, en: 43111, k: 174636, ub: 31752, un: 22936 },
];

// Anonimowy rozkład: roczne dochody radnych-lekarzy z jawnych oświadczeń majątkowych
// (oddolne zestawienie; każda kwota do sprawdzenia w BIP właściwej jednostki). Malejąco.
const radniDochody = [1491932, 1334692, 1212738, 1065886, 1040192, 1024636, 987192, 969570, 935753, 916009, 844387, 806843, 719721, 718902, 711179, 707986, 685544, 587746, 581708];
const radniStat = { n: 19, mediana: 916009, srednia: 912769, min: 581708, max: 1491932, przychodMax: 3918517 };
const nilWykonujacy = 164892; // rejestr NIL, 16 I 2026 (lekarze wykonujący zawód)
---

<BaseLayout
  title="Rekordowe rozliczenia lekarzy — zarobkilekarzy.pl"
  description="Udokumentowane rekordy rozliczeń ze środków publicznych: od 316 tys. zł miesięcznie po miliony rocznie. Bez nazwisk — opisujemy mechanizm, nie osobę."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow"><a href="/dane/">Dane</a> · Rekordy</p>
      <h1>Rekordowe rozliczenia</h1>
      <Aktualizacja />
      <p class="lead">
        Udokumentowane, oźródłowane rekordy — z odpowiedzi urzędów, oświadczeń majątkowych
        (jawnych z mocy prawa) i doniesień prasowych. <strong>Nie podajemy nazwisk</strong> —
        opisujemy rolę, dziedzinę i region. Mechanizm, nie osoba.
      </p>

      <DisclaimerZarobki />

      <div class="skala">
        <div class="skala-tile is-zarzut">
          <div class="skala-eb">za godzinę</div>
          <div class="skala-num">26 000<span class="skala-zl"> zł</span></div>
          <p class="skala-who">Spółka neurochirurgów — 308 tys. zł za dzień pracy (Mogilno, Miastko)</p>
          <p class="skala-foot"><span class="chip chip-alert">zarzut — sprawa w toku</span> <a href={heroDzien.data.zrodloUrl} target="_blank" rel="noopener noreferrer">{heroDzien.data.zrodloNazwa}</a></p>
        </div>
        <div class="skala-tile">
          <div class="skala-eb">za miesiąc</div>
          <div class="skala-num">{fmt(heroMc.data.kwota)}<span class="skala-zl"> zł</span></div>
          <p class="skala-who">Kontrakt B2B — ortopeda, Ciechanów</p>
          <p class="skala-foot"><a href={heroMc.data.zrodloUrl} target="_blank" rel="noopener noreferrer">Rynek Zdrowia</a></p>
        </div>
        <div class="skala-tile">
          <div class="skala-eb">za rok</div>
          <div class="skala-num">{fmt(heroRok.data.kwota)}<span class="skala-zl"> zł</span></div>
          <p class="skala-who">Dochód roczny — analiza oświadczeń majątkowych</p>
          <p class="skala-foot"><a href={heroRok.data.zrodloUrl} target="_blank" rel="noopener noreferrer">Co w Zdrowiu</a></p>
        </div>
      </div>
      <p class="skala-ctx">
        Dla skali: najwyższy miesięczny kontrakt to <strong>ponad {heroMcMult}× mediana kontraktu
        specjalisty</strong> — <a href="/dane/rozklad-wynagrodzen/">25 595 zł/mies., mediana AOTMiT (II 2026)</a>.
      </p>

      <div class="czas">
        <div class="czas-head">
          <span class="czas-eb"><i class="czas-clock" aria-hidden="true">🕐</i> Rekord czasu — nie pieniędzy</span>
          <span class="chip chip-alert">zarzut — sprawa w toku</span>
        </div>
        <p class="czas-line"><span class="czas-num">1000+</span><span class="czas-per">godzin / miesiąc</span></p>
        <p class="czas-sub">
          W miesiącu, który ma najwyżej <strong>744 godziny</strong>; w skali roku wykazano
          <strong>11 577 godzin</strong> (rok ma 8 760), a bywały doby rozliczone na <strong>72 godziny</strong>.
          Ten sam lekarz rozliczany w kilku miejscach naraz — <strong>bo nikt nie sumuje jego godzin</strong>.
        </p>
        <p class="czas-note">
          Roczne rozliczenie <strong>1 772 879,50 zł</strong>; szacowana strata szpitala
          <strong>~3,8 mln zł</strong> w trzy lata. Ujawnił to dopiero nowy zarząd podczas weryfikacji
          wypłat; sprawa trafiła do prokuratury (III 2025), lekarz sam się zwolnił (VII 2025) — nikomu
          nie postawiono zarzutów. Możliwe, bo <strong>żaden rejestr nie sumuje godzin jednej osoby po
          numerze PWZ</strong>. Szpital powiatowy w Braniewie (warmińsko-mazurskie).
        </p>
        <p class="rec-src"><a href="https://wydarzenia.interia.pl/kraj/news-lekarz-pracowal-72-godziny-na-dobe-to-bylo-wprost-dojenie-sz,nId,23511769" target="_blank" rel="noopener noreferrer">Interia</a></p>
      </div>

      <h2 style="margin-top: 2.5rem">Miesięczne rozliczenia (NFZ / kontrakty)</h2>
      <div class="rank">
        {miesieczne.map((z, i) => (
          <div class="rank-row">
            <span class="rank-i">{i + 1}</span>
            <div class="rank-main">
              <div class="rank-top">
                <span class="rank-label">{z.data.etykieta}</span>
                <span class="rank-num">{fmt(z.data.kwota)}<span class="rank-unit"> {z.data.jednostka}</span></span>
              </div>
              <div class="rank-bar"><div class={`rank-fill${i === 0 ? ' is-top' : ''}`} style={`width:${barW(z.data.kwota, miesieczne[0].data.kwota)}%`}></div></div>
              <p class="rank-meta">
                {z.data.forma && z.data.forma !== '—' && <span class="chip">{z.data.forma}</span>}
                {z.data.rola && <span class="rank-role">{z.data.rola}</span>}
                {z.data.region && <span> · {z.data.region}</span>}
                {z.data.statusFaktu === 'zarzut' && <span class="chip chip-alert">zarzut</span>}
                <a class="rank-src" href={z.data.zrodloUrl} target="_blank" rel="noopener noreferrer">{z.data.zrodloNazwa}</a>
              </p>
              {z.data.uwaga && <p class="rank-note">{z.data.uwaga}</p>}
            </div>
          </div>
        ))}
      </div>

      <h2 style="margin-top: 2.5rem">Roczne rozliczenia</h2>
      <p class="muted" style="max-width: 68ch; margin-top: 0.5rem">
        Różne źródła tej samej prawdy: <strong>oświadczenia majątkowe</strong> (jawne z mocy prawa),
        <strong>kontrakty</strong> i <strong>bezpośrednie wypłaty szpitali</strong>. Malejąco, wg kwoty.
      </p>
      <div class="rank">
        {roczne.map((z, i) => (
          <div class="rank-row">
            <span class="rank-i">{i + 1}</span>
            <div class="rank-main">
              <div class="rank-top">
                <span class="rank-label">{z.data.etykieta}</span>
                <span class="rank-num">{fmt(z.data.kwota)}<span class="rank-unit"> {z.data.jednostka}</span></span>
              </div>
              <div class="rank-bar"><div class={`rank-fill${i === 0 ? ' is-top' : ''}`} style={`width:${barW(z.data.kwota, roczne[0].data.kwota)}%`}></div></div>
              <p class="rank-meta">
                {z.data.forma && z.data.forma !== '—' && <span class="chip">{z.data.forma}</span>}
                {z.data.rola && <span class="rank-role">{z.data.rola}</span>}
                {z.data.region && <span> · {z.data.region}</span>}
                {z.data.statusFaktu === 'zarzut' && <span class="chip chip-alert">zarzut</span>}
                <a class="rank-src" href={z.data.zrodloUrl} target="_blank" rel="noopener noreferrer">{z.data.zrodloNazwa}</a>
              </p>
              {z.data.uwaga && <p class="rank-note">{z.data.uwaga}</p>}
            </div>
          </div>
        ))}
      </div>

      <p class="source-note" style="margin-top: 1.5rem">
        <strong>Uczciwie:</strong> to różne miary — <strong>dochód</strong> z oświadczenia majątkowego
        (praktyka indywidualna) nie jest tożsamy z <strong>wypłatą</strong> kontraktu czy etatu, a część
        praktyk rozlicza się też prywatnie. Kwoty rozliczeń to fakty; ewentualne zarzuty w postępowaniach
        oznaczamy osobno i traktujemy jako <strong>nieudowodnione</strong>.
      </p>

      <h2 style="margin-top: 2.75rem">Kontrakt bije etat: pełna tabela wojewódzka (2025)</h2>
      <p class="muted" style="max-width: 68ch; margin-top: 0.5rem">
        Jedno oficjalne zestawienie — <strong>10 najwyższych wynagrodzeń</strong> w szpitalach
        wojewódzkich Mazowsza (2025), wg formy zatrudnienia — pokazuje sedno całej strony: za tę
        samą pracę <strong>kontrakt (B2B) bije etat i umowę cywilnoprawną kilkukrotnie</strong>.
        I to właśnie <strong>kwot kontraktowych nikt zwykle nie ujawnia</strong> — dlatego jawny
        rejestr po numerze <a href="/postulat/">PWZ</a> zmieniłby tu wszystko.
      </p>
      <div class="table-wrap">
        <table class="woj">
          <thead>
            <tr>
              <th rowspan="2">L.p.</th>
              <th colspan="2">Etat (umowa o pracę)</th>
              <th rowspan="2" class="woj-kh">Kontrakt<br /><span class="woj-sub">za mies.</span></th>
              <th colspan="2">Umowa cywilnoprawna</th>
            </tr>
            <tr>
              <th class="woj-sub2">brutto</th><th class="woj-sub2">netto</th>
              <th class="woj-sub2">brutto</th><th class="woj-sub2">netto</th>
            </tr>
          </thead>
          <tbody>
            {woj2025.map((r) => (
              <tr>
                <td class="woj-lp">{r.lp}</td>
                <td class="num">{fmt(r.eb)}</td>
                <td class="num woj-netto">{fmt(r.en)}</td>
                <td class="num woj-k">{fmt(r.k)}{r.kx ? '**' : ''}</td>
                <td class="num">{fmt(r.ub)}</td>
                <td class="num woj-netto">{fmt(r.un)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="source-note">
        Kwoty w zł/mies., zaokrąglone do złotego. <strong>*</strong> kwota wypłacona jednej osobie:
        wszystkie cykliczne dodatki i dyżury (bez nagród jubileuszowych, odpraw, „trzynastek”,
        premii i wypłat jednorazowych). <strong>**</strong> umowa rozwiązana. Etat ma wysokie
        obciążenia — stąd duża różnica brutto/netto; dla kontraktu (B2B) źródło podaje jedną kwotę,
        bez rozbicia. Źródło: zestawienie Urzędu Marszałkowskiego
        Woj. Mazowieckiego za
        <a href="https://www.rynekzdrowia.pl/Finanse-i-zarzadzanie/Kacprzyk-nie-byl-rekordzista-W-szpitalach-mazowieckich-mozna-zarobic-nawet-316-tys-zl-miesiecznie,285578,1.html" target="_blank" rel="noopener noreferrer">Rynek Zdrowia</a>.
      </p>

      <h2 style="margin-top: 2.75rem">Kiedy jawność zadziałała — Włocławek</h2>
      <p class="muted" style="max-width: 68ch; margin-top: 0.5rem">
        Zwykle kwot kontraktowych <strong>nikt nie ujawnia</strong>. Tu było inaczej: Wojewódzki
        Szpital Specjalistyczny we Włocławku po prostu <strong>odpowiedział lokalnej gazecie</strong>
        pełnym zestawieniem. Żadnego wycieku ani afery — zwykła odpowiedź instytucji publicznej
        na pytanie prasy.
      </p>
      <div class="jawnosc-case">
        <div class="jc-head"><span class="jc-mark">✓</span> Szpital podał liczby, bo redakcja zapytała</div>
        <p class="jc-lead">
          <strong>315 lekarzy</strong>, a wśród nich najlepiej zarabiający rozliczył w 2025 r.
          <strong>1 474 919 zł</strong> (~122 tys. zł/mies.); w maju 2026 najwyższe miesięczne
          rozliczenie sięgnęło <strong>139 957 zł</strong> brutto — najwięcej w radiologii i
          kardiologii inwazyjnej, przy dyżurach <strong>350–400 zł/h</strong>. Na samych lekarzy
          poszło <strong>84,1 mln zł</strong>, czyli <strong>32,86%</strong> kosztów osobowych szpitala.
        </p>
        <div class="realne">
          <div class="realne-stat">
            <span class="realne-num">~22 tys.</span>
            <span class="realne-lab">średnio na lekarza / mies.</span>
          </div>
          <div class="realne-x">× 6,3 →</div>
          <div class="realne-stat is-rec">
            <span class="realne-num">~140 tys.</span>
            <span class="realne-lab">rekord miesięczny (V 2026)</span>
          </div>
        </div>
        <p class="realne-cap">
          <strong>To są realne pensje:</strong> 84,1 mln zł ÷ 315 lekarzy = <strong>~267 tys. zł rocznie
          (~22 tys./mies.)</strong> średnio na lekarza — niemal tyle, co
          <a href="/dane/rozklad-wynagrodzen/">mediana kontraktu specjalisty (25,6 tys.)</a>.
          Najwyższe miesięczne rozliczenie (maj 2026) to <strong>139 957 zł — 6,3× średniej</strong>:
          wąski margines, nie norma. (Średni koszt szpitala na lekarza — miesza pełne i częściowe etaty,
          więc to rząd wielkości, nie wypłata konkretnej osoby.)
        </p>
        <div class="jc-split" role="img" aria-label="Z 315 lekarzy: 245 na kontraktach, 61 na etacie, 9 na innych umowach">
          <div class="jc-seg jc-seg-k" style="width:77.8%"><span>245 kontrakty</span></div>
          <div class="jc-seg jc-seg-e" style="width:19.4%"><span>61 etat</span></div>
          <div class="jc-seg jc-seg-i" style="width:2.8%"></div>
        </div>
        <p class="jc-legend">
          <span class="jc-key jc-key-k"></span> kontrakty (245) ·
          <span class="jc-key jc-key-e"></span> etat (61) ·
          <span class="jc-key jc-key-i"></span> inne umowy (9)
        </p>
        <p class="jc-note">
          Ponad <strong>trzech na czterech</strong> lekarzy rozlicza się tu na kontrakcie — i to
          właśnie <strong>kwot kontraktowych zwykle nie widać</strong>. Dokładnie tak wyglądałby
          <a href="/postulat/">rejestr po numerze PWZ</a>: pełne, łączne rozliczenie ze środków
          publicznych — tyle że <strong>systemowo, dla każdego szpitala i każdego lekarza</strong>,
          a nie wtedy, gdy akurat zapyta lokalna gazeta.
        </p>
        <p class="rec-src"><a href="https://ddwloclawek.pl/pl/11_wiadomosci/95804_milionowe-zarobki-lekarzy-takze-w-szpitalu-we-wloclawku-rekordzista-dostal.html" target="_blank" rel="noopener noreferrer">DDWłocławek</a></p>
      </div>

      <h2 style="margin-top: 2.75rem">Jawne — a i tak niewidoczne</h2>
      <p class="muted" style="max-width: 68ch; margin-top: 0.5rem">
        Bywa, że dochód lekarza jest <strong>jawny z mocy prawa</strong> — u <strong>radnych-lekarzy</strong>,
        bo pełnią funkcję publiczną i składają oświadczenia majątkowe. Poniżej 19 takich rocznych
        dochodów z praktyki lekarskiej (bez nazwisk). Sęk w tym, że widać je <em>tylko dlatego</em>,
        że akurat są radnymi.
      </p>

      <p class="okno-q">Czyj dochód ze środków publicznych <strong>w ogóle da się sprawdzić?</strong></p>
      <div class="okno">
        <div class="okno-card is-yes">
          <div class="okno-head"><span class="okno-mark">✓</span> Widać</div>
          <p class="okno-who">Lekarz, który jest <strong>radnym</strong></p>
          <p class="okno-count">garstka — te 19 kwot wyżej</p>
          <p class="okno-desc">Pełni funkcję publiczną, więc składa <strong>jawne oświadczenie majątkowe</strong> (BIP). Dlatego jego dochód można poznać.</p>
        </div>
        <div class="okno-card is-no">
          <div class="okno-head"><span class="okno-mark">✗</span> Nie widać</div>
          <p class="okno-who"><strong>Każdy inny</strong> lekarz</p>
          <p class="okno-count">~164 892 wykonujących zawód</p>
          <p class="okno-desc">Ta sama praca, ten sam publiczny NFZ — ale <strong>żaden publiczny rejestr</strong> nie pokazuje, ile zarabia.</p>
        </div>
      </div>
      <p class="okno-cap">
        Różnica nie leży w pracy ani w pieniądzach — tylko w tym, że jednego widać <em>przez przypadek</em>
        (bo jest radnym). <strong>Rejestr po numerze PWZ</strong> pokazywałby tak samo <strong>wszystkich</strong>.
      </p>
      <p class="source-note">
        Liczba lekarzy wykonujących zawód — rejestr <strong>NIL</strong> (stan 16 I 2026), zob.
        <a href="/analizy/zarobki-lekarzy-polska-sasiedzi/">lejek liczby lekarzy</a>.
      </p>

      <div class="callout quiet">
        <p style="margin: 0">
          <strong>19 dochodów, rocznie:</strong> mediana <strong>~916 tys. zł</strong> · średnia
          <strong>~913 tys. zł</strong> · rozrzut od <strong>582 tys.</strong> do
          <strong>1,49 mln zł</strong>. U części sam przychód (obrót) sięgał <strong>3,9 mln zł</strong>.
        </p>
      </div>
      <div class="dist">
        {radniDochody.map((d) => (
          <div class={`dist-row${d === radniStat.mediana ? ' is-med' : ''}`}>
            <div class="dist-track">
              <div class="dist-bar" style={`width:${Math.round((d / radniStat.max) * 100)}%`}></div>
              {d === radniStat.mediana && <span class="dist-tag">mediana</span>}
            </div>
            <span class="dist-val">{fmt(d)} zł</span>
          </div>
        ))}
      </div>

      <div class="callout">
        <p>
          <strong>To nie kwoty są tu sednem — lecz to, że są jawne, a mimo to rozsypane.</strong>
          Te ~20 dochodów widać przez <strong>przypadek pełnienia funkcji</strong>. Dla ~164 892
          lekarzy wykonujących zawód nie ma nawet tego okna — choć płaci im ten sam publiczny NFZ.
          Rejestr powiązany z numerem <a href="/postulat/">PWZ</a> zsumowałby to systemowo, dla
          każdego, w jeden dzień. Ktoś już liczy to <strong>ręcznie, po omacku</strong> — bo
          państwo takiego rejestru nie prowadzi.
        </p>
      </div>
      <p class="source-note">
        <strong>Metoda i zastrzeżenia.</strong> Oddolne zestawienie z <strong>jawnych oświadczeń
        majątkowych</strong> radnych-lekarzy (dokumenty publiczne w BIP właściwych jednostek) —
