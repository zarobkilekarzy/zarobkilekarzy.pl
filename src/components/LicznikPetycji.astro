---
// Licznik „wysłałem petycję" — self-reported, anonimowy. REUŻYWA istniejący endpoint
// /api/clicks (D1, binding CLICKS_DB) ze slugiem 'petycja-wyslana' — zero nowego backendu.
// GET (odczyt) jest edge-cache'owany Cache Rule na /api/* (Edge TTL ~300 s), więc odsłony
// nie palą Funkcji/Workera; POST inkrementuje raz na przeglądarkę (localStorage).
//
// Ochrona:
//  • anty-double-click — flagi `done`/`submitting` + `disabled` (w sesji), localStorage
//    (między odświeżeniami/kartami), jednorazowy token po stronie serwera (replay);
//  • antybot — gdy serwer ma skonfigurowany Turnstile, GET zwraca `turnstileSiteKey`,
//    front renderuje widżet i dokłada token do POST (slug 'petycja-wyslana' jest chroniony).
// Bez konfiguracji Turnstile / bez bindingu / w `npm run dev` degraduje się łagodnie:
// widżet się nie pojawia, liczba „—", a klik i tak działa lokalnie.
---

<div class="licznik" id="licznik-petycji">
  <p class="eyebrow">Dołącz</p>
  <p class="licz-line"><span class="licz-n" id="licz-n">—</span> <span id="licz-osoby">osób zadeklarowało</span> już wysłanie petycji</p>
  <div class="licz-cta">
    <button class="btn btn-primary" id="licz-btn" type="button">Wysłałem/-am petycję</button>
    <span class="licz-done" id="licz-done" hidden>Dziękujemy — doliczono anonimowo.</span>
  </div>
  <div class="licz-turnstile" hidden></div>
  <p class="licz-alert" role="alert" hidden></p>
  <p class="licz-hint">
    Kliknij dopiero po faktycznym wysłaniu petycji — nie na znak poparcia. Tylko wtedy
    liczba cokolwiek znaczy.
  </p>
  <p class="licz-note">
    Licznik opiera się na Twoich zgłoszeniach (nie weryfikujemy wysyłki) — zapisujemy je
    w tej przeglądarce, zbiorczo i anonimowo, bez danych osobowych.
  </p>
</div>

<script>
  const SLUG = 'petycja-wyslana';
  const KEY = 'petycja-wyslana-v1';
  const API = '/api/clicks';
  const TURNSTILE_API = 'https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit';
  const root = document.getElementById('licznik-petycji');
  if (root) {
    const nEl = root.querySelector('#licz-n');
    const osobyEl = root.querySelector('#licz-osoby');
    const btn = root.querySelector('#licz-btn');
    const doneEl = root.querySelector('#licz-done');
    const turnstileEl = root.querySelector('.licz-turnstile');
    const alertEl = root.querySelector('.licz-alert');

    let count = null;
    let done = false;             // zgłoszono / zablokowane na stałe
    let submitting = false;       // trwa wysyłka — anty-double-click „w locie"
    let tsToken = null;           // ostatni token Turnstile (null = brak/wygasł)
    let tsWidgetId = null;        // id wyrenderowanego widżetu (do execute/reset)
    let tsSiteKey = null;         // klucz publiczny (potrzebny przy execute)
    let turnstileEnabled = false; // czy serwer wymaga tokenu dla tego sluga

    // Odmiana frazy do liczby: 1 → „osoba zadeklarowała"; końcówka 2–4 (ale nie 12–14)
    // → „osoby zadeklarowały"; reszta (w tym 5–21) → „osób zadeklarowało".
    const formaOsoby = (n) => {
      if (n === 1) return 'osoba zadeklarowała';
      const d = n % 10, s = n % 100;
      if (d >= 2 && d <= 4 && !(s >= 12 && s <= 14)) return 'osoby zadeklarowały';
      return 'osób zadeklarowało';
    };
    const render = () => {
      nEl.textContent = count == null ? '—' : count.toLocaleString('pl-PL');
      osobyEl.textContent = count == null ? 'osób zadeklarowało' : formaOsoby(count);
    };
    const showAlert = (msg) => { alertEl.textContent = msg || ''; alertEl.hidden = !msg; };
    const markDone = () => {
      done = true;
      btn.disabled = true;
      btn.classList.add('chosen');
      doneEl.hidden = false;
      turnstileEl.hidden = true;
      showAlert('');
    };

    // Zgłoszono już w tej przeglądarce? → od razu stan „zrobione", bez Turnstile.
    let prev = null;
    try { prev = localStorage.getItem(KEY); } catch (e) {}
    if (prev) markDone();

    const loadScript = (src) => new Promise((res, rej) => {
      const s = document.createElement('script');
      s.src = src; s.async = true; s.defer = true; s.onload = res; s.onerror = rej;
      document.head.appendChild(s);
    });

    const postClick = async (token) => {
      try {
        const body = token ? { slug: SLUG, turnstileToken: token } : { slug: SLUG };
        // fetch + keepalive (nie sendBeacon) — musimy dołożyć token i odczytać status.
        const r = await fetch(API, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
          keepalive: true,
        });
        return { ok: r.ok, status: r.status };
      } catch (e) { return { ok: false, status: 0 }; }
    };

    // Wysyłka ze świeżym (lub żadnym) tokenem: optymistyczny +1, POST, obsługa 403.
    const submitWith = async (token) => {
      try { localStorage.setItem(KEY, String(Date.now())); } catch (e) {}
      if (count != null) { count += 1; render(); } // optymistycznie
      const res = await postClick(token);
      if (res.status === 403) {
        // token odrzucony (wygasł / duplikat) → cofnij optymizm, zresetuj widżet, pozwól ponowić
        if (count != null) { count -= 1; render(); }
        try { localStorage.removeItem(KEY); } catch (e) {}
        tsToken = null;
        if (tsWidgetId != null && window.turnstile) { try { window.turnstile.reset(tsWidgetId); } catch (e) {} }
        submitting = false;
        btn.disabled = false;
        showAlert('Weryfikacja nie powiodła się — spróbuj ponownie.');
        return;
      }
      // Sukces (204) albo miękki błąd sieci: licznik jest self-reported, więc i tak
      // zostawiamy stan „zrobione" (zgodnie z dotychczasowym łagodnym zachowaniem).
      markDone();
    };

    // Świeży token z execute() → dokończ trwającą wysyłkę tym tokenem.
    const onToken = (token) => {
      tsToken = token;
      showAlert('');
      if (submitting) submitWith(token);
    };
    // Wyzwanie nie powiodło się/timeout w trakcie kliknięcia → odblokuj i pokaż komunikat.
    const onTurnstileFail = () => {
      tsToken = null;
      if (submitting) {
        if (tsWidgetId != null && window.turnstile) { try { window.turnstile.reset(tsWidgetId); } catch (e) {} }
        submitting = false;
        btn.disabled = false;
        showAlert('Weryfikacja nie powiodła się — spróbuj ponownie.');
      }
    };

    // Turnstile w trybie EXECUTE: NIE rozwiązujemy wyzwania na starcie (token żyje ~300 s
    // i wygasłby, zanim ktoś kliknie po faktycznym wysłaniu petycji — to była przyczyna
    // 403 „Weryfikacja nie powiodła się" na prodzie). Wyzwanie odpalamy DOPIERO przy
    // kliknięciu, tuż przed POST → token zawsze świeży i jednorazowy.
    const initTurnstile = async (siteKey) => {
      try {
        await loadScript(TURNSTILE_API);
        // poczekaj aż globalne `turnstile` będzie gotowe (maks. ~5 s)
        await new Promise((res) => {
          if (window.turnstile) return res();
          const iv = setInterval(() => { if (window.turnstile) { clearInterval(iv); res(); } }, 50);
          setTimeout(() => { clearInterval(iv); res(); }, 5000);
        });
        if (!window.turnstile) return false;
        tsSiteKey = siteKey;
        turnstileEl.hidden = false;
        tsWidgetId = window.turnstile.render(turnstileEl, {
          sitekey: siteKey,
          execution: 'execute',           // rozwiąż na żądanie (przy kliknięciu), nie na starcie
          appearance: 'interaction-only', // widżet niewidoczny, chyba że wymaga interakcji
          callback: (token) => { onToken(token); },
          'expired-callback': () => { tsToken = null; },
          'error-callback': () => { onTurnstileFail(); },
          'timeout-callback': () => { onTurnstileFail(); },
        });
        return true;
      } catch (e) { return false; }
    };

    // Odczyt licznika + konfiguracji jednym cache'owanym GET-em. Gdy Turnstile jest
    // włączony i jeszcze nie zgłoszono — wyrenderuj widżet (execute, bez rozwiązywania).
    // Błąd/brak bindingu → zostaje „—", przycisk działa dalej (fallback bez tokenu).
    (async () => {
      let cfg = null;
      try { const r = await fetch(API); if (r.ok) cfg = await r.json(); } catch (e) {}
      if (!cfg) return;
      count = (cfg.counts && cfg.counts[SLUG]) || 0;
      render();
      if (!done && cfg.turnstileSiteKey) {
        turnstileEnabled = await initTurnstile(cfg.turnstileSiteKey);
      }
    })();

    // Klik: przy włączonym Turnstile odpalamy ŚWIEŻE wyzwanie i wysyłamy w callbacku;
    // bez Turnstile wysyłamy od razu. Anty-double-click: flagi done/submitting + disabled.
    btn.addEventListener('click', () => {
      if (done || submitting) return;
      submitting = true;
      btn.disabled = true;
      showAlert('');
      if (turnstileEnabled) {
        if (tsWidgetId == null || !window.turnstile) {
          // widżet się nie wyrenderował (np. skrypt CF zablokowany) → nie wysyłamy bez
          // tokenu (serwer i tak odrzuci); pozwól spróbować za chwilę.
          submitting = false;
          btn.disabled = false;
          showAlert('Trwa weryfikacja antybotowa — spróbuj za chwilę.');
          return;
        }
        showAlert('Weryfikacja antybotowa…');
        // execute() → onToken(świeży token) → submitWith; onTurnstileFail obsługuje błąd/timeout.
        try { window.turnstile.execute(turnstileEl, { sitekey: tsSiteKey }); }
        catch (e) { onTurnstileFail(); }
      } else {
        submitWith(null);
      }
    });
  }
</script>

<style>
  .licznik {
    background: var(--brand-50);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.75rem;
    margin-top: 2.5rem;
  }
  .licz-line { margin: 0.3rem 0 1.1rem; font-size: 1.15rem; color: var(--ink); }
  .licz-n {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.9rem;
    color: var(--brand);
    font-variant-numeric: tabular-nums;
    margin-right: 0.15rem;
  }
  .licz-cta { display: flex; align-items: center; gap: 0.9rem; flex-wrap: wrap; }
  #licz-btn.chosen { background: var(--brand-700); border-color: var(--brand-700); color: #fff; opacity: 1; cursor: default; }
  .licz-done { font-weight: 500; color: var(--brand-700); }
  .licz-turnstile:not([hidden]) { margin-top: 1.1rem; }
  .licz-alert:not([hidden]) { margin: 0.8rem 0 0; font-size: 0.9rem; color: var(--alert); }
  .licz-hint { margin: 0.85rem 0 0; font-size: 0.92rem; color: var(--ink-soft); line-height: 1.5; }
  .licz-note { margin: 0.6rem 0 0; font-size: 0.85rem; color: var(--ink-faint); line-height: 1.5; }
</style>
