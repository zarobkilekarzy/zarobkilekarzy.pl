---
// Pliki-indeksy fontsource: każdy niesie @font-face z unicode-range dla subsetów
// `latin` ORAZ `latin-ext`, więc przeglądarka złoży pełną polszczyznę (m.in. „ó",
// która jest w zakresie podstawowym `latin`, nie w `latin-ext`). Nieużywane subsety
// (cyrylica/greka/wietnamski) mają rozłączny unicode-range i nie są pobierane.
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/500.css';
import '@fontsource/ibm-plex-sans/600.css';
import '@fontsource/ibm-plex-serif/500.css';
import '@fontsource/ibm-plex-serif/600.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
// Główny font tekstowy — preload obu subsetów wagi 400 (ASCII/„ó" + diakryty),
// by ograniczyć FOUT i opóźnienie LCP.
import bodyFontUrl from '@fontsource/ibm-plex-sans/files/ibm-plex-sans-latin-400-normal.woff2?url';
import bodyFontExtUrl from '@fontsource/ibm-plex-sans/files/ibm-plex-sans-latin-ext-400-normal.woff2?url';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { ogPages } from '../lib/ogPages';
import { lastmodFor, normalizePath } from '../lib/pageDates.mjs';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = 'zarobkilekarzy.pl — jawność wynagrodzeń w ochronie zdrowia',
  description =
    'Obywatelska inicjatywa na rzecz jawności publicznych pieniędzy w ochronie zdrowia. Dane, źródła i postulat jawnego rejestru wynagrodzeń lekarzy.',
  image,
  noindex = false,
} = Astro.props;

// Obraz OG: jawny `image` z propsów > dynamiczny per-strona (ogPages). Dla tras
// dynamicznych (paginacja artykułów, kategorie) dziedziczymy OG najbliższego rodzica
// z mapy (np. artykuly/2 → artykuly). Brak trafienia → navy karta strony głównej —
// nigdy biały statyczny fallback (ten wisiał w cache X jako „stara karta").
const rawKey = Astro.url.pathname.replace(/^\/+|\/+$/g, '') || 'home';
const ogKey = (() => {
  const parts = rawKey.split('/');
  while (parts.length) {
    const k = parts.join('/');
    if (ogPages[k]) return k;
    parts.pop();
  }
  return 'home';
})();
const resolvedImage = image ?? `/og/${ogKey}.png`;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(resolvedImage, Astro.site);

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'zarobkilekarzy.pl',
  url: Astro.site?.toString(),
  logo: new URL('/favicon.png', Astro.site).toString(),
  description:
    'Obywatelska inicjatywa na rzecz jawności publicznych pieniędzy w ochronie zdrowia.',
};

const siteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'zarobkilekarzy.pl',
  url: Astro.site?.toString(),
  inLanguage: 'pl-PL',
  description:
    'Dane, źródła i postulat jawnego rejestru wynagrodzeń lekarzy ze środków publicznych.',
};

// Wydawca powtarzany w kilku schematach (Article/Dataset) — jedna definicja.
const publisher = {
  '@type': 'Organization',
  name: 'zarobkilekarzy.pl',
  url: Astro.site?.toString(),
  logo: {
    '@type': 'ImageObject',
    url: new URL('/favicon.png', Astro.site).toString(),
  },
};

// Dane strukturalne generowane automatycznie z URL — bez propsów per-strona:
//  • BreadcrumbList — dla stron zagnieżdżonych (widoczny trop to „eyebrow"),
//  • Article       — teksty redakcyjne (/analizy, /mechanizmy),
//  • Dataset       — strony danych (/dane) → kwalifikacja do Google Dataset Search.
// Nazwa strony do schematów = tytuł bez sufiksu „ — zarobkilekarzy.pl".
const headline = title.replace(/\s*—\s*zarobkilekarzy\.pl\s*$/, '').trim();
const norm = normalizePath(Astro.url.pathname);
const segs = norm === '/' ? [] : norm.slice(1).split('/');
const nested = segs.length >= 2;
const modified = lastmodFor(Astro.url.pathname);

const SECTION_LABELS = {
  dane: 'Dane',
  analizy: 'Analizy',
  mechanizmy: 'Mechanizmy',
};

// noindex (np. /admin) nie dostają żadnych danych strukturalnych.
const wantSchema = !noindex && nested;
const isArticle = wantSchema && (segs[0] === 'analizy' || segs[0] === 'mechanizmy');
const isDataset = wantSchema && segs[0] === 'dane';

let breadcrumbSchema = null;
if (wantSchema) {
  const crumbs = [{ name: 'Strona główna', url: Astro.site?.toString() }];
  let acc = '';
  segs.forEach((s, i) => {
    acc += `/${s}`;
    const last = i === segs.length - 1;
    crumbs.push({
      name: last ? headline : (SECTION_LABELS[s] ?? s),
      url: new URL(acc, Astro.site).toString(),
    });
  });
  breadcrumbSchema = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: crumbs.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: c.name,
      item: c.url,
    })),
  };
}

const articleSchema = isArticle
  ? {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline,
      description,
      inLanguage: 'pl-PL',
      image: ogImage.toString(),
      mainEntityOfPage: canonical.toString(),
      author: publisher,
      publisher,
      ...(modified ? { datePublished: modified, dateModified: modified } : {}),
    }
  : null;

const datasetSchema = isDataset
  ? {
      '@context': 'https://schema.org',
      '@type': 'Dataset',
      name: headline,
      description,
      url: canonical.toString(),
      inLanguage: 'pl-PL',
      isAccessibleForFree: true,
      license: 'https://creativecommons.org/licenses/by/4.0/',
      creator: publisher,
      publisher,
      spatialCoverage: { '@type': 'Place', name: 'Polska' },
      keywords: [
        'wynagrodzenia lekarzy',
        'NFZ',
        'ochrona zdrowia',
        'dane publiczne',
        'jawność',
        'Polska',
      ],
      ...(modified ? { dateModified: modified } : {}),
    }
  : null;

// Wszystkie schematy w jednej tablicy — render jedną pętlą (mniej powtórzeń).
const jsonLd = [orgSchema, siteSchema, breadcrumbSchema, articleSchema, datasetSchema].filter(
  Boolean,
);
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preload" href={bodyFontUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={bodyFontExtUrl} as="font" type="font/woff2" crossorigin />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0f4c81" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={noindex ? 'noindex,follow' : 'index,follow'} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="zarobkilekarzy.pl — baza źródeł"
      href="/rss.xml"
    />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="zarobkilekarzy.pl" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="pl_PL" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@zarobkilekarzy" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="zarobkilekarzy.pl — jawność wynagrodzeń w ochronie zdrowia" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema).replace(/</g, '\\u003c')} />
    ))}
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Przejdź do treści</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script>
      // Liczniki przejść do źródeł: pokaż liczby (1 cache'owany GET /api/clicks)
      // i policz kliknięcie w kartę (beacon POST, raz na ~12 h na slug w tej
      // przeglądarce). Bez ciasteczek, bez danych osobowych. No-op, gdy na
      // stronie nie ma kart artykułów lub gdy D1 nie jest jeszcze podpięte.
      (async () => {
        const badges = document.querySelectorAll('.article-clicks[data-clicks-for]');
        if (badges.length) {
          try {
            const res = await fetch('/api/clicks');
            if (res.ok) {
              const { counts } = await res.json();
              badges.forEach((el) => {
                const n = (counts && counts[el.dataset.clicksFor]) || 0;
                if (n > 0) {
                  el.textContent = n + ' ↗';
                  el.title = 'Przejścia do źródła: ' + n;
                  el.hidden = false;
                }
              });
            }
          } catch (e) {}
        }
        document.addEventListener('click', (e) => {
          const t = e.target;
          if (!(t instanceof Element)) return;
          const a = t.closest('a.article-link[data-slug]');
          if (!a) return;
          const slug = a.dataset.slug;
          try {
            const key = 'clk:' + slug;
            const now = Date.now();
            if (now - (Number(localStorage.getItem(key)) || 0) < 12 * 3600 * 1000) return;
            localStorage.setItem(key, String(now));
          } catch (e) {}
          try {
            navigator.sendBeacon('/api/clicks', JSON.stringify({ slug }));
          } catch (e) {}
        });
      })();
    </script>
  </body>
</html>
