---
// Dateline „ostatnia aktualizacja" dla stron redakcyjnych (analizy, mechanizmy).
// Data pochodzi z centralnej mapy `pageDates` (jedno źródło prawdy: ta sama data
// zasila też Article JSON-LD i <lastmod> w sitemapie). Prop `data` pozwala nadpisać
// ręcznie, ale zwykle wystarczy <Aktualizacja /> — datę czytamy po ścieżce URL.
// Emituje <time datetime> — czytelny sygnał świeżości dla czytelnika i wyszukiwarki.
import { lastmodFor } from '../lib/pageDates.mjs';

interface Props {
  data?: string;       // 'RRRR-MM-DD' — opcjonalne nadpisanie mapy
  zrodla?: string;     // opcjonalny dopisek, np. „ · dane AOTMiT (02.2026)"
}
const { data, zrodla } = Astro.props;
const iso = data ?? lastmodFor(Astro.url.pathname);

// Południe lokalne, by uniknąć przesunięcia dnia przy strefach czasowych.
const czytelna = iso
  ? new Intl.DateTimeFormat('pl-PL', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    }).format(new Date(`${iso}T12:00:00`))
  : null;
---

{iso && (
<p class="aktualizacja">
  Ostatnia aktualizacja: <time datetime={iso}><strong>{czytelna}</strong></time>{zrodla}
</p>
)}

<style>
  .aktualizacja {
    font-size: 0.82rem;
    color: var(--ink-faint);
    margin: 0.35rem 0 1.5rem;
  }
</style>
