---
const path = Astro.url.pathname;
const links = [
  { href: '/mechanizmy/', label: 'Mechanizmy' },
  { href: '/dane/', label: 'Dane' },
  { href: '/analizy/', label: 'Analizy' },
  { href: '/prawa-pacjenta/', label: 'Prawa pacjenta' },
  { href: '/artykuly/', label: 'Artykuły' },
  { href: '/postulat/', label: 'Postulat' },
];
const isActive = (href: string) =>
  path === href || (href !== '/' && path.startsWith(href));
---

<header class="site-nav">
  <div class="nav-inner">
    <a href="/" class="brand" aria-label="Strona główna — zarobkilekarzy.pl">
      <span class="brand-mark" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 32 32">
          <rect width="32" height="32" rx="7" fill="#0f4c81"></rect>
          <path
            d="M4 17h6l2-7 3.5 13L18 17h10"
            fill="none"
            stroke="#ffffff"
            stroke-width="2.4"
            stroke-linejoin="round"
            stroke-linecap="round"></path>
        </svg>
      </span>
      <span class="brand-name">zarobkilekarzy.pl</span>
    </a>

    <div class="nav-cluster">
      <nav id="nav-menu" class="nav-links" aria-label="Główna nawigacja">
        {
          links.map((l) => (
            <a href={l.href} class={isActive(l.href) ? 'active' : ''}>
              {l.label}
            </a>
          ))
        }
        <a href="/petycja/" class="btn btn-primary btn-sm">Petycja</a>
      </nav>

      {/* Lupa po nav-links → na desktopie na prawym skraju; na mobile (nav-links
          zwinięte do dropdownu) zostaje obok burgera. */}
      <a
        href="/szukaj/"
        class={`nav-search${isActive('/szukaj/') ? ' active' : ''}`}
        aria-label="Szukaj w serwisie"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="21" y1="21" x2="16.5" y2="16.5"></line>
        </svg>
      </a>

      <button
        type="button"
        class="nav-burger"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="nav-menu"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  // Menu mobilne dostępne z klawiatury: prawdziwy <button> + aria-expanded
  // (zastępuje wcześniejszy checkbox-hack, którego nie dało się otworzyć z klawiatury).
  const burger = document.querySelector('.nav-burger');
  const menu = document.getElementById('nav-menu');
  if (burger && menu) {
    const setOpen = (open) => {
      menu.classList.toggle('open', open);
      burger.setAttribute('aria-expanded', String(open));
    };
    burger.addEventListener('click', () =>
      setOpen(burger.getAttribute('aria-expanded') !== 'true'),
    );
    // Klik w link zamyka menu (kotwice/nawigacja w obrębie strony).
    menu.addEventListener('click', (e) => {
      if (e.target instanceof Element && e.target.closest('a')) setOpen(false);
    });
    // Escape zamyka i zwraca focus na przycisk.
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && burger.getAttribute('aria-expanded') === 'true') {
        setOpen(false);
        burger.focus();
      }
    });
    // Klik poza nagłówkiem zamyka otwarte menu.
    document.addEventListener('click', (e) => {
      if (
        burger.getAttribute('aria-expanded') === 'true' &&
        e.target instanceof Element &&
        !e.target.closest('.nav-inner')
      ) {
        setOpen(false);
      }
    });
  }
</script>
