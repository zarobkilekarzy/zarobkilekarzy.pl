---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareRow from '../../components/ShareRow.astro';
import Aktualizacja from '../../components/Aktualizacja.astro';

// MONITOR REFORMY ZDROWIA — żywe rozliczenie deklaracji obecnego rządu z osią czasu.
// Zasada: KAŻDA pozycja ma publiczne źródło (link) i jawny status. Rozróżniamy obietnicę
// (zapowiedź polityka) od legislacji (twardy etap: uchwalenie, podpis, wejście w życie).
// Status opisuje ETAP, nie ocenę intencji. „Spełnione" = weszło w życie / zrealizowane;
// nie znaczy, że działa dla pacjenta — to osobne pytanie, które zadajemy w opisach.
//
// AKTUALIZACJA: dopisujemy nowe wpisy do tablicy DEKLARACJE i bumpujemy datę w
// src/lib/pageDates.mjs. Statusy zmieniamy w miarę biegu spraw. Nic bez źródła.
//
// Ministra zdrowia (2026): Jolanta Sobierańska-Grenda; wcześniej Izabela Leszczyna. Uwaga na
// atrybucję: „Moje Zdrowie", KSO i część zapowiedzi z 2025 r. to okres Leszczyny; plan reform
// z 8.07.2026, ustawa o danych i limity płac — Sobierańska-Grenda. Ta sama koalicja (rząd Tuska).
// Pułapki liczbowe uszanowane w danych: KSK = „354 przedsięwzięcia / ~1,94 mld zł w dwóch
// naborach; pula KPO 2,65 mld" (NIE „376 / 2,6 mld"); zniesienie limitów AOS to reforma
// POPRZEDNIEGO rządu (2021), którą obecny częściowo odwraca; „7% PKB" to ścieżka USTAWOWA.

// — Słownik statusów (kolejność = od „domkniętego" do „porzuconego") —
const STATUSY = {
  spelnione:     { label: 'Spełnione',    opis: 'weszło w życie lub zrealizowane', kolor: 'ok' },
  'w-toku':      { label: 'W toku',       opis: 'prace trwają, w terminie',        kolor: 'teal' },
  zapowiedziane: { label: 'Zapowiedziane', opis: 'ogłoszone, jeszcze nierozpoczęte', kolor: 'neutral' },
  spozniona:     { label: 'Spóźnione',    opis: 'termin minął lub się zsuwa',       kolor: 'amber' },
  porzucone:     { label: 'Porzucone',    opis: 'wycofane, zawetowane lub martwe',  kolor: 'alert' },
} as const;
type Status = keyof typeof STATUSY;

// — Filary reformy (grupy tematyczne) —
const FILARY = {
  szpitale:     { nazwa: 'Szpitale: sieć, restrukturyzacja, oddłużenie' },
  koszty:       { nazwa: 'Koszty pracy i wynagrodzenia' },
  jawnosc:      { nazwa: 'Jawność, dane i kontrola' },
  cyfryzacja:   { nazwa: 'Cyfryzacja i dostęp' },
  sieci:        { nazwa: 'Sieci klinicze i profilaktyka' },
  finansowanie: { nazwa: 'Finansowanie, składka i leki' },
} as const;
type Filar = keyof typeof FILARY;

type Zrodlo = { label: string; url: string };
interface Deklaracja {
  tytul: string;
  kto: string;
  data: string;        // ISO — kotwica na osi czasu (dzień zdarzenia albo ogłoszenia)
  termin?: string;     // obiecany termin / etap docelowy
  status: Status;
  typ: 'obietnica' | 'legislacja';
  filar: Filar;
  opis: string;
  zrodla: Zrodlo[];
}

// — DANE. Każda pozycja oźródłowana. Cytaty i liczby dokładne. —
