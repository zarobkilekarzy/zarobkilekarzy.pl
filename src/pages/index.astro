---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Sonda from '../components/Sonda.astro';
import ShareRow from '../components/ShareRow.astro';
import { getCollection } from 'astro:content';

const latest = (await getCollection('articles'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Inicjatywa obywatelska na rzecz jawności</p>
        <h1>Publiczne pieniądze,<br /><span class="hl">niejawne zarobki</span></h1>
        <p class="lead">
          Część lekarzy rozlicza miliony złotych ze środków publicznych, łącząc
          kontrakty w wielu placówkach — a pacjenci miesiącami czekają w kolejce.
          Zbieramy dane, linkujemy źródła i postulujemy jawny rejestr wynagrodzeń.
        </p>
        <div class="cta-row">
          <a class="btn btn-primary" href="/dzialaj">Podpisz postulat</a>
          <a class="btn" href="/dane">Zobacz dane</a>
        </div>
        <p style="font-size:0.85rem;color:var(--ink-soft);margin-top:0.9rem">
          Petycja powstanie wkrótce — <a href="/dzialaj">napisz do polityka już teraz →</a>
        </p>
      </div>

      <aside class="stat-card">
        <p class="stat-label">Stan obecny</p>
        <p class="stat-num">0</p>
        <p class="stat-desc">
          ogólnodostępnych rejestrów pokazujących łączne wynagrodzenie jednego
          lekarza ze środków publicznych
        </p>
        <span class="pill pill-alert">brak jawności</span>
      </aside>
    </div>
  </section>

  <!-- FILARY -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow">Co pokazujemy</p>
      <div class="pillars">
        <div class="pillar">
          <span class="ico" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
              <ellipse cx="12" cy="6" rx="7" ry="3"></ellipse>
              <path d="M5 6v6c0 1.7 3.1 3 7 3s7-1.3 7-3V6"></path>
              <path d="M5 12v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6"></path>
            </svg>
          </span>
          <h3>Wynagrodzenia z NFZ</h3>
          <p>Ile środków publicznych trafia do placówek i kto na tym korzysta.</p>
        </div>

        <div class="pillar">
          <span class="ico" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
              <path d="M4 21V8l8-5 8 5v13"></path>
              <path d="M9 21v-5h6v5"></path>
              <path d="M12 7v4M10 9h4"></path>
            </svg>
          </span>
          <h3>Wieloetatowość</h3>
          <p>Praca i rozliczanie kontraktów w kilku placówkach jednocześnie.</p>
        </div>

        <div class="pillar">
          <span class="ico" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
              <circle cx="12" cy="12" r="9"></circle>
              <path d="M12 7v5l3 2"></path>
            </svg>
          </span>
          <h3>Dostęp pacjentów</h3>
          <p>Czas oczekiwania w kolejce zestawiony z wydatkami systemu.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SKALA RÓŻNICY: WYKRES PŁAC -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Skala różnicy</p>
      <h2>Ile zarabia lekarz, a ile Ty?</h2>
      <p class="lead">
        Miesięczne wynagrodzenie brutto. Mediana lekarza dotyczy <strong>jednej
        placówki</strong> — a ok. 75% lekarzy pracuje na kontraktach, często w kilku
        naraz.
      </p>

      <div class="salary">
        <div class="bar-row">
          <div class="bar-head">
            <span class="bar-name">Minimalna krajowa</span>
            <span class="bar-val">4 806 zł</span>
          </div>
          <div class="bar-track">
            <div class="bar-fill is-min" style="width:20%"></div>
            <span class="bar-flag">← to Ty?</span>
          </div>
        </div>

        <div class="bar-row">
          <div class="bar-head">
            <span class="bar-name">Mediana wynagrodzeń w Polsce</span>
            <span class="bar-val">7 907 zł</span>
          </div>
          <div class="bar-track">
            <div class="bar-fill is-med" style="width:33%"></div>
          </div>
        </div>

        <div class="bar-row">
          <div class="bar-head">
            <span class="bar-name">Mediana wynagrodzenia lekarza</span>
            <span class="bar-val">≈ 24 000 zł</span>
          </div>
          <div class="bar-track">
            <div class="bar-fill is-doc" style="width:100%"></div>
          </div>
        </div>

        <div class="bar-row">
          <div class="bar-head">
            <span class="bar-name">Najwyższe rozliczenia lekarzy</span>
            <span class="bar-val">&gt; 100 000 zł</span>
          </div>
          <div class="bar-track">
            <div class="bar-fill is-patol" style="width:100%">
              <span class="patol-label">≥ 625 lekarzy · poza skalą wykresu ↗</span>
            </div>
          </div>
        </div>
      </div>

      <p class="salary-insight">
        Mediana wynagrodzenia lekarza to ok. <strong>5×</strong> płacy minimalnej i
        <strong>3×</strong> mediany krajowej — i to liczone w <strong>jednej</strong>
        placówce.
      </p>

      <div class="patol-note">
        <p>
          To nie sufit. <strong>≥ 625 lekarzy</strong> rozlicza ponad
          <strong>100 000 zł miesięcznie</strong> — licząc tylko <strong>jedną
          placówkę</strong>; po zsumowaniu kontraktów AOTMiT szacuje <strong>5–10%
          specjalistów</strong>. Ze środków publicznych rekordzista na kontrakcie w
          mazowieckim szpitalu wojewódzkim rozliczył <strong>316 079 zł netto
          miesięcznie</strong> — ponad <strong>1,26 mln zł w cztery miesiące</strong>
          (przy 1,4 mld zł długu tych szpitali). Rekord łącznych dochodów z oświadczenia
          majątkowego: ok. <strong>3 mln zł</strong> za 2025 r. (32-letni ortopeda,
          głównie prywatna praktyka).
        </p>
        <p class="source-note" style="margin-top: 0.5rem">
          Źródła: skala &gt; 100 tys./mc — dane AOTMiT (luty 2026), za
          <a href="https://www.rp.pl/ochrona-zdrowia/art44466691-625-lekarzy-w-polsce-zarabia-powyzej-100-tys-zl-dotarlismy-do-wyliczen" target="_blank" rel="noopener noreferrer">Rzeczpospolitą</a>;
          316 079 zł netto/mc — odpowiedź Urzędu Marszałkowskiego Woj. Mazowieckiego, za
          <a href="https://www.termedia.pl/mz/Milioner-w-cztery-miesiace,66022.html" target="_blank" rel="noopener noreferrer">Menedżerem Zdrowia</a>;
          rekord ~3 mln zł —
          <a href="https://www.rp.pl/zdrowie/art44641281-trzy-miliony-zlotych-w-rok-rekordowe-zarobki-32-letniego-ortopedy" target="_blank" rel="noopener noreferrer">Rzeczpospolita</a>.
        </p>
      </div>

      <p class="source-note">
        Źródła: płaca minimalna —
        <a href="https://isap.sejm.gov.pl/isap.nsf/DocDetails.xsp?id=WDU20250001242" target="_blank" rel="noopener noreferrer">Rozp. Rady Ministrów z 11.09.2025 (Dz.U. 2025 poz. 1242)</a>;
        mediana krajowa (XII 2025) —
        <a href="https://stat.gov.pl/obszary-tematyczne/rynek-pracy/pracujacy-zatrudnieni-wynagrodzenia-koszty-pracy/rozklad-wynagrodzen-w-gospodarce-narodowej-w-listopadzie-2025-r-,32,23.html" target="_blank" rel="noopener noreferrer">GUS, rozkład wynagrodzeń</a>;
        mediana lekarza (w jednej placówce, 22–25 tys.) — dane
        <a href="https://www.gazetaprawna.pl/biznes/zdrowie/artykuly/11149864,pensje-lekarzy-i-pielegniarek-w-polsce-2025-ile-zarabiaja-etatowcy-i.html" target="_blank" rel="noopener noreferrer">AOTMiT / Gazeta Prawna</a>.
      </p>
    </div>
  </section>

  <!-- NIEPRZEJRZYSTOŚĆ: NIE DA SIĘ POLICZYĆ -->
  <section class="section section-alt">
    <div class="container">
      <div class="opacity-block">
        <p class="opacity-q">Ile łącznie z budżetu NFZ trafia do jednego lekarza?</p>
        <p class="opacity-a">
          Nie wiadomo — i <strong>nie da się tego policzyć</strong>. Nie istnieje
          rejestr, który sumuje wynagrodzenia jednego lekarza ze wszystkich umów,
          zleceń i kontraktów ze środków publicznych. To nie luka techniczna — to
          <strong>sedno problemu</strong>.
        </p>
        <a class="btn btn-primary" href="/postulat">Dlatego żądamy jawnego rejestru →</a>
      </div>
    </div>
  </section>

  <!-- KOLEJKI vs ZAROBKI -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Druga strona</p>
      <h2>Ty czekasz, oni zarabiają</h2>
      <p class="lead">
        Na wizytę u specjalisty NFZ czeka się średnio <strong>4,2 miesiąca</strong>
        (Barometr WHC, 2025). U tego samego lekarza prywatnie — zwykle kilka dni.
        Różnicę napędza praca w wielu miejscach naraz.
      </p>

      <div class="queues">
        <div class="q-row">
          <div class="q-meta"><span class="q-name">Neurochirurg</span><span class="q-nfz">13,1 mies. NFZ</span></div>
          <div class="q-bar"><div class="q-fill" style="width:100%"></div></div>
        </div>
        <div class="q-row">
          <div class="q-meta"><span class="q-name">Endokrynolog</span><span class="q-nfz">~12,9 mies. NFZ</span></div>
          <div class="q-bar"><div class="q-fill" style="width:98%"></div></div>
        </div>
        <div class="q-row">
          <div class="q-meta"><span class="q-name">Kardiolog</span><span class="q-nfz">kilka–kilkanaście mies. · prywatnie 7–21 dni</span></div>
          <div class="q-bar"><div class="q-fill" style="width:53%"></div></div>
        </div>
        <div class="q-row">
          <div class="q-meta"><span class="q-name">Ortopeda</span><span class="q-nfz">~5 mies. NFZ · prywatnie 5–14 dni</span></div>
          <div class="q-bar"><div class="q-fill" style="width:38%"></div></div>
        </div>
      </div>

      <p class="salary-insight">
        Lekarz rozlicza ok. <strong>24 000 zł/mc</strong>, a Ty czekasz
        <strong>miesiącami</strong>. Prywatnie, za dopłatą, ten sam specjalista przyjmie
        Cię w kilka dni.
      </p>

      <p class="source-note">
        Źródła:
        <a href="https://www.rynekzdrowia.pl/Polityka-zdrowotna/Barometr-Watch-Health-Care-sredni-czas-oczekiwania-na-leczenie-w-2025-r-to-ponad-4-miesiace,279890,14.html" target="_blank" rel="noopener noreferrer">Barometr WHC 2025 (Rynek Zdrowia)</a>;
        czasy wg specjalności —
        <a href="https://www.gazetaprawna.pl/biznes/zdrowie/artykuly/11155472,kolejkidolekarzynfz2025.html" target="_blank" rel="noopener noreferrer">dane NFZ (Gazeta Prawna)</a>;
        terminy —
        <a href="https://terminyleczenia.nfz.gov.pl/" target="_blank" rel="noopener noreferrer">Informator NFZ</a>.
      </p>
    </div>
  </section>

  <!-- SPOTLIGHT: REGLAMENTACJA DOSTĘPU DO ZAWODU -->
  <section class="section section-alt">
    <div class="container">
      <div class="spotlight">
        <p class="eyebrow">Mechanizm: reglamentacja dostępu</p>
        <h2>Dlaczego lekarzy jest mało — i komu to służy</h2>
        <p>
          Polska ma ok. 3,4–3,9 lekarza na 1000 mieszkańców — poniżej średniej UE
          (ok. 4,3) — a 5,2% osób rezygnuje z potrzebnej pomocy. Wejście do zawodu jest
          reglamentowane: limit przyjęć na studia i miejsc specjalizacyjnych ustala
          ministerstwo, a samorząd lekarski protestuje przeciw nowym kierunkom i
          uproszczonym ścieżkom dla lekarzy spoza UE.
        </p>
        <p>
          Krytycy nazywają to <strong>logiką korporacyjną</strong>: im mniej nowych
          lekarzy, tym silniejsza — także płacowo — pozycja tych już w zawodzie. Mniej
          konkurencji to wyższe stawki i dłuższe kolejki dla pacjenta.
        </p>
        <a class="btn btn-primary" href="/mechanizmy#dostep">Jak to działa →</a>
      </div>
    </div>
  </section>

  <!-- NAJNOWSZE ARTYKUŁY -->
  <section class="section">
    <div class="container">
      <header class="section-head row">
        <h2>Najnowsze artykuły</h2>
        <a href="/artykuly" class="muted">Cała baza artykułów →</a>
      </header>
      <div class="article-list">
        {latest.map((a) => <ArticleCard article={a} />)}
      </div>
    </div>
  </section>

  <!-- SONDA -->
  <Sonda />

  <!-- PASMO CTA -->
  <section class="cta-band">
    <div class="container cta-band-inner">
      <div>
        <h2>Postuluj jawny rejestr wynagrodzeń lekarzy</h2>
        <p>
          Środki publiczne powinny być jawne — tak jak wynagrodzenia w
          administracji publicznej.
        </p>
      </div>
      <a class="btn btn-on-brand" href="/postulat">Poznaj postulat</a>
    </div>
  </section>

  <!-- UDOSTĘPNIJ -->
  <section class="section">
    <div class="container">
      <ShareRow heading="Pomóż nagłośnić sprawę:" />
    </div>
  </section>
</BaseLayout>

<style>
  .salary { display: flex; flex-direction: column; gap: 1.4rem; margin: 1.75rem 0 1.25rem; }
  .bar-head { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; margin-bottom: 0.4rem; }
  .bar-name { font-size: 0.95rem; font-weight: 500; color: var(--ink); }
  .bar-val { font-family: var(--font-mono); font-size: 1.05rem; font-weight: 500; color: var(--ink); white-space: nowrap; }
  .bar-track { display: flex; align-items: center; height: 30px; background: var(--paper-2); border-radius: var(--radius); }
  .bar-fill { height: 100%; border-radius: var(--radius); min-width: 4px; }
  .is-min { background: var(--ink-faint); }
  .is-med { background: var(--ink-soft); }
  .is-doc { background: var(--brand); }
  .bar-flag { margin-left: 0.6rem; white-space: nowrap; font-weight: 600; font-size: 0.9rem; color: var(--alert); }
  .salary-insight { font-size: 1.05rem; color: var(--ink); margin: 0.5rem 0 1.25rem; }
  .salary-insight strong { color: var(--alert); }
  .is-patol { background: var(--alert); display: flex; align-items: center; justify-content: flex-end; }
  .patol-label { color: #fff; font-size: 0.8rem; font-weight: 500; padding-right: 12px; white-space: nowrap; }
  .patol-note { background: var(--alert-50); border-left: 4px solid var(--alert); border-radius: 0 var(--radius) var(--radius) 0; padding: 1rem 1.25rem; margin: 0.5rem 0 1.25rem; }
  .patol-note p { margin: 0; }
  .queues { display: flex; flex-direction: column; gap: 1.1rem; margin: 1.5rem 0 1.25rem; }
  .q-row { display: block; }
  .q-meta { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; margin-bottom: 0.35rem; }
  .q-name { font-size: 0.95rem; font-weight: 500; }
  .q-bar { background: var(--paper-2); border-radius: var(--radius); height: 24px; width: 100%; }
  .q-fill { background: var(--ink-soft); height: 100%; border-radius: var(--radius); min-width: 4px; }
  .q-nfz { font-size: 0.85rem; color: var(--ink-soft); text-align: right; }
  @media (max-width: 600px) {
    .q-meta { flex-direction: column; gap: 0.15rem; align-items: flex-start; }
    .q-nfz { text-align: left; }
  }
  .spotlight { background: var(--bg); border: 1px solid var(--line); border-left: 5px solid var(--brand); border-radius: 0 var(--radius-lg) var(--radius-lg) 0; padding: 1.75rem 2rem; }
  .spotlight h2 { margin-top: 0.3rem; }
  .spotlight p { color: var(--ink-soft); margin-bottom: 1rem; }
  .spotlight .btn { margin-top: 0.25rem; }
  .opacity-block { max-width: 760px; }
  .opacity-q { font-family: var(--font-serif); font-size: clamp(1.4rem, 3vw, 1.9rem); font-weight: 600; color: var(--ink); line-height: 1.25; margin: 0 0 0.75rem; }
  .opacity-a { font-size: 1.1rem; line-height: 1.65; color: var(--ink-soft); margin: 0 0 1.25rem; }
  .opacity-a strong { color: var(--ink); }
  @media (max-width: 600px) {
    .bar-val, .bar-flag { font-size: 0.85rem; }
  }
</style>
