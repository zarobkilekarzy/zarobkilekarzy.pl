---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShareRow from '../components/ShareRow.astro';
import DisclaimerZarobki from '../components/DisclaimerZarobki.astro';

const stats = [
  { n: '308 tys.', u: 'zł / dzień', cap: 'Rekordowy dzień neurochirurga — więcej niż dniówka Messiego.', href: '/dane/rekordy', hot: true },
  { n: '316 079', u: 'zł / mc', cap: 'Najwyższy kontrakt — w regionie, którego szpitale mają 1,4 mld zł długu.', href: '/dane/rekordy', hot: true },
  { n: '0', u: 'rejestrów', cap: 'Publicznych rejestrów sumujących wypłaty jednego lekarza. To sedno problemu.', href: '/postulat', core: true },
  { n: '~75%', u: 'na kontrakcie', cap: 'Lekarzy rozlicza się na B2B — a kwot tych kontraktów nikt nie publikuje.', href: '/dane/rozklad-wynagrodzen' },
  { n: '4,2', u: 'miesiąca', cap: 'Kolejka do specjalisty — mimo budżetu NFZ realnie ×2 od 2015 r.', href: '/dane/kolejki' },
  { n: '34', u: 'mld zł', cap: 'Dług szpitali — idzie głównie na pensje wypłacane „na kredyt”.', href: '/dane/zadluzenie-szpitali' },
  { n: '7', u: 'miejsc', cap: 'Rezydenckich na chirurgię plastyczną — w całym kraju, przy 7 chętnych na miejsce.', href: '/dane/wedlug-specjalizacji' },
  { n: '625', u: 'specjalistów', cap: 'Ma kontrakt ponad 100 tys. zł/mc — i to licząc tylko jedną placówkę. Po zsumowaniu byłoby ich kilka razy więcej.', href: '/dane/rozklad-wynagrodzen' },
];

const podstrony = [
  { href: '/dane/rozklad-wynagrodzen', t: 'Rozkład wynagrodzeń', d: 'Od pensji rezydenta po górny 1% — cała rozpiętość, per forma zatrudnienia.' },
  { href: '/dane/wedlug-specjalizacji', t: 'Według specjalizacji', d: 'Pensja rezydenta, stawka rynkowa, miejsca i konkurencja — dla 15 dziedzin.' },
  { href: '/dane/pensje-rezydentow', t: 'Pensje rezydentów', d: 'Jedyna dokładna liczba „zł per specjalizacja”. Paradoks priorytetów.' },
  { href: '/dane/rekordy', t: 'Rekordowe rozliczenia', d: 'Od 316 tys. zł/mc po miliony rocznie. Bez nazwisk — mechanizm, nie osoba.' },
  { href: '/dane/stawki', t: 'Stawki godzinowe', d: 'Minimum ustawowe kontra rynek. Oferta to nie to samo co wypłata.' },
  { href: '/dane/budzet-nfz', t: 'Budżet NFZ', d: 'Budżet rośnie, ale wzrost pochłaniają ustawowe płace, nie nowe świadczenia.' },
  { href: '/dane/zadluzenie-szpitali', t: 'Zadłużenie szpitali', d: 'Dług 34 mld zł idzie głównie na wynagrodzenia — pensje na kredyt, który spłacamy.' },
  { href: '/dane/kolejki', t: 'Pieniądze a kolejka', d: 'Infografika + dłuższa perspektywa: budżet, składka, dopłaty i inflacja rosną — kolejka też.' },
  { href: '/dane/polska-na-tle-ue', t: 'Polska na tle UE', d: 'Liczba lekarzy ≈ średnia OECD. Ile kosztowałyby niemieckie stawki?' },
];
---

<BaseLayout
  title="Dane — zarobkilekarzy.pl"
  description="Dane o wydatkach publicznych, wynagrodzeniach i dostępności świadczeń — każda liczba z podaniem źródła."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Liczby</p>
      <h1>Dane</h1>
      <p class="lead">
        Zestawiamy wydatki publiczne, wynagrodzenia i dostępność świadczeń dla pacjenta.
        Zasada jest jedna: <strong>żadnej liczby bez źródła</strong>. Każdą oznaczamy jako
        <em>dokładną</em> albo <em>szacunek</em> i nie mieszamy tych kategorii.
      </p>
      <p class="updated">Ostatnia aktualizacja: <strong>6 lipca 2026</strong> · dane AOTMiT (02.2026), CMKP (jesień 2025), rozporządzenie MZ (od 1 VII 2026).</p>

      <DisclaimerZarobki />

      <p class="eyebrow" style="margin-top: 0.5rem">Na start</p>
      <h2 style="margin-top: 0.1rem">Osiem liczb, które pokazują skalę</h2>
      <p class="muted" style="max-width: 62ch; margin: 0.35rem 0 0.25rem">
        Najmocniejsze dane z całego serwisu w jednym miejscu. Kliknij dowolną, by wejść
        głębiej — z pełnym rozbiciem i źródłami.
      </p>
      <div class="stats-grid">
        {stats.map((s) => (
          <a class={`dstat${s.hot ? ' is-hot' : ''}${s.core ? ' is-core' : ''}`} href={s.href}>
            <span class="dstat-num">{s.n}<span class="dstat-unit">{s.u}</span></span>
            <span class="dstat-cap">{s.cap}</span>
            <span class="dstat-go" aria-hidden="true">→</span>
          </a>
        ))}
      </div>

      <div class="stat-callout">
        <span class="stat-callout-num">do 106%</span>
        <div class="stat-callout-body">
          <p class="stat-callout-quote">„W niektórych szpitalach na wynagrodzenia przeznaczone jest nawet 106 proc. budżetu, co jest skrajnie trudną sytuacją dla podmiotu.”</p>
          <p class="stat-callout-note">Chodzi o <strong>całkowite budżety szpitali</strong> — w skrajnych przypadkach same wynagrodzenia przekraczają 100% wszystkich środków, jakimi dysponuje placówka.</p>
          <p class="stat-callout-src">— Ministra Zdrowia, maj 2026 · <a href="https://www.rynekzdrowia.pl/Polityka-zdrowotna/Ministra-zdrowia-w-niektorych-szpitalach-pensje-pochlaniaja-106-proc-budzetu-Resort-chce-limitu,284133,14.html" target="_blank" rel="noopener noreferrer">Rynek Zdrowia</a></p>
        </div>
      </div>

      <h2 style="margin-top: 2.5rem">Przeglądaj wszystkie dane</h2>
      <div class="hub-grid">
        {podstrony.map((p) => (
          <a class="hub-card" href={p.href}>
            <span class="hub-t">{p.t}</span>
            <span class="hub-d">{p.d}</span>
            <span class="hub-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>

      <p class="source-note" style="margin-top: 2rem">
        Nie publikujemy liczb „z pamięci”. Dopóki pole nie ma źródła, pozostaje oznaczone jako „—”.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <ShareRow heading="Pomóż nagłośnić sprawę:" />
    </div>
  </section>
</BaseLayout>

<style>
  .updated { font-size: 0.82rem; color: var(--ink-faint); margin: -0.25rem 0 1.25rem; }
  .stats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1rem; margin: 1rem 0 2rem; }
  .dstat { position: relative; display: flex; flex-direction: column; gap: 0.55rem; background: var(--bg); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: 1.3rem 1.35rem 2.5rem; text-decoration: none; transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s; }
  .dstat:hover { border-color: var(--brand); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(15,76,129,0.1); }
  .dstat.is-hot { border-left: 5px solid var(--alert); }
  .dstat.is-core { border-left: 5px solid var(--brand); }
  .dstat-num { font-family: var(--font-mono); font-size: clamp(1.9rem, 5.5vw, 2.6rem); font-weight: 700; color: var(--brand); line-height: 1; }
  .dstat.is-hot .dstat-num { color: var(--alert); }
  .dstat-unit { display: block; font-family: var(--font-sans); font-size: 0.8rem; font-weight: 500; color: var(--ink-faint); margin-top: 0.3rem; }
  .dstat-cap { font-size: 0.9rem; color: var(--ink-soft); line-height: 1.5; }
  .dstat-go { position: absolute; left: 1.35rem; bottom: 1rem; color: var(--brand); font-weight: 700; }
  .stat-callout { display: flex; gap: 1.25rem; align-items: center; background: var(--alert-50); border-left: 5px solid var(--alert); border-radius: 0 var(--radius-lg) var(--radius-lg) 0; padding: 1.5rem 1.75rem; margin: 1.5rem 0 2rem; }
  .stat-callout-num { font-family: var(--font-mono); font-size: clamp(2.4rem, 7vw, 3.4rem); font-weight: 500; color: var(--alert); line-height: 1; flex-shrink: 0; }
  .stat-callout-quote { font-family: var(--font-serif); font-size: 1.1rem; line-height: 1.5; color: var(--ink); margin: 0 0 0.5rem; }
  .stat-callout-note { font-size: 0.92rem; color: var(--ink-soft); margin: 0 0 0.5rem; }
  .stat-callout-src { font-size: 0.85rem; color: var(--ink-soft); margin: 0; }
  @media (max-width: 600px) { .stat-callout { flex-direction: column; align-items: flex-start; gap: 0.6rem; } }
  .hub-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; margin: 1.25rem 0; }
  .hub-card { position: relative; display: flex; flex-direction: column; gap: 0.35rem; background: var(--bg); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: 1.1rem 1.25rem; text-decoration: none; transition: border-color 0.15s, transform 0.15s; }
  .hub-card:hover { border-color: var(--brand); transform: translateY(-2px); }
  .hub-t { font-weight: 600; color: var(--ink); font-size: 1.02rem; }
  .hub-d { font-size: 0.88rem; color: var(--ink-soft); line-height: 1.45; }
  .hub-arrow { color: var(--brand); font-weight: 700; margin-top: 0.15rem; }
</style>
