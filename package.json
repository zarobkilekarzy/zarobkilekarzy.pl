{
  "name": "zarobkilekarzy",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Obywatelska inicjatywa na rzecz jawności wynagrodzeń w ochronie zdrowia.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "og": "node scripts/generate-og.mjs",
    "petycja:pdf": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/generate-petycja-pdf.mjs",
    "preview:cf": "astro build && npx wrangler pages dev dist --kv SONDA_KV --binding BASIC_AUTH_ENABLED=false",
    "deploy": "astro build && npx wrangler pages deploy dist --project-name=zarobkilekarzy",
    "deploy:ci": "node scripts/dispatch-deploy.mjs",
    "push:bot": "node scripts/push-as-bot.mjs"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/ibm-plex-mono": "^5.0.0",
    "@fontsource/ibm-plex-sans": "^5.0.0",
    "@fontsource/ibm-plex-serif": "^5.0.0",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^6.4.8",
    "jspdf": "^4.2.1",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2"
  },
  "devDependencies": {
    "pdfkit": "^0.19.1",
    "sharp": "^0.35.1"
  }
}
