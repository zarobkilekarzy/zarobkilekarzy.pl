<script>
  // Interaktywna oś czasu: filtry po statusie (wielokrotny wybór) + „rozwiń widoczne".
  // Progresywne wzbogacenie — bez JS wszystkie wpisy są widoczne i rozwijalne natywnie.
  document.querySelectorAll('[data-mrz-tl]').forEach((tl) => {
    const btns = Array.from(tl.querySelectorAll('.mrz-fbtn'));
    const items = Array.from(tl.querySelectorAll('.mrz-item'));
    const empty = tl.querySelector('.mrz-empty');
    const count = tl.querySelector('.mrz-count');
    const expand = tl.querySelector('[data-expand]');
    const total = items.length;
    const active = new Set();

    const sync = () => {
      let shown = 0;
      items.forEach((it) => {
        const on = active.size === 0 || active.has(it.dataset.status);
        it.hidden = !on;
        if (on) shown += 1;
      });
      btns.forEach((b) => {
        const f = b.dataset.filter;
        const on = f === 'all' ? active.size === 0 : active.has(f);
        b.classList.toggle('is-on', on);
        b.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
      if (empty) empty.hidden = shown > 0;
      if (count) count.textContent = shown === total ? '' : `Pokazano ${shown} z ${total}`;
    };

    btns.forEach((b) =>
      b.addEventListener('click', () => {
        const f = b.dataset.filter;
        if (f === 'all') active.clear();
        else if (active.has(f)) active.delete(f);
        else active.add(f);
        sync();
      }),
    );

    if (expand) {
      expand.addEventListener('click', () => {
        const vis = items.filter((it) => !it.hidden);
        const anyClosed = vis.some((it) => !it.querySelector('details').open);
        vis.forEach((it) => {
          it.querySelector('details').open = anyClosed;
        });
        expand.textContent = anyClosed ? 'Zwiń widoczne' : 'Rozwiń widoczne';
        expand.setAttribute('aria-expanded', anyClosed ? 'true' : 'false');
      });
    }

    sync();
  });
</script>

