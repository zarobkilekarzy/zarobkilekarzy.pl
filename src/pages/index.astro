  .btn-ghost:hover { background: rgba(255,255,255,0.10); border-color: #fff; color: #fff; }

  .mh-anchor { text-align: left; }
  .mh-big { font-family: var(--font-mono); font-weight: 500; line-height: 0.9; margin: 0; color: #fff; letter-spacing: -0.03em; white-space: nowrap; font-size: clamp(4rem, 12vw, 8.5rem); }
  .mh-big-label { font-size: 0.98rem; line-height: 1.5; color: rgba(255,255,255,0.78); margin: 0.5rem 0 1rem; max-width: 34ch; }
  .pill-teal { background: var(--teal-50); color: var(--teal); }

  /* ===== TRZY KAFLE = NAWIGACJA (nachodzą na hero) ================== */
  .trio-wrap { position: relative; z-index: 2; margin-top: -5.25rem; padding-bottom: 1.5rem; }
  .trio { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.1rem; }
  .tcard {
    position: relative; display: flex; flex-direction: column; gap: 0.4rem; text-align: left;
    font: inherit; cursor: pointer;
    background: var(--surface); border: 1px solid var(--line); border-top: 4px solid var(--line-2);
    border-radius: var(--radius-lg); padding: 1.4rem 1.5rem 1.5rem;
    box-shadow: 0 12px 32px rgba(10,17,25,0.16);
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease, opacity 0.15s ease;
  }
  .tcard:hover { transform: translateY(-2px); }
  /* Aktywny kafel: podniesiony; górny akcent rysuje pasek postępu (.tc-prog),
     a border-top zostaje neutralnym „torem" pod nim. Nieaktywne przygaszone. */
  .tcard[aria-current="true"] { transform: translateY(-4px); box-shadow: 0 18px 40px rgba(10,17,25,0.24); }
  .tcard[aria-current="false"] { opacity: 0.9; }

  /* Pasek postępu autoprzewijania — leży dokładnie na górnej krawędzi (4px
     border-top + 1px boki) aktywnego kafla. W czasie autoodliczania skrypt
     (Web Animations API) wypełnia go 0→100% w akcencie kafla; koniec = zmiana
     slajdu. Gdy autoplay nieaktywny (pauza/reduced-motion/ręczny wybór), WAAPI
     nie działa i CSS pokazuje pasek pełny — statyczny wskaźnik aktywnego kafla. */
  .tc-prog {
    position: absolute; top: -4px; left: -1px; right: -1px; height: 4px;
