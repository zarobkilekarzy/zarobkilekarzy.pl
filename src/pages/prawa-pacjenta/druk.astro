---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { lastmodFor } from '../../lib/pageDates.mjs';

// Kieszonkowy wyciąg z praw pacjenta — dwie karty A6 (przód/tył) do wydruku.
// Zasada doboru treści: NA KARCIE TYLKO TEZY PEWNE. Nie ma tu miejsca na
// zastrzeżenia i niuanse, a wyrwane z kontekstu półprawdy szkodzą bardziej niż
// pomagają — dlatego świadomie pominięto:
//   • przedawnienie roszczeń sądowych (art. 442¹ k.c.) — samo w sobie ustalone
//     (przy szkodzie na osobie limit 10 lat nie działa, SN III CZP 2/09), ale bez
//     tego wyjaśnienia „3 lata" na karcie czytałoby się jako pułapkę, a z nim
//     zjadłoby pół strony — zostaje w pełnej wersji;
//   • numer TIP z zagranicy — strona RPP (22 688 05 00) i strona NFZ (22 125 66 00)
//     podają dla tej samej infolinii różne numery;
//   • CBA — kanał aktualny, ale trwa spór o likwidację urzędu (weto z 05.2026).
// Każda pozycja poniżej ma artykuł ustawy zweryfikowany w tekście jednolitym
// (Dz.U. 2024 poz. 581). Pełna wersja z linkami: /prawa-pacjenta/.
const data = lastmodFor('/prawa-pacjenta');
const czytelna = new Intl.DateTimeFormat('pl-PL', { month: '2-digit', year: 'numeric' })
  .format(new Date(`${data}T12:00:00`));

const prawa = [
  ['Przystępnej informacji', 'o stanie zdrowia, rozpoznaniu, metodach leczenia i rokowaniu. Od 16 lat — samodzielnie.', 'art. 9'],
  ['Zgody i odmowy', 'po uzyskaniu informacji. Operacja lub podwyższone ryzyko — zgoda na piśmie.', 'art. 16–18'],
  ['Drugiej opinii', 'lub konsylium. Lekarz może odmówić, ale musi wpisać odmowę do dokumentacji.', 'art. 6 ust. 3–5'],
  ['Leczenia bólu', '— placówka ma obowiązek zmierzyć ból, leczyć go i sprawdzać skuteczność.', 'art. 20a'],
  ['Obecności osoby bliskiej', 'przy badaniu. Odmowa tylko z powodu zagrożenia epidemicznego lub bezpieczeństwa.', 'art. 21'],
  ['Natychmiastowej pomocy', 'przy zagrożeniu zdrowia lub życia — niezależnie od kolejki.', 'art. 7'],
  ['Tajemnicy', 'o Twoim stanie zdrowia — także po śmierci. To Ty wskazujesz, kogo upoważniasz.', 'art. 13–14'],
  ['Intymności i godności', 'w czasie udzielania świadczeń.', 'art. 20'],
];

const bezplatne = [
  ['Pierwsza kopia dokumentacji medycznej', 'w żądanym zakresie — placówka nie pobiera opłaty.', 'art. 28 ust. 2a pkt 1'],
  ['Pobyt rodzica lub opiekuna przy dziecku', 'albo przy osobie ze znacznym stopniem niepełnosprawności.', 'art. 35 ust. 4'],
  ['Wniosek do Rzecznika Praw Pacjenta', '— „wolny od opłat”.', 'art. 50 ust. 2'],
];

const terminy = [
  ['30 dni', 'na sprzeciw wobec orzeczenia lekarza — przez RPP, z podaniem przepisu. Odwołania nie ma.', 'art. 31'],
  ['rok / max 3 lata', 'na wniosek o świadczenie kompensacyjne za szkodę w szpitalu (zdarzenia od 6.09.2023). Wniosek 348 zł.', 'FKZM'],
  ['20 lat', 'tyle placówka przechowuje dokumentację (30 lat, gdy zgon z uszkodzenia ciała lub zatrucia).', 'art. 29'],
];

const gdzie = [
  ['Naruszono Twoje prawo pacjenta', 'Rzecznik Praw Pacjenta', '800 190 590 · kancelaria@rpp.gov.pl'],
  ['Kazano zapłacić za świadczenie z NFZ, odmówiono zapisu', 'Oddział wojewódzki NFZ', 'skargi-i-wnioski.nfz.gov.pl · 30 dni'],
  ['Widzisz wizytę, której nie było', 'Internetowe Konto Pacjenta', 'pacjent.gov.pl → Historia leczenia'],
];
---

<BaseLayout
  title="Prawa pacjenta — wersja do druku (karta kieszonkowa) — zarobkilekarzy.pl"
  description="Kieszonkowy wyciąg z praw pacjenta do wydruku: dwie karty A6 z najważniejszymi prawami, terminami i numerami. Każda pozycja z artykułem ustawy."
  noindex={true}
>
  <section class="section no-print">
    <div class="container" style="max-width: 760px">
      <p class="eyebrow"><a href="/prawa-pacjenta/">Prawa pacjenta</a> · Wersja do druku</p>
      <h1>Karta kieszonkowa do wydruku</h1>
      <p class="lead">
        Wyciąg z <a href="/prawa-pacjenta/">pełnej wersji</a>: dwie karty <strong>A6</strong>
        (105 × 148 mm) — przód i tył. Do portfela, do teczki z dokumentacją, do powieszenia
        na korytarzu w przychodni. Do wykorzystania bez pytania o zgodę.
      </p>

      <div class="callout">
        <p>
          <strong>Jak wydrukować.</strong> Naciśnij <strong>Drukuj</strong> poniżej (albo Ctrl/Cmd + P).
          W oknie drukowania wybierz <strong>druk dwustronny</strong> — wyjdą dwie strony, które razem
          tworzą jedną kartę. Format ustawiony jest na <strong>A6</strong>. Jeśli Twoja drukarka nie
          ma A6, wybierz <strong>A4</strong> i opcję <strong>„dopasuj do strony”</strong>, a potem
          przytnij — albo <strong>„2 strony na arkuszu”</strong>, żeby przód i tył wyszły obok siebie.
          Marginesy ustaw na <strong>„brak”/„minimalne”</strong>. Karta jest czarno-biała, więc
          drukarka atramentowa nie zużyje kolorowego tuszu.
        </p>
      </div>

      <div class="cta-row">
        <button type="button" class="btn btn-primary" id="drukuj">Drukuj kartę →</button>
        <a class="btn" href="/prawa-pacjenta/">Wróć do pełnej wersji</a>
      </div>

      <p class="source-note" style="margin-top: 1.25rem">
        Na karcie są <strong>wyłącznie tezy pewne</strong>, każda z artykułem ustawy z 6 listopada
        2008 r. o prawach pacjenta i Rzeczniku Praw Pacjenta (tekst jednolity Dz.U. 2024 poz. 581).
        Świadomie pominęliśmy to, czego nie da się uczciwie zmieścić w jednym zdaniu:
        <strong>przedawnienie roszczeń sądowych</strong> (samo „3 lata” bez wyjaśnienia, że przy
        szkodzie na osobie termin biegnie dopiero od <em>dowiedzenia się</em> o szkodzie, brzmiałoby
        jak pułapka) oraz <strong>numer infolinii dla dzwoniących z zagranicy</strong>, który
        w oficjalnych źródłach RPP i NFZ jest podany rozbieżnie. Obie sprawy omawiamy
        w <a href="/prawa-pacjenta/">pełnej wersji</a>.
      </p>

      <p class="podglad-note">Podgląd karty — tak wyjdzie na papierze:</p>
    </div>
  </section>

  <div class="arkusz">
    {/* ——— PRZÓD ——— */}
    <article class="karta">
      <header class="k-head">
        <p class="k-tytul">Prawa pacjenta</p>
        <p class="k-podtytul">Wyciąg kieszonkowy · {czytelna}</p>
      </header>

      <div class="k-tel">
        <p class="k-tel-n">800 190 590</p>
        <p class="k-tel-d">
          Telefoniczna Informacja Pacjenta — <strong>bezpłatna, całodobowo, 7 dni w tygodniu</strong>.
          Wspólny numer Rzecznika Praw Pacjenta i NFZ.
        </p>
      </div>

      <p class="k-sekcja">Masz prawo do</p>
      <ul class="k-lista">
        {prawa.map(([t, o, a]) => (
          <li><strong>{t}</strong> {o} <span class="k-art">{a}</span></li>
        ))}
      </ul>

      <p class="k-stopka">Pełna wersja, źródła i kanały zgłoszeń: <strong>zarobkilekarzy.pl/prawa-pacjenta</strong></p>
    </article>

    {/* ——— TYŁ ——— */}
    <article class="karta">
      <p class="k-sekcja k-sekcja-1">To jest bezpłatne — choć rzadko ktoś o tym mówi</p>
      <ul class="k-lista">
        {bezplatne.map(([t, o, a]) => (
          <li><strong>{t}</strong> {o} <span class="k-art">{a}</span></li>
        ))}
      </ul>

      <p class="k-sekcja">Pilnuj terminów</p>
      <ul class="k-lista">
        {terminy.map(([t, o, a]) => (
          <li><strong class="k-termin">{t}</strong> {o} <span class="k-art">{a}</span></li>
        ))}
      </ul>
      <p class="k-uwaga">
        <strong>Uwaga:</strong> przyjęcie świadczenia kompensacyjnego oznacza
        <strong> zrzeczenie się roszczeń sądowych</strong> z tego zdarzenia. To ścieżka
        zamiast sądu, nie obok niego.
      </p>

      <p class="k-sekcja">Gdzie zgłosić</p>
      <dl class="k-gdzie">
        {gdzie.map(([kiedy, kto, jak]) => (
          <>
            <dt>{kiedy}</dt>
            <dd><strong>{kto}</strong><br />{jak}</dd>
          </>
        ))}
      </dl>

      <p class="k-stopka">
        Podstawa: ustawa o prawach pacjenta (Dz.U. 2024 poz. 581). To nie jest porada prawna.
        <strong> zarobkilekarzy.pl/prawa-pacjenta</strong>
      </p>
    </article>
  </div>
</BaseLayout>

<script>
  document.getElementById('drukuj')?.addEventListener('click', () => window.print());
</script>

<style>
  .podglad-note { font-size: 0.85rem; color: var(--ink-faint); margin: 2rem 0 0; }

  /* Arkusz: na ekranie dwie karty obok siebie, na papierze — dwie osobne strony. */
  .arkusz {
    display: flex; flex-wrap: wrap; gap: 1.5rem; justify-content: center;
    padding: 1.5rem 1rem 3rem;
  }

  /* Karta w rzeczywistym rozmiarze A6. Milimetry, nie rem — to ma trafić na papier
     1:1, a nie skalować się z ustawieniami przeglądarki. */
  .karta {
    width: 105mm; height: 148mm;
    box-sizing: border-box;
    padding: 7mm 7mm 5mm;
    background: #fff;
    color: #000;
    /* 8,2 pt to świadomy kompromis: karta trafia do rąk ludzi w poczekalni, często
       starszych — zapas miejsca lepiej wydać na czytelność niż na dodatkowe treści. */
    font-size: 8.2pt;
    line-height: 1.34;
    display: flex; flex-direction: column;
    /* Na ekranie: cień i ramka pokazują krawędź papieru. W druku znikają. */
    border: 1px solid var(--line);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  }

  .k-head { border-bottom: 1.2pt solid #000; padding-bottom: 1.5mm; margin-bottom: 3mm; }
  .k-tytul { font-family: var(--font-serif, Georgia, serif); font-size: 16pt; font-weight: 600; margin: 0; letter-spacing: -0.01em; }
  .k-podtytul { font-size: 6.9pt; margin: 0.6mm 0 0; text-transform: uppercase; letter-spacing: 0.08em; color: #444; }

  /* Numer alarmowy — ramka zamiast wypełnienia: czytelne i tanie w druku. */
  .k-tel { border: 1.2pt solid #000; padding: 2mm 2.5mm; margin-bottom: 3mm; text-align: center; }
  .k-tel-n { font-family: var(--font-mono, monospace); font-size: 20pt; font-weight: 700; margin: 0; letter-spacing: 0.02em; line-height: 1; }
  .k-tel-d { font-size: 6.8pt; margin: 1.2mm 0 0; line-height: 1.3; }

  .k-sekcja {
    font-size: 7.1pt; font-weight: 700; text-transform: uppercase; letter-spacing: 0.09em;
    margin: 0 0 1.5mm; padding-bottom: 0.8mm; border-bottom: 0.5pt solid #999;
  }
  .k-sekcja-1 { margin-top: 0; }
  .k-sekcja:not(.k-sekcja-1) { margin-top: 3mm; }

  .k-lista { list-style: none; margin: 0; padding: 0; }
  .k-lista li { margin: 0 0 1.4mm; padding-left: 2.6mm; position: relative; }
  .k-lista li::before { content: "▪"; position: absolute; left: 0; top: -0.2mm; font-size: 5pt; }
  .k-art { color: #555; white-space: nowrap; font-size: 6.7pt; }
  .k-termin { font-family: var(--font-mono, monospace); }

  .k-uwaga { border-left: 1.5pt solid #000; padding: 1mm 0 1mm 2mm; margin: 2mm 0 0; font-size: 7.1pt; line-height: 1.3; }

  .k-gdzie { margin: 0; display: grid; grid-template-columns: 1fr; gap: 1.3mm; }
  .k-gdzie dt { font-size: 6.9pt; color: #444; font-style: italic; }
  .k-gdzie dd { margin: 0.3mm 0 0; }

  /* Stopka dosunięta do dołu karty — `auto` zjada nadmiar miejsca zamiast zostawiać
     dziurę w środku. */
  .k-stopka {
    margin: auto 0 0; padding-top: 1.8mm; border-top: 0.5pt solid #999;
    font-size: 6.4pt; color: #333; line-height: 1.3;
  }

  @media print {
    /* Rozmiar strony = rozmiar karty. Bez marginesu drukarki, bo karta ma własny. */
    @page { size: 105mm 148mm; margin: 0; }
    .no-print { display: none !important; }
    .arkusz { display: block; padding: 0; gap: 0; }
    .karta {
      border: 0; box-shadow: none;
      width: 105mm; height: 148mm;
      page-break-after: always; break-after: page;
    }
    .karta:last-child { page-break-after: auto; break-after: auto; }
    /* Nagłówek i stopka serwisu nie mają czego szukać na papierze. */
    :global(.site-nav), :global(.site-footer), :global(footer) { display: none !important; }
  }

  @media (max-width: 560px) {
    /* Karta ma stały rozmiar w mm — na wąskim ekranie skalujemy podgląd, żeby nie
       rozpychał strony w poziomie. */
    .arkusz { gap: 0.5rem; }
    .karta { transform: scale(0.85); transform-origin: top center; margin-bottom: -20mm; }
  }
</style>
