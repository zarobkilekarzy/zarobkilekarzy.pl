---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — nie znaleziono strony · zarobkilekarzy.pl"
  description="Strona, której szukasz, nie istnieje lub została przeniesiona."
  search={false}
>
  <section class="section">
    <div class="container" style="text-align: center; max-width: 640px;">
      <p class="eyebrow">Błąd 404</p>
      <h1>Nie znaleźliśmy tej strony</h1>
      <p class="lead">
        Strona mogła zostać przeniesiona albo nigdy nie istniała. Wróć na stronę
        główną lub przejdź do danych i źródeł.
      </p>
      <div class="cta-row" style="justify-content: center;">
        <a class="btn btn-primary" href="/">Strona główna</a>
        <a class="btn" href="/dane/">Dane</a>
        <a class="btn" href="/artykuly/">Baza artykułów</a>
      </div>
    </div>
  </section>
</BaseLayout>
