---
// Sekcja „udostępnij petycję" — 2 gotowe grafiki do pobrania (PNG z endpointów
// /petycja/udostepnij/*.png generowanych satori) + przyciski X / Facebook / kopiuj link.
// Reużywana: landing /petycja (po liczniku, „od razu po wysłaniu") i /petycja/jak-to-dziala.
interface Props {
  heading?: string;
  intro?: string;
  id?: string;
}
const {
  heading = 'Podpisz i daj znać innym',
  intro =
    'Siła petycji wielokrotnej to liczba: jedna to sygnał, tysiące identycznych w tej samej sprawie to fakt, którego nie da się przemilczeć. Najprostsze, co możesz zrobić po wysłaniu — przekazać ją dalej. Pobierz gotową grafikę i dołącz do posta albo udostępnij sam link (podgląd graficzny dołączy się automatycznie).',
  id = 'udostepnij',
} = Astro.props;

const shareUrl = 'https://zarobkilekarzy.pl/petycja/';
const shareText =
  'Petycja o jawny rejestr zarobków lekarzy ze środków publicznych — jawność zamiast domysłów. Podpisz i przekaż dalej:';
const fbShare = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`;
const xShare = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(shareUrl)}`;
---

<h2 class="pet-share-h" id={id}>{heading}</h2>
<p class="muted pet-share-intro">{intro}</p>

<div class="share-cards">
  <figure class="scard">
    <img src="/petycja/udostepnij/zero.png" width="1080" height="1350" loading="lazy"
      alt="Grafika do udostępnienia: Ile łącznie z NFZ trafia do jednego lekarza? Zero — tyle jest dziś ogólnodostępnych rejestrów, które to pokazują. zarobkilekarzy.pl/petycja" />
    <a class="btn scard-dl" href="/petycja/udostepnij/zero.png" download="zarobkilekarzy-petycja-0-rejestrow.png" data-beacon="petycja-share-grafika">Pobierz grafikę ↓</a>
  </figure>
  <figure class="scard">
    <img src="/petycja/udostepnij/podpisz.png" width="1080" height="1350" loading="lazy"
      alt="Grafika do udostępnienia: Podpisałem/-am petycję o jawność zarobków lekarzy ze środków publicznych. Podpisz i Ty. zarobkilekarzy.pl/petycja" />
    <a class="btn scard-dl" href="/petycja/udostepnij/podpisz.png" download="zarobkilekarzy-petycja-podpisz-i-ty.png" data-beacon="petycja-share-grafika">Pobierz grafikę ↓</a>
  </figure>
</div>

<div class="share-row">
  <a class="btn btn-primary share-btn" href={xShare} target="_blank" rel="noopener noreferrer" aria-label="Udostępnij na X" data-beacon="petycja-share-x">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.24 2.25h3.31l-7.23 8.26 8.5 11.24h-6.66l-5.22-6.82-5.97 6.82H1.66l7.73-8.84L1.25 2.25h6.83l4.71 6.23 5.45-6.23zm-1.16 17.52h1.83L7.01 4.13H5.05l12.03 15.64z"></path></svg>
    Udostępnij na X ↗
  </a>
  <a class="btn share-btn" href={fbShare} target="_blank" rel="noopener noreferrer" aria-label="Udostępnij na Facebooku" data-beacon="petycja-share-fb">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.9h2.54V9.85c0-2.51 1.49-3.9 3.78-3.9 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.87h2.78l-.44 2.9h-2.34V22c4.78-.76 8.44-4.92 8.44-9.94z"></path></svg>
    Facebook ↗
  </a>
  <button class="btn share-btn" type="button" data-copy-link data-url={shareUrl}>Skopiuj link</button>
</div>

<style>
  .pet-share-h { margin-top: 2.5rem; }
  .pet-share-intro { max-width: 66ch; }
  .share-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin: 1.25rem 0 1.5rem; }
  @media (max-width: 560px) { .share-cards { grid-template-columns: 1fr; } }
  .scard { display: flex; flex-direction: column; gap: 0.7rem; margin: 0; }
  .scard img { width: 100%; height: auto; display: block; border: 1px solid var(--line); border-radius: var(--radius-lg); }
  .scard-dl { align-self: stretch; text-align: center; }
  .share-row { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 0.5rem; }
  .share-btn { display: inline-flex; align-items: center; gap: 0.5rem; }
</style>

<script>
  // Beacon lejka — anonimowy licznik akcji (reużywa /api/clicks; slugi share nie są
  // chronione Turnstile, więc przyjmują beacon bez tokenu). Dedup ~12 h per slug w
  // localStorage (jak w BaseLayout). Fire-and-forget, bez danych osobowych i bez
  // przeszkadzania domyślnej nawigacji/pobieraniu.
  const beacon = (slug) => {
    try {
      const key = 'clk:' + slug;
      const now = Date.now();
      if (now - (Number(localStorage.getItem(key)) || 0) < 12 * 3600 * 1000) return;
      localStorage.setItem(key, String(now));
    } catch (e) {}
    try { navigator.sendBeacon('/api/clicks', JSON.stringify({ slug })); } catch (e) {}
  };
  // X / Facebook / pobierz grafikę (oba .scard-dl) — slug z data-beacon.
  document.querySelectorAll('[data-beacon]').forEach((el) => {
    el.addEventListener('click', () => beacon(el.getAttribute('data-beacon')));
  });

  // Kopiuj link — obsługa wszystkich przycisków [data-copy-link] (działa dla wielu instancji).
  document.querySelectorAll('button[data-copy-link]').forEach((b) => {
    b.addEventListener('click', () => {
      beacon('petycja-share-link');
      const url = b.getAttribute('data-url') || 'https://zarobkilekarzy.pl/petycja/';
      const done = () => {
        const prev = b.textContent;
        b.textContent = 'Skopiowano ✓';
        setTimeout(() => { b.textContent = prev; }, 1800);
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(url).then(done).catch(() => { b.textContent = 'Skopiuj: zarobkilekarzy.pl/petycja'; });
      } else {
        b.textContent = 'Skopiuj: zarobkilekarzy.pl/petycja';
      }
    });
  });
</script>
