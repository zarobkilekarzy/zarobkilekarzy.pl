---
// Sonda opinii (niereprezentatywna). Wyniki zbiorcze: anonimowe liczniki w Cloudflare
// KV przez endpoint /api/sonda. Lokalnie lub bez bindingu KV: graceful fallback
// (po głosie pokazujemy podziękowanie, bez wyników).
//
// Ochrona antybotowa (opcjonalna): jeśli serwer ma skonfigurowany Turnstile, GET zwraca
// `turnstileSiteKey` i front renderuje widżet; głos wymaga wtedy ważnego tokenu. Bez
// konfiguracji widżet się nie pojawia, a głosowanie działa jak dotąd.
---

<section class="section section-alt" id="sonda">
  <div class="container">
    <div class="sonda">
      <p class="eyebrow">Sonda (niereprezentatywna)</p>
      <h2>Sztuczna inteligencja do rutyny, lekarz do pacjenta</h2>
      <p class="sonda-q">
        Czy sztuczna inteligencja powinna przejmować najprostsze, powtarzalne czynności — recepty na
        leki stałe, proste skierowania i zwolnienia — by odciążyć lekarzy?
      </p>
      <p class="sonda-sub">
        Mniej rutyny to większa dostępność dla pacjenta i mniejsza presja na wzrost stawek.
      </p>

      <div class="sonda-options" role="group" aria-label="Odpowiedzi sondy">
        <button class="sonda-btn" data-vote="tak">Tak</button>
        <button class="sonda-btn" data-vote="nie">Nie</button>
        <button class="sonda-btn" data-vote="nie-wiem">Trudno powiedzieć</button>
      </div>

      <div class="sonda-turnstile" hidden></div>
      <p class="sonda-hint" role="alert" hidden></p>

      <div class="sonda-results" hidden>
        <div class="sres-row" data-k="tak">
          <span class="sres-top"><span class="sres-label">Tak</span><span class="sres-pct">0%</span></span>
          <span class="sres-track"><span class="sres-fill"></span></span>
        </div>
        <div class="sres-row" data-k="nie">
          <span class="sres-top"><span class="sres-label">Nie</span><span class="sres-pct">0%</span></span>
          <span class="sres-track"><span class="sres-fill"></span></span>
        </div>
        <div class="sres-row" data-k="nie-wiem">
          <span class="sres-top"><span class="sres-label">Trudno powiedzieć</span><span class="sres-pct">0%</span></span>
          <span class="sres-track"><span class="sres-fill"></span></span>
        </div>
        <p class="sres-total muted"></p>
      </div>

      <p class="sonda-thanks" hidden>Dziękujemy za głos. To sonda opinii, nie badanie reprezentatywne.</p>
      <p class="sonda-note">Twój głos zapisujemy w tej przeglądarce; wyniki zbiorcze są anonimowe.</p>
    </div>
  </div>
</section>

<script>
  const KEY = 'sonda-ai-rutyna-v1';
  const API = '/api/sonda';
  const LABELS = { tak: 'Tak', nie: 'Nie', 'nie-wiem': 'Trudno powiedzieć' };
  const TURNSTILE_API = 'https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit';
  const root = document.getElementById('sonda');
  if (root) {
    const btns = [...root.querySelectorAll('.sonda-btn')];
    const optionsEl = root.querySelector('.sonda-options');
    const turnstileEl = root.querySelector('.sonda-turnstile');
    const hintEl = root.querySelector('.sonda-hint');
    const resultsEl = root.querySelector('.sonda-results');
    const thanksEl = root.querySelector('.sonda-thanks');
    const totalEl = root.querySelector('.sres-total');

    let tsToken = null;            // aktualny token Turnstile (null = brak/wygasł)
    let tsWidgetId = null;         // id wyrenderowanego widżetu (do execute/reset)
    let tsSiteKey = null;          // klucz publiczny (potrzebny przy execute)
    let turnstileEnabled = false;  // czy serwer wymaga tokenu (ustawiane po wczytaniu configu)
    let done = false;              // głos już oddany / wyniki pokazane → blokuj ponowne
    let submitting = false;        // trwa wysyłka — anty-double-click „w locie"
    let pendingChoice = null;      // wybór zapamiętany do chwili, gdy execute() zwróci token

    const showHint = (msg) => { hintEl.textContent = msg; hintEl.hidden = !msg; };

    const loadConfig = async () => {
      try { const r = await fetch(API); if (!r.ok) return null; return await r.json(); } catch (e) { return null; }
    };
    const postVote = async (choice, token) => {
      try {
        const body = token ? { choice, turnstileToken: token } : { choice };
        const r = await fetch(API, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
        const data = await r.json().catch(() => null);
        return { ok: r.ok, status: r.status, data };
      } catch (e) { return { ok: false, status: 0, data: null }; }
    };

    const showResults = (counts, mine) => {
      done = true;
      const total = (counts.tak || 0) + (counts.nie || 0) + (counts['nie-wiem'] || 0);
      resultsEl.querySelectorAll('.sres-row').forEach((row) => {
        const k = row.getAttribute('data-k');
        const n = counts[k] || 0;
        const pct = total ? Math.round((n / total) * 100) : 0;
        row.querySelector('.sres-pct').textContent = pct + '%';
        row.querySelector('.sres-fill').style.width = pct + '%';
        row.classList.toggle('mine', k === mine);
      });
      totalEl.textContent = 'Łącznie głosów: ' + total + (mine ? ' · Twój głos: ' + LABELS[mine] : '');
      optionsEl.hidden = true;
      turnstileEl.hidden = true;
      showHint('');
      thanksEl.hidden = true;
      resultsEl.hidden = false;
    };

    const showThanksFallback = (mine) => {
      done = true;
      btns.forEach((b) => { b.disabled = true; if (b.getAttribute('data-vote') === mine) b.classList.add('chosen'); });
      turnstileEl.hidden = true;
      showHint('');
      thanksEl.hidden = false;
    };

    const loadScript = (src) => new Promise((res, rej) => {
      const s = document.createElement('script');
      s.src = src; s.async = true; s.defer = true; s.onload = res; s.onerror = rej;
      document.head.appendChild(s);
    });

    // Wysyłka ze świeżym (lub żadnym) tokenem: zapisz w localStorage, POST, obsłuż wynik/403.
    const submitWith = async (choice, token) => {
      try { localStorage.setItem(KEY, choice); } catch (e) {}
      const res = await postVote(choice, token);
      if (res.ok && res.data) {
        showResults(res.data, choice);
      } else if (res.status === 403) {
        // token odrzucony (wygasł / duplikat) → pozwól spróbować ponownie
        try { localStorage.removeItem(KEY); } catch (e) {}
        tsToken = null;
        pendingChoice = null;
        if (tsWidgetId != null && window.turnstile) { try { window.turnstile.reset(tsWidgetId); } catch (e) {} }
        submitting = false;
        btns.forEach((x) => (x.disabled = false));
        showHint('Weryfikacja nie powiodła się — spróbuj ponownie.');
      } else {
        showThanksFallback(choice);
      }
    };

    // Świeży token z execute() → dokończ trwającą wysyłkę dla zapamiętanego wyboru.
    const onToken = (token) => {
      tsToken = token;
      showHint('');
      if (submitting && pendingChoice) submitWith(pendingChoice, token);
    };
    // Wyzwanie nie powiodło się/timeout w trakcie kliknięcia → odblokuj i pokaż komunikat.
    const onTurnstileFail = () => {
      tsToken = null;
      if (submitting) {
        pendingChoice = null;
        if (tsWidgetId != null && window.turnstile) { try { window.turnstile.reset(tsWidgetId); } catch (e) {} }
        submitting = false;
        btns.forEach((x) => (x.disabled = false));
        showHint('Weryfikacja nie powiodła się — spróbuj ponownie.');
      }
    };

    // Turnstile w trybie EXECUTE: NIE rozwiązujemy wyzwania na starcie (token żyje ~300 s
    // i mógłby wygasnąć, zanim ktoś kliknie) — wyzwanie odpalamy DOPIERO przy kliknięciu,
    // tuż przed POST → token zawsze świeży i jednorazowy (wzorem LicznikPetycji.astro).
    const initTurnstile = async (siteKey) => {
      try {
        await loadScript(TURNSTILE_API);
        // poczekaj aż globalne `turnstile` będzie gotowe (maks. ~5 s)
        await new Promise((res) => {
          if (window.turnstile) return res();
          const iv = setInterval(() => { if (window.turnstile) { clearInterval(iv); res(); } }, 50);
          setTimeout(() => { clearInterval(iv); res(); }, 5000);
        });
        if (!window.turnstile) return false;
        tsSiteKey = siteKey;
        turnstileEl.hidden = false;
        tsWidgetId = window.turnstile.render(turnstileEl, {
          sitekey: siteKey,
          execution: 'execute',           // rozwiąż na żądanie (przy kliknięciu), nie na starcie
          appearance: 'interaction-only', // widżet niewidoczny, chyba że wymaga interakcji
          callback: (token) => { onToken(token); },
          'expired-callback': () => { tsToken = null; },
          'error-callback': () => { onTurnstileFail(); },
          'timeout-callback': () => { onTurnstileFail(); },
        });
        return true;
      } catch (e) { return false; }
    };

    // Listenery podpinamy SYNCHRONICZNIE — klik nigdy nie przepadnie, nawet zanim
    // wczyta się config czy widżet (stan `turnstileEnabled` czytamy w chwili kliknięcia).
    // Klik: przy włączonym Turnstile zapamiętujemy wybór i odpalamy ŚWIEŻE wyzwanie,
    // wysyłka leci w callbacku (onToken); bez Turnstile wysyłamy od razu.
    btns.forEach((b) => {
      b.addEventListener('click', () => {
        if (done || submitting) return;
        const choice = b.getAttribute('data-vote');
        submitting = true;
        showHint('');
        btns.forEach((x) => (x.disabled = true));
        if (turnstileEnabled) {
          if (tsWidgetId == null || !window.turnstile) {
            // widżet się nie wyrenderował (np. skrypt CF zablokowany) → nie wysyłamy bez
            // tokenu (serwer i tak odrzuci); pozwól spróbować za chwilę.
            submitting = false;
            btns.forEach((x) => (x.disabled = false));
            showHint('Trwa weryfikacja antybotowa — spróbuj za chwilę.');
            return;
          }
          pendingChoice = choice;
          showHint('Weryfikacja antybotowa…');
          // execute() → onToken(świeży token) → submitWith; onTurnstileFail obsługuje błąd/timeout.
          try { window.turnstile.execute(turnstileEl, { sitekey: tsSiteKey }); }
          catch (e) { onTurnstileFail(); }
        } else {
          submitWith(choice, null);
        }
      });
    });

    // Tło: jeśli już głosowano — pokaż wyniki; w przeciwnym razie ewentualnie włącz Turnstile.
    (async () => {
      let voted = null;
      try { voted = localStorage.getItem(KEY); } catch (e) {}
      const cfg = await loadConfig();
      if (voted) {
        if (cfg) showResults(cfg, voted); else showThanksFallback(voted);
        return;
      }
      const siteKey = cfg && cfg.turnstileSiteKey;
      if (siteKey) turnstileEnabled = await initTurnstile(siteKey);
    })();
  }
</script>

<style>
  .sonda { max-width: 720px; }
  .sonda h2 { margin-top: 0.3rem; }
  .sonda-q { font-size: 1.15rem; font-weight: 500; color: var(--ink); margin: 0.5rem 0 0.4rem; }
  .sonda-sub { color: var(--ink-soft); margin: 0 0 1.25rem; }
  .sonda-options:not([hidden]) { display: flex; gap: 0.6rem; flex-wrap: wrap; }
  .sonda-btn { padding: 0.7rem 1.4rem; border: 1px solid var(--line-2); background: #fff; color: var(--ink); border-radius: var(--radius); font-family: var(--font-sans); font-size: 0.98rem; font-weight: 500; cursor: pointer; transition: all 0.15s ease; }
  .sonda-btn:hover:not(:disabled) { border-color: var(--brand); color: var(--brand); }
  .sonda-btn:disabled { cursor: default; opacity: 0.65; }
  .sonda-btn.chosen { background: var(--brand); border-color: var(--brand); color: #fff; opacity: 1; }
  .sonda-turnstile:not([hidden]) { margin-top: 1.1rem; }
  .sonda-hint:not([hidden]) { margin: 0.8rem 0 0; font-size: 0.9rem; color: var(--alert); }
  .sonda-results:not([hidden]) { display: flex; flex-direction: column; gap: 0.85rem; max-width: 520px; margin-top: 2.25rem; }
  .sres-top { display: flex; justify-content: space-between; font-size: 0.95rem; margin-bottom: 0.3rem; }
  .sres-pct { font-family: var(--font-mono); font-weight: 500; }
  .sres-track { display: block; height: 14px; background: var(--paper-2); border-radius: 999px; overflow: hidden; }
  .sres-fill { display: block; height: 100%; width: 0; background: var(--ink-soft); border-radius: 999px; transition: width 0.4s ease; }
  .sres-row.mine .sres-fill { background: var(--brand); }
  .sres-row.mine .sres-label { font-weight: 500; }
  .sres-total { margin: 0.4rem 0 0; font-size: 0.85rem; }
  .sonda-thanks { margin: 1.1rem 0 0; font-weight: 500; color: var(--brand-700); }
  .sonda-note { margin: 0.9rem 0 0; font-size: 0.85rem; color: var(--ink-faint); }
</style>
