---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareRow from '../../components/ShareRow.astro';
import Aktualizacja from '../../components/Aktualizacja.astro';
import DisclaimerZarobki from '../../components/DisclaimerZarobki.astro';

// WERSJA ROBOCZA (niepublikowana). Rdzeń: DANE O ZAROBKACH lekarzy ze środków
// publicznych, wyłuskane z list ujawnionych w obywatelskim monitoringu „Ile
// zarabiają lekarze?" (Sieć Obywatelska Watchdog Polska, fedrowanie.siecobywatelska.pl).
// Lejek „kto odpowiada" zostaje tylko jako krótkie wprowadzenie i źródło liczb.
// Zasady rdzenia redakcyjnego:
//  • liczby = AGREGATY z ujawnionych odpowiedzi (rozkład, percentyle) — odporne na
//    pojedynczy szum; POJEDYNCZE rekordy oznaczamy „surowiec / do weryfikacji";
//  • to DOLNE GRANICE: kwota z JEDNEJ placówki, nikt nie sumuje po PWZ → pointa;
//  • mechanizm, nie osoba — bez nazwisk; placówek-przykładów nie piętnujemy z nazwy
//    (ujawnienie to dobra praktyka, nie afera);
//  • kredyt + link do Watchdog Polska (zasada źródła).
// Dane oczyszczone: tylko listy ROCZNE (mediana ≥60 tys.), bez agregatów zespołów/sum,
// bez list miesięcznych. Stan na 2026-07-18.

const fmt = (n) => new Intl.NumberFormat('pl-PL').format(n);
const SYNC = '2026-07-18';
const SYNC_HR = new Intl.DateTimeFormat('pl-PL', {
  day: 'numeric', month: 'long', year: 'numeric',
}).format(new Date(SYNC + 'T12:00:00'));

// — Lejek-pomost (skąd biorą się kwoty) —
const N = 1358;         // wysłanych wniosków
const MERYT = 693;      // merytoryczna odpowiedź
const LISTY = 74;       // placówki z pełnymi listami per-lekarz
const ROCZNE = 54;      // z tego listy roczne (baza analizy kwot)
const LEKARZY = 3746;   // pojedynczych kwot rocznych na czystym zbiorze

// — Rozkład rocznego brutto na jednego lekarza (czysty zbiór roczny) —
const MEDIANA = 203000;
const P75 = 366000, P90 = 564000, P99 = 1052000;
const OVER300 = 33.4, OVER500 = 13.9;   // % lekarzy
const OVER1M = 55;                       // lekarzy > 1 mln zł/rok
const OVER1Mpct = 1.5;

// Histogram (progi brutto/rok). Kolor rośnie z kwotą: spokój → alarm.
const hist = [
  { label: 'do 100 tys.', n: 1072, pct: 28.6, band: 'lo' },
  { label: '100–200 tys.', n: 781, pct: 20.8, band: 'lo' },
  { label: '200–300 tys.', n: 641, pct: 17.1, band: 'lo' },
  { label: '300–400 tys.', n: 436, pct: 11.6, band: 'mid' },
  { label: '400–500 tys.', n: 296, pct: 7.9, band: 'mid' },
  { label: '500–750 tys.', n: 353, pct: 9.4, band: 'hi' },
  { label: '750 tys.–1 mln', n: 112, pct: 3.0, band: 'hi' },
  { label: 'ponad 1 mln', n: 55, pct: 1.5, band: 'top' },
];
const histMax = Math.max(...hist.map((h) => h.pct));

// — Drabina percentyli (kto ile rozliczył — z JEDNEJ placówki) —
const ladder = [
  { who: 'Mediana — środkowy lekarz na listach', v: '≈ 200 tys.', wpct: 20 },
  { who: 'Co czwarty lekarz (górne 25%)', v: 'ponad 365 tys.', wpct: 37 },
  { who: 'Co dziesiąty (górne 10%)', v: 'ponad 560 tys.', wpct: 56 },
  { who: 'Jeden na stu (górne 1%)', v: 'ponad 1 mln', wpct: 100 },
];

const MONITORING = 'https://fedrowanie.siecobywatelska.pl/monitoringi/ile-zarabiaja-lekarze';
const WATCHDOG = 'https://siecobywatelska.pl/';
const FEDROWANIE = 'https://fedrowanie.siecobywatelska.pl/';
---

<BaseLayout
  title="Ile trafia do jednego lekarza — z ujawnionych list — zarobkilekarzy.pl"
  description="54 publiczne szpitale ujawniły pełne listy wynagrodzeń lekarzy — 3746 rozliczeń. Mediana ok. 200 tys. zł rocznie, co siódme ponad 500 tys., dziesiątki powyżej miliona — a każda kwota to zapłata jednego tylko szpitala. Dane, wykresy i uczciwe zastrzeżenia. Źródło: obywatelski monitoring Watchdog Polska."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow"><a href="/dane/">Dane</a> · Zarobki z ujawnionych list</p>
      <h1>Ile trafia do jednego lekarza — z ujawnionych list</h1>
      <Aktualizacja zrodla=" · obywatelski monitoring „Ile zarabiają lekarze?” (Sieć Obywatelska Watchdog Polska)." />
      <p class="lead">
        Watchdog Polska zapytał <strong>{fmt(N)} publicznych placówek</strong>, ile płacą lekarzom ze środków
        publicznych. Część ujawniła <strong>pełne, wierszowe listy</strong> — złożyły się na
        <strong> {fmt(LEKARZY)} konkretnych kwot rocznych</strong>. Oto co z nich wynika. Bez
        akapitów tam, gdzie wystarczy wykres — a każda kwota to i tak dopiero <strong>fragment</strong>.
      </p>

      <DisclaimerZarobki />

      <!-- ————————————————— SKĄD TE DANE (WATCHDOG) ————————————————— -->
      <aside class="wd-box" aria-label="Źródło danych">
        <div class="wd-head">
          <span class="wd-tag">Skąd te dane</span>
          <span class="wd-name">Sieć Obywatelska Watchdog Polska</span>
        </div>
        <p class="wd-lead">
          To nie nasze szacunki. Liczby pochodzą z <strong>obywatelskiego monitoringu</strong>
          „Ile zarabiają lekarze?", prowadzonego przez
          <a href={WATCHDOG} target="_blank" rel="noopener noreferrer">Sieć Obywatelską Watchdog Polska</a> —
          organizację strażniczą, która egzekwuje prawo do informacji publicznej. W ramach
          monitoringu do publicznych placówek ochrony zdrowia rozesłano <strong>{fmt(N)} jednakowych
          wniosków</strong> o <strong>roczne brutto lekarzy za 2025 r.</strong> ze środków
          publicznych. Cała korespondencja — wnioski i odpowiedzi wraz z tabelami — jest
          <strong> jawna</strong> na platformie
          <a href={FEDROWANIE} target="_blank" rel="noopener noreferrer">fedrowanie.siecobywatelska.pl</a>.
          Kwoty poniżej wyłuskaliśmy z tych odpowiedzi.
        </p>
        <p class="wd-cta">
          <a href={MONITORING} target="_blank" rel="noopener noreferrer">Zobacz monitoring u źródła →</a>
        </p>
      </aside>

      <!-- ————————————————— POMOST: SKĄD 3746 KWOT ————————————————— -->
      <figure class="bridge" aria-label={`Z ${fmt(N)} wniosków ${fmt(MERYT)} odpowiedziało merytorycznie, ${fmt(LISTY)} podało pełne listy, co dało ${fmt(LEKARZY)} kwot rocznych z ${ROCZNE} placówek.`}>
        <div class="br-step"><span class="br-n">{fmt(N)}</span><span class="br-l">wysłanych wniosków</span></div>
        <span class="br-arr" aria-hidden="true">→</span>
        <div class="br-step"><span class="br-n">{fmt(MERYT)}</span><span class="br-l">odpowiedziało merytorycznie</span></div>
        <span class="br-arr" aria-hidden="true">→</span>
        <div class="br-step"><span class="br-n">{fmt(LISTY)}</span><span class="br-l">podało pełne listy płac</span></div>
        <span class="br-arr" aria-hidden="true">→</span>
        <div class="br-step is-out"><span class="br-n">{fmt(LEKARZY)}</span><span class="br-l">kwot rocznych do analizy<br />(z {ROCZNE} placówek)</span></div>
      </figure>
      <p class="mod-cap" style="margin-top:0.6rem">
        Rozbicie „kto odpowiada, a kto milczy" (¾ placówek zwleka, milczy lub odmawia) to osobny
        wątek — tu skupiamy się na tym, co pokazali <strong>ci, którzy odpowiedzieli</strong>.
      </p>

      <!-- ————————————————— TRZY LICZBY NA WEJŚCIE ————————————————— -->
      <div class="head3">
        <div class="h3tile">
          <span class="h3lab">mediana — roczne brutto</span>
          <span class="h3num">≈ 200<span class="h3u"> tys. zł</span></span>
          <span class="h3ctx">Środkowy lekarz na ujawnionych listach — za 2025 r., z <strong>jednej</strong> placówki.</span>
          <a class="h3src" href="#rozklad">Zobacz rozkład ↓</a>
        </div>
        <div class="h3tile is-brand2">
          <span class="h3lab">co siódmy lekarz</span>
          <span class="h3num">&gt; 500<span class="h3u"> tys. zł/rok</span></span>
          <span class="h3ctx">{OVER500}% rozliczeń przekracza pół miliona rocznie — a to zapłata jednego tylko szpitala.</span>
          <a class="h3src" href="#ogon">Zobacz ogon ↓</a>
        </div>
        <div class="h3tile is-alert">
          <span class="h3lab">rozliczeń powyżej miliona</span>
          <span class="h3num">{fmt(OVER1M)}<span class="h3u"> lekarzy</span></span>
          <span class="h3ctx">≈ {OVER1Mpct}% pozycji przekracza milion złotych rocznie — z jednego tylko szpitala. Pojedyncze sięgają 2 mln. <span class="chip chip-alert">surowiec — do weryfikacji</span></span>
          <a class="h3src" href="#ogon">Rekordy ↓</a>
        </div>
      </div>

      <p class="act" id="rozklad"><span class="act-num">I</span> Rozkład: ile realnie dostają</p>

      <!-- ————————————————— 1. HISTOGRAM ————————————————— -->
      <h2 class="mod-h">{fmt(LEKARZY)} rozliczeń z {ROCZNE} szpitali</h2>
      <p class="mod-sub">
        Rozkład rocznego brutto na jedno rozliczenie — ze <strong>wszystkich {ROCZNE} ujawnionych
        list rocznych</strong>. Każda pozycja to zapłata jednego szpitala jednemu lekarzowi za rok;
        im wyższa kwota, tym cieplejszy słupek.
      </p>
      <figure class="hist" aria-label="Rozkład rocznego brutto: do 100 tys. 28,6%, 100–200 tys. 20,8%, 200–300 tys. 17,1%, 300–400 tys. 11,6%, 400–500 tys. 7,9%, 500–750 tys. 9,4%, 750 tys.–1 mln 3%, ponad 1 mln 1,5%.">
        {hist.map((h) => (
          <div class="hrow">
            <span class="hlab">{h.label}</span>
            <div class="htrack">
              <div class={`hfill hband-${h.band}`} style={`width:${(h.pct / histMax) * 100}%`}></div>
            </div>
            <span class="hval">{h.pct}%<span class="hn"> · {fmt(h.n)}</span></span>
          </div>
        ))}
      </figure>
      <p class="mod-cap">
        Mediana to <strong>≈ 200 tys. zł</strong> rocznie (ok. 17 tys. zł miesięcznie brutto).
        Ale rozkład jest silnie <strong>prawostronny</strong>: „długi ogon" bogatych rozliczeń
        ciągnie średnią w górę i to on jest właściwą historią. Wszystko <strong>za rok 2025, z
        jednego szpitala</strong> — a realnie u wielu lekarzy sumuje się to z kilku miejsc naraz.
      </p>

      <!-- ————————————————— UCZCIWIE: JAK CZYTAĆ TE LICZBY ————————————————— -->
      <div class="callout quiet">
        <p>
          <strong>Jak czytać te liczby — uczciwie.</strong> To <strong>nie</strong> jest próba
          reprezentatywna dla wszystkich lekarzy w Polsce. Cztery zastrzeżenia:
        </p>
        <ul class="rz-list">
          <li>dane ujawniło <strong>{ROCZNE} z {fmt(N)} placówek</strong> — dobór nielosowy, ze
            skosem ku dużym szpitalom wojewódzkim i specjalistycznym, które płacą więcej;</li>
          <li><strong>pięć największych list to ~47% wszystkich pozycji</strong> — rozkład w dużej
            mierze opisuje kilka dużych szpitali, nie „przeciętną placówkę";</li>
          <li>mediana ważona pozycją to ≈ 200 tys., ale ważona <strong>placówką</strong> (typowy
            szpital z zestawu) to <strong>≈ 150 tys.</strong> — duże, lepiej płacące szpitale ciągną
            ją w górę;</li>
          <li>to <strong>rozliczenia</strong> (pozycje na listach), a nie zsumowane dochody osób;
            część list rozbija jednego lekarza na kilka umów, więc per osoba kwoty bywają
            <strong> wyższe</strong>, nie niższe.</li>
        </ul>
        <p style="margin-bottom:0">
          Wniosek dotyczył rocznego brutto 2025. Te liczby to <strong>rząd wielkości i dolna
          granica</strong> tego, co widać w ujawnionych listach — nie precyzyjny pomiar całego rynku.
        </p>
      </div>

      <!-- ————————————————— 2. DRABINA PERCENTYLI ————————————————— -->
      <h2 class="mod-h">Im wyżej, tym stromiej</h2>
      <p class="mod-sub">Ile rocznie rozliczył lekarz na danym poziomie listy (brutto, zapłata jednego szpitala):</p>
      <figure class="ladder" aria-label="Mediana około 200 tys., górne 25% ponad 365 tys., górne 10% ponad 560 tys., górny 1% ponad milion złotych rocznie.">
        {ladder.map((r, i) => (
          <div class="lrow">
            <span class="lwho">{r.who}</span>
            <div class="ltrack">
              <div class={`lfill lstep-${i}`} style={`width:${r.wpct}%`}><span class="lv">{r.v}<span class="lu"> zł</span></span></div>
            </div>
          </div>
        ))}
      </figure>

      <!-- killer stat -->
      <div class="quotecard">
        <div class="qc-num">1 na 7</div>
        <blockquote class="qc-quote">Co siódmy lekarz na tych listach rozliczył ponad pół miliona złotych — w jeden rok, z jednego szpitala.</blockquote>
        <p class="qc-cap">
          Dokładnie <strong>{OVER500}%</strong> rozliczeń przekracza 500 tys. zł rocznie, a
          <strong> {OVER300}%</strong> — 300 tys. To nie są oferty ani stawki godzinowe: to
          <strong> faktyczne roczne wypłaty ze środków publicznych</strong>, podane przez same
          placówki w odpowiedzi na wniosek.
        </p>
      </div>

      <p class="act" id="ogon"><span class="act-num">II</span> Ogon: rozliczenia powyżej miliona</p>

      <!-- ————————————————— 3. OGON / REKORDY ————————————————— -->
      <h2 class="mod-h">Milion złotych rocznie — w jednym tylko szpitalu</h2>
      <p class="mod-sub">
        Na samym końcu rozkładu jest wąska, ale realna grupa. To rozliczenia, które w publicznej
        debacie brzmią nieprawdopodobnie — a wynikają wprost z urzędowych odpowiedzi.
      </p>
      <div class="dtiles">
        <div class="dtile">
          <span class="dt-num">{fmt(OVER1M)}</span>
          <span class="dt-lab">pozycji rozliczono na <strong>ponad 1 mln zł</strong> w 2025 r. (≈ {OVER1Mpct}% list)</span>
        </div>
        <div class="dtile">
          <span class="dt-num">≈ 1,4 mln</span>
          <span class="dt-lab">najwyższa pozycja na jednoznacznie <strong>numerowanej</strong> liście (1 wiersz = 1 lekarz)</span>
        </div>
        <div class="dtile">
          <span class="dt-num">1 / 100</span>
          <span class="dt-lab">rozliczeń przekracza milion — górny 1% (p99 ≈ 1,05 mln zł)</span>
        </div>
      </div>
      <p class="mod-cap">
        Ostrożnie z rekordami. Na listach <strong>numerowanych</strong> (1 wiersz = 1 lekarz) najwyższe
        pozycje sięgają <strong>~1,4 mln zł</strong>. Na listach z <strong>inicjałami</strong> pojawiają
        się pozycje nawet powyżej 2 mln — ale tam te same inicjały potrafią się powtarzać, więc mogą
        <strong> łączyć kilka umów albo różne osoby</strong>; nie podajemy ich jako rekordów jednej osoby.
        Zdarzają się też sumy zespołów i błędy odczytu skanów, które odfiltrowujemy. Każdą pojedynczą
        kwotę traktujemy jako <strong>surowiec do weryfikacji przy źródle</strong> —
        <a href={MONITORING} target="_blank" rel="noopener noreferrer">monitoring Watchdog</a>.
        Dokładniej opisane, potwierdzone rekordy zbieramy w <a href="/dane/rekordy/">rekordach</a>.
      </p>

      <!-- ————————————————— 4. JEDNA LISTA Z BLISKA ————————————————— -->
      <h2 class="mod-h">Jak wygląda jedna taka lista</h2>
      <p class="mod-sub">
        Wzorcowa odpowiedź: jeden szpital wojewódzki podał <strong>całą listę {fmt(446)} lekarzy</strong> —
        i sam ją zanonimizował, numerując „Lekarz nr 1, 2, 3…". Dokładnie nasz model:
        <strong> jawna kwota bez nazwiska</strong>.
      </p>
      <div class="anon-wrap">
        <div class="anon-card" role="img" aria-label="Przykład zanonimizowanej listy jednego szpitala: 446 lekarzy oznaczonych numerami, mediana około 190 tysięcy, rekord około 1,4 miliona złotych rocznie.">
          <div class="anon-row"><span class="anon-id">Lekarz nr 1</span><span class="anon-kw">■ ■■■ ■■■ zł</span></div>
          <div class="anon-row"><span class="anon-id">Lekarz nr 2</span><span class="anon-kw">■■■ ■■■ zł</span></div>
          <div class="anon-row"><span class="anon-id">Lekarz nr 3</span><span class="anon-kw">■ ■■■ ■■■ zł</span></div>
          <div class="anon-more">… aż do „Lekarz nr 446" — bez jednego nazwiska</div>
        </div>
        <div class="anon-side">
          <ul class="mini-stats">
            <li><span class="ms-n">446</span><span class="ms-l">lekarzy na jednej liście</span></li>
            <li><span class="ms-n">≈ 190 tys.</span><span class="ms-l">mediana brutto/rok</span></li>
            <li><span class="ms-n">≈ 1,38 mln</span><span class="ms-l">najwyższe rozliczenie</span></li>
            <li><span class="ms-n">47</span><span class="ms-l">lekarzy powyżej 500 tys. zł</span></li>
          </ul>
          <p class="anon-note">
            Nazwy szpitala nie podajemy — <strong>ujawnienie to dobra praktyka, nie afera</strong>.
            Piętnujemy system, w którym takie dane są loterią, a nie tych, którzy odpowiedzieli.
          </p>
        </div>
      </div>

      <p class="act"><span class="act-num">III</span> Dlaczego to wciąż zaniżone</p>

      <!-- ————————————————— 5. DOLNA GRANICA / POINTA ————————————————— -->
      <h2 class="mod-h">Każda z tych kwot to dolna granica</h2>
      <p class="mod-sub">
        Rozkład wyżej złożyliśmy z <strong>54 szpitali</strong> — ale każda pojedyncza kwota to
        zapłata <strong>tylko jednego</strong> z nich danemu lekarzowi. Ten sam lekarz może
        rozliczać się równolegle w kilku szpitalach, na kontrakcie i etacie naraz — tych
        pozostałych wypłat tu <strong>nie widać</strong>.
      </p>
      <figure class="sumbox" aria-label="Ten sam lekarz w kilku placówkach: widzimy kwotę tylko z jednej, suma po PWZ pozostaje nieznana.">
        <div class="sb-nodes">
          <div class="sb-node is-seen">Szpital A<span>widoczne: ■ ■■■ ■■■ zł</span></div>
          <div class="sb-node">Szpital B<span>nie ujawnił</span></div>
          <div class="sb-node">Przychodnia C<span>nie ujawniła</span></div>
        </div>
        <div class="sb-sum">
          <span class="sb-q">Σ po numerze PWZ = ?</span>
          <span class="sb-qcap">Nikt nie ma prawa tego zsumować — dlatego oficjalne liczby są zaniżone.</span>
        </div>
      </figure>
      <p class="mod-cap">
        Co więcej — pełne listy pokazało zaledwie <strong>{ROCZNE} z {fmt(N)} placówek</strong>. Reszta
        milczy, zwleka albo odmawia. Widzimy więc <strong>ułamek rynku — i to tylko po jednej stronie
        każdego lekarza</strong>. Skala całości pozostaje zakryta.
      </p>

      <!-- ————————————————— POINTA ————————————————— -->
      <div class="callout" style="border-left-color: var(--brand); margin-top: 2.5rem">
        <p>
          Mediana <strong>≈ 200 tys. zł</strong>, co siódme rozliczenie ponad pół miliona,
          dziesiątki powyżej miliona — a każda z tych kwot to zapłata <strong>jednego tylko szpitala, za jeden rok</strong>.
          Prawdziwej, łącznej kwoty ze <strong>wszystkich</strong> źródeł publicznych nie zna nikt,
          bo nikt nie ma prawa jej zsumować. To jedyny postulat tej strony: <strong>jawny rejestr
          łącznych wypłat powiązany z PWZ</strong> — nie z PESEL, bez danych prywatnych.
          <a href="/postulat/">Zobacz postulat →</a>
        </p>
      </div>

      <!-- ————————————————— ATRYBUCJA / METODA ————————————————— -->
      <p class="source-note" style="margin-top:2rem">
        <strong>Źródło i metoda.</strong> Dane: obywatelski monitoring „Ile zarabiają lekarze?"
        prowadzony przez <a href={WATCHDOG} target="_blank" rel="noopener noreferrer">Sieć
        Obywatelską Watchdog Polska</a> na platformie
        <a href={FEDROWANIE} target="_blank" rel="noopener noreferrer">Obywatelskiego fedrowania
        danych</a> (<a href={MONITORING} target="_blank" rel="noopener noreferrer">monitoring „Ile
        zarabiają lekarze?"</a>). Z jawnych odpowiedzi wyłuskaliśmy wierszowe tabele płac; do rozkładu
        bierzemy wyłącznie listy <strong>roczne</strong> (mediana ≥ 60 tys. zł), po odfiltrowaniu sum
        zespołów, wierszy „razem" i list miesięcznych — {fmt(LEKARZY)} kwot z {ROCZNE} placówek.
        Pojedyncze rekordy wymagają potwierdzenia u źródła. Stan na {SYNC_HR} (monitoring trwa,
