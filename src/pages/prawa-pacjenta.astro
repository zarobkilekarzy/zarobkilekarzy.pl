  .hotline-d a { color: #fff; }

  /* Baner wersji do druku — oferta, nie druczek. Wcześniej ginął w wyszarzonym
     callout obok disclaimera; teraz treść po lewej, przycisk po prawej. */
  .druk-banner {
    display: flex; align-items: center; justify-content: space-between; gap: 1.25rem;
    background: var(--brand-50); border: 1px solid var(--line);
    border-radius: var(--radius-lg); padding: 1.1rem 1.4rem; margin: 1.75rem 0;
  }
  .druk-banner-t { margin: 0 0 0.15rem; font-size: 1rem; }
  .druk-banner-d { margin: 0; color: var(--ink-soft); font-size: 0.92rem; line-height: 1.55; }
  .druk-banner .btn { flex-shrink: 0; }
  @media (max-width: 560px) {
    .druk-banner { flex-direction: column; align-items: flex-start; gap: 0.9rem; }
  }

  /* FAQ — wzorem /faq/, ale pytania to realne pytania pacjenta, więc bez cudzysłowów. */
  .faq { margin: 1rem 0 2rem; display: flex; flex-direction: column; gap: 0.75rem; }
  .faq details { border: 1px solid var(--line); border-radius: var(--radius); background: #fff; }
  .faq summary { cursor: pointer; padding: 1rem 1.25rem; font-weight: 500; font-size: 1.02rem; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary::after { content: "+"; color: var(--brand); font-size: 1.4rem; font-weight: 400; line-height: 1; flex-shrink: 0; }
  .faq details[open] summary::after { content: "−"; }
  .faq details[open] summary { border-bottom: 1px solid var(--line); }
  .faq-a { padding: 1rem 1.25rem 1.25rem; }
  .faq-a p { margin: 0; color: #29384b; line-height: 1.7; }

  /* Kanały zgłoszeń — lista zwijana, nie karty. Rozwinięte zajmowały ponad połowę
     strony i spychały pointę poza ekran, a to materiał do jednorazowego użycia:
     pacjent potrzebuje JEDNEGO kanału, nie siedmiu naraz. Zwinięte wiersze dają się
     przeskanować wzrokiem, szczegóły są o jedno kliknięcie. */
  .kanaly { display: flex; flex-direction: column; gap: 0.4rem; margin: 1.25rem 0 2rem; }
  .kanal {
    background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius);
