  .mh-title { font-family: var(--font-serif); font-weight: 600; line-height: 1.08; letter-spacing: -0.015em; font-size: clamp(2.3rem, 5.6vw, 3.7rem); margin: 0 0 1.1rem; color: #fff; }
  .mh-hl { color: #7fb0e0; }
  .mh-hl-teal { color: #5fc7d1; }
  .mh-lead { font-size: 1.2rem; line-height: 1.6; color: rgba(255,255,255,0.82); max-width: 52ch; margin: 0 0 1.75rem; }
  .mh-cta { display: flex; gap: 0.75rem; flex-wrap: wrap; }
