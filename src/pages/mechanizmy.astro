---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShareRow from '../components/ShareRow.astro';

const podstrony = [
  { href: '/mechanizmy/wieloetatowosc/', t: 'Wieloetatowość i równoległe kontrakty', d: 'Ten sam lekarz rozlicza kontrakty w kilku placówkach naraz — nikt nie widzi sumy.' },
  { href: '/mechanizmy/kontrakt-vs-etat/', t: 'Kontrakt czy etat', d: 'Dlaczego ~73% specjalistów rozlicza się jako firma — i czemu to właśnie forma zatrudnienia decyduje o jawności.' },
  { href: '/mechanizmy/dyzury-i-gotowosc/', t: 'Dyżur „pod telefonem”', d: 'Opłacana gotowość bez obecności w szpitalu. Ile ich przypada na tę samą dobę?' },
  { href: '/mechanizmy/rozliczenia-nfz/', t: 'Rozliczenia: ryczałt, punkty, nadwykonania', d: 'Nieprzejrzysty sposób rozliczeń tworzy przestrzeń do optymalizacji przychodu.' },
  { href: '/mechanizmy/fikcyjne-wizyty/', t: 'Wizyty, których nie było', d: 'Świadczenie sprawozdane do NFZ na pacjenta, który o nim nie wie. Jedynym świadkiem spoza układu placówka–NFZ jest ten pacjent — sprawdź swoje IKP.' },
  { href: '/mechanizmy/wycena-swiadczen/', t: 'Wycena świadczeń: kto ustala, ile płaci NFZ', d: 'Niezależną taryfą objęto ~17% wartości świadczeń — resztę cen ustala sam płatnik. Cena rozjeżdża się z kosztem: raz szpital traci na leczeniu (kolejka), raz procedura staje się magnesem na zysk.' },
  { href: '/mechanizmy/brak-jawnosci/', t: 'Brak jawności jako warunek nadużyć', d: 'Wspólny mianownik wszystkich mechanizmów — i to, kto na tym traci.' },
  { href: '/mechanizmy/samorzad-nil/', t: 'Rola samorządu (NIL)', d: 'Izba z mocy ustawy reprezentuje interesy zawodu, nie pacjentów. Asymetria głosu.' },
  { href: '/mechanizmy/reglamentacja-dostepu/', t: 'Reglamentacja dostępu do zawodu', d: 'Limity miejsc i sprzeciw wobec nowych kierunków. Mniej konkurencji to wyższe stawki.' },
];
---

<BaseLayout
  title="Mechanizmy — zarobkilekarzy.pl"
  description="Jak działa system: wieloetatowość, rozliczanie kontraktów, dyżury pod telefonem, reglamentacja dostępu i rola braku jawności w nadużyciach finansowych w ochronie zdrowia."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Jak działa system</p>
      <h1>Mechanizmy</h1>
      <p class="lead">
        Opisujemy mechanizmy systemowe, nie konkretne osoby. Celem jest pokazanie,
        jak konstrukcja systemu pozwala wąskiej grupie kumulować dochody ze środków
        publicznych — kosztem pacjentów i uczciwych lekarzy.
      </p>

      <div class="hub-grid">
        {podstrony.map((p) => (
          <a class="hub-card" href={p.href}>
            <span class="hub-t">{p.t}</span>
            <span class="hub-d">{p.d}</span>
            <span class="hub-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>

      <div class="callout" style="margin-top: 2rem">
        <p>
          <strong>Wspólny mianownik: brak jawności.</strong> Wszystkie te mechanizmy łączy
          jedno — nie istnieje rejestr sumujący wynagrodzenia jednego lekarza ze środków
          publicznych. Dlatego nasz postulat dotyczy jawności, nie osób.
          <a href="/postulat/">Poznaj postulat →</a>
        </p>
      </div>

      <p class="source-note" style="margin-top: 1.5rem">
        Każda teza na podstronach jest powiązana z ogólnodostępnym źródłem — zob. też
        <a href="/dane/">dane</a> i <a href="/artykuly/">bazę artykułów</a>.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <ShareRow heading="Pomóż nagłośnić sprawę:" />
    </div>
  </section>
</BaseLayout>

<style>
  .hub-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
  .hub-card { position: relative; display: flex; flex-direction: column; gap: 0.35rem; background: var(--bg); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: 1.1rem 1.25rem; text-decoration: none; transition: border-color 0.15s, transform 0.15s; }
  .hub-card:hover { border-color: var(--brand); transform: translateY(-2px); }
  .hub-t { font-weight: 600; color: var(--ink); font-size: 1.02rem; }
  .hub-d { font-size: 0.88rem; color: var(--ink-soft); line-height: 1.45; }
  .hub-arrow { color: var(--brand); font-weight: 700; margin-top: 0.15rem; }
</style>
