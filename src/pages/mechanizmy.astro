---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShareRow from '../components/ShareRow.astro';
import HubSekcje from '../components/HubSekcje.astro';
import { stronyDzialu } from '../lib/pages';

const podstrony = stronyDzialu('mechanizmy');
---

<BaseLayout
  title="Mechanizmy — zarobkilekarzy.pl"
  description="Jak działa system: wieloetatowość, rozliczanie kontraktów, dyżury pod telefonem, reglamentacja dostępu i rola braku jawności w nadużyciach finansowych w ochronie zdrowia."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Jak działa system</p>
      <h1>Mechanizmy</h1>
      <p class="lead">
        Opisujemy mechanizmy systemowe, nie konkretne osoby. Celem jest pokazanie,
        jak konstrukcja systemu pozwala wąskiej grupie kumulować dochody ze środków
        publicznych — kosztem pacjentów i uczciwych lekarzy.
      </p>

      <HubSekcje strony={podstrony} />

      <div class="callout" style="margin-top: 2rem">
        <p>
          <strong>Wspólny mianownik: brak jawności.</strong> Wszystkie te mechanizmy łączy
          jedno — nie istnieje rejestr sumujący wynagrodzenia jednego lekarza ze środków
          publicznych. Dlatego nasz postulat dotyczy jawności, nie osób.
          <a href="/postulat/">Poznaj postulat →</a>
        </p>
      </div>

      <p class="source-note" style="margin-top: 1.5rem">
        Każda teza na podstronach jest powiązana z ogólnodostępnym źródłem — zob. też
        <a href="/dane/">dane</a> i <a href="/artykuly/">bazę artykułów</a>.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <ShareRow heading="Pomóż nagłośnić sprawę:" />
    </div>
  </section>
</BaseLayout>
