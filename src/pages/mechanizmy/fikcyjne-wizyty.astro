     nie osobnym walkthroughem, dlatego odstęp między krokami jest większy. */
  .steps { list-style: none; padding: 0; margin: 1.25rem 0 0; display: flex; flex-direction: column; gap: 1.4rem; }
  .steps li { display: flex; align-items: baseline; gap: 0.7rem; line-height: 1.6; color: var(--ink); }
  .steps li > span:last-child { min-width: 0; }
  .step-n {
    flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center;
    width: 1.7rem; height: 1.7rem; border-radius: 999px;
    background: var(--brand); color: #fff; font-size: 0.9rem; font-weight: 600;
    transform: translateY(0.2rem);
  }
  /* Bez obramowania — zrzuty mają własny cień okna (kanał alfa). */
  .step-shot { display: block; width: 100%; height: auto; margin-top: 0.6rem; }
</style>
