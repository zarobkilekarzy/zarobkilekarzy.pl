---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShareRow from '../components/ShareRow.astro';

const analizy = [
  { href: '/analizy/pielegniarstwo-w-polsce/', t: 'Pielęgniarstwo w Polsce: drabina wieku i nadchodzący niedobór', d: 'Najstarsza kadra systemu: średni wiek pielęgniarki to 54 lata, 34% jest już w wieku emerytalnym, a do 2030 r. będzie ich 65%. Wchodzi 6205 rocznie, w wiek emerytalny — nawet 10 tys. Do tego gęstość 5,9 na 1000 (najniższa w UE), emigracja i starzejące się społeczeństwo. Nożyce, które właśnie się zamykają.' },
  { href: '/analizy/sladem-zlotowki/', t: 'Śladem publicznej złotówki', d: 'Prześledź jedną złotówkę: od Twojej składki, przez wycenę leczenia i ryczałt szpitala, po wypłatę lekarza. Na każdym z pięciu przystanków widać zbiorczą kwotę — nigdy tego, ile trafiło do konkretnego numeru PWZ. Wykład o tym, jak działa finansowanie NFZ, i o tym, gdzie po drodze znika jawność.' },
  { href: '/analizy/jedno-pwz/', t: 'Jeden lekarz, wiele strumieni', d: 'Kontrakt, dyżury i poradnia mogą zbiegać się na jednym numerze PWZ — a łącznej sumy nikt nie liczy. Model tego, czego nie widać.' },
  { href: '/analizy/poz-pieniadz-za-pacjenta/', t: 'POZ: pieniądz za zarejestrowanego pacjenta', d: 'Kapitacja jest jawna co do grosza — a i tak nie wiadomo, ile zostaje lekarzowi. Ten sam strumień naraz najbardziej i najmniej jawny w systemie.' },
  { href: '/analizy/zarobki-lekarzy-polska-sasiedzi/', t: 'Zarobki lekarzy: Polska na tle sąsiadów', d: 'Czechy, Niemcy, Austria — u sąsiadów płace są jawne w taryfach. Polska ukrywa realny dochód w niejawnym kontrakcie.' },
  { href: '/analizy/dlaczego-brakuje-lekarzy/', t: 'Dlaczego brakuje lekarzy', d: 'Miejsc jest dużo, a lekarza „nie ma”. Sześć mechanizmów paradoksu — i dlaczego to nie problem samej liczby.' },
  { href: '/analizy/lekarze-ze-wschodu/', t: 'Lekarze ze wschodu', d: 'Lekarze spoza UE wchodzą do zawodu decyzją ministra, z pominięciem izb i weryfikacji dyplomu. Mechanizm, liczby i luki jawności.' },
  { href: '/analizy/lejek-ksztalcenia/', t: 'Lejek kształcenia', d: 'Miejsc przybywa, ale 2/3–3/4 miejsc specjalizacyjnych co roku stoi pustych. Wąskie gardło jest strukturalne.' },
  { href: '/analizy/apteka-pieniadz-publiczny/', t: 'Apteka i recepta: pieniądz, którego nikt nie sumuje', d: 'Refundacja 25,5 mld zł, wyłudzenia, receptomaty, kolejka po receptę — wszystko zbiega się na numerze PWZ, a nikt tego nie łączy ani nie publikuje.' },
  { href: '/analizy/covid-pieniadz-publiczny/', t: 'COVID-19: miliardy bez jawnego rozliczenia', d: 'Fundusz COVID ~190 mld zł, ~9 mld dodatków wypłaconych — wg NIK — bez żadnej kontroli, 15 tys. zł za 30 minut pracy. Nie o szczepionkach, o pieniądzu.' },
  { href: '/analizy/ucieczka-lekarzy/', t: 'Zarezerwowane dla lekarzy: rynek urody, który wyciąga ich z kolejki', d: 'Państwo oddaje lekarzom wyłączność na dochodową medycynę estetyczną. Skoro tylko oni mogą — gotówka przeciąga deficytowe godziny od pacjenta. Miarą ciągu jest cały zagrożony rynek beauty, nie garstka dzisiejszych lekarzy.' },
  { href: '/analizy/nil-a-kontrakty-lekarskie/', t: 'Naczelna Izba Lekarska a kontrakty lekarskie', d: 'Kontraktów samorząd nie wprowadził — zrobił to związek zawodowy (OZZL) i ustawodawca. NIL ani ich nie forsuje, ani przeciw nim nie protestuje: broni prawa do kontraktu, lecz krytykuje nadużycia. Rozwiązaniem nie jest likwidacja formy, lecz jawność łącznej kwoty po numerze PWZ.' },
  { href: '/analizy/zarobki-dyrektorow-szpitali/', t: 'Ile zarabiają dyrektorzy szpitali — i dlaczego akurat to jest jawne', d: 'Zarobki dyrektorów SPZOZ i części prezesów spółek są jawne co do złotówki — z mocy prawa, w oświadczeniach majątkowych. To odwrotność ukrytych kontraktów. A jednak ta jawność odsłania kumulację funkcji, pensje rosnące mimo długu i lukę między reżimem SPZOZ a spółką. Dowód, że jawny rejestr jest wykonalny.' },
  { href: '/analizy/komin-placowy/', t: 'Co to jest komin płacowy', d: 'Rażąco wysoka płaca jednej osoby, „wystająca” ponad resztę jak komin ponad dach. Ustawa kominowa miała je ścinać — działa jednak tam, gdzie pieniądz i tak widać (jawna pensja na etacie), a jest ślepa na najwyższy komin w ochronie zdrowia: kontrakt sumowany po placówkach.' },
];
---

<BaseLayout
  title="Analizy — zarobkilekarzy.pl"
  description="Pogłębione, oźródłowane analizy o pieniądzu publicznym w ochronie zdrowia: porównania międzynarodowe, niedobór lekarzy, kształcenie i reglamentacja."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Pogłębione tematy</p>
      <h1>Analizy</h1>
      <p class="lead">
        Dłuższe, oźródłowane analizy wychodzące poza pojedynczą liczbę — porównania
        międzynarodowe, mechanika niedoboru lekarzy i kształcenia. Każda teza z linkiem do
        źródła.
      </p>

      <div class="hub-grid">
        {analizy.map((a) => (
          <a class="hub-card" href={a.href}>
            <span class="hub-t">{a.t}</span>
            <span class="hub-d">{a.d}</span>
            <span class="hub-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>

      <p class="source-note" style="margin-top: 1.5rem">
        To dopiero początek działu — kolejne analizy w przygotowaniu. Zob. też
        <a href="/dane/">dane</a>, <a href="/mechanizmy/">mechanizmy</a> i
        <a href="/artykuly/">bazę artykułów</a>.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <ShareRow heading="Pomóż nagłośnić sprawę:" />
    </div>
  </section>
</BaseLayout>

<style>
  .hub-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
  .hub-card { position: relative; display: flex; flex-direction: column; gap: 0.35rem; background: var(--bg); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: 1.1rem 1.25rem; text-decoration: none; transition: border-color 0.15s, transform 0.15s; }
  .hub-card:hover { border-color: var(--brand); transform: translateY(-2px); }
  .hub-t { font-weight: 600; color: var(--ink); font-size: 1.02rem; }
  .hub-d { font-size: 0.88rem; color: var(--ink-soft); line-height: 1.45; }
  .hub-arrow { color: var(--brand); font-weight: 700; margin-top: 0.15rem; }
</style>
